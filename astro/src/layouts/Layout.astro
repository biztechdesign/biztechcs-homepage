---
import '../styles/global.css'
import '../styles/site.css'
---
<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/assets/biztech-icon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Enterprise Software Development, Delivered With US & EU Accountability | BiztechCS</title>
    <meta name="description" content="Custom enterprise software since 2006 — AI, ERP, ecommerce and cloud. 1,200+ projects, 98% client retention, ISO 27001/9001, IP you fully own. Book a 30-min call." />
    <link rel="canonical" href="https://www.biztechcs.com/" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Enterprise Software Development, Delivered With US & EU Accountability | BiztechCS" />
    <meta property="og:description" content="Custom enterprise software since 2006 — AI, ERP, ecommerce and cloud. 1,200+ projects, 98% client retention, ISO 27001/9001, IP you fully own." />
    <meta property="og:url" content="https://www.biztechcs.com/" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@flaticon/flaticon-uicons@3.3.1/css/all/all.css" />
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Biztech Consulting & Solutions",
        "alternateName": "BiztechCS",
        "url": "https://www.biztechcs.com/",
        "foundingDate": "2006",
        "description": "Enterprise software development & IT consulting since 2006 — AI, ERP, ecommerce and cloud — delivered with US & EU accountability and global engineering scale.",
        "areaServed": ["US", "GB", "EU", "AU", "AE"],
        "hasCredential": ["ISO 27001", "ISO 9001"],
        "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "80", "bestRating": "5" }
      },
      { "@context": "https://schema.org", "@type": "WebSite", "name": "BiztechCS", "url": "https://www.biztechcs.com/" },
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          { "@type": "Question", "name": "How do you handle time-zone differences?", "acceptedAnswer": { "@type": "Answer", "text": "We maintain daily working-hour overlap with US and European clients and have local offices in both regions — real-time collaboration during your day, plus progress overnight." } },
          { "@type": "Question", "name": "Who owns the intellectual property?", "acceptedAnswer": { "@type": "Answer", "text": "You do. We use US-style work-for-hire agreements with full IP transfer on payment, backed by NDAs and clear code ownership from day one." } },
          { "@type": "Question", "name": "How do you protect our data and stay compliant?", "acceptedAnswer": { "@type": "Answer", "text": "We're ISO 27001 and 9001 certified, with encryption, strict access controls, and GDPR-aligned data handling built into our processes." } },
          { "@type": "Question", "name": "What engagement models do you offer?", "acceptedAnswer": { "@type": "Answer", "text": "Dedicated teams, fixed-scope projects, or staff augmentation — all with transparent estimates and Agile delivery to avoid cost overruns." } },
          { "@type": "Question", "name": "How quickly can we get started?", "acceptedAnswer": { "@type": "Answer", "text": "Most engagements begin within 1–2 weeks of a scoping call. Book a free 30-minute call and we'll outline a plan." } }
        ]
      }
    ])} />
  </head>
  <body>
    <slot />
    <script>
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target) }
        }
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' })
      const observe = () => document.querySelectorAll('[data-reveal]:not(.in)').forEach((el) => io.observe(el))
      observe()
      document.addEventListener('astro:after-swap', observe)

      /* Sticky-reveal footer: reserve space below the page shell equal to the footer's
         height so the content scrolls up and uncovers the fixed footer beneath it.
         Only on wide screens; below 1025px the footer is a normal static block. */
      const shell = document.querySelector('.page-shell')
      const footer = document.querySelector('footer')
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      if (shell && footer && !reduce) {
        const sync = () => {
          if (window.innerWidth > 1024) {
            shell.style.marginBottom = footer.offsetHeight + 'px'
          } else {
            shell.style.marginBottom = ''
          }
        }
        sync()
        window.addEventListener('resize', sync, { passive: true })
        if (window.ResizeObserver) new ResizeObserver(sync).observe(footer)
      }

      /* WhyBiztech tilted-card carousel — transform-based slide (overflow scroll was blocked
         by the rotated cards, so we translateX the track instead). */
      const why = document.querySelector('#why')
      if (why) {
        const carousel = why.querySelector('.rcarousel')
        const track = why.querySelector('[data-rtrack]')
        const cards = track ? track.querySelectorAll('.rcard') : []
        if (carousel && track && cards.length) {
          let idx = 0
          const cardW = () => cards[0].offsetWidth + 22
          const maxIdx = () => {
            const visible = Math.max(1, Math.floor(carousel.clientWidth / cardW()))
            return Math.max(0, cards.length - visible)
          }
          const apply = () => {
            idx = Math.max(0, Math.min(idx, maxIdx()))
            track.style.setProperty('--rx', (-idx * cardW()) + 'px')
          }
          why.querySelector('[data-rnext]')?.addEventListener('click', () => { idx++; apply() })
          why.querySelector('[data-rprev]')?.addEventListener('click', () => { idx--; apply() })
          window.addEventListener('resize', apply, { passive: true })
          apply()
        }
      }
    </script>
  </body>
</html>
