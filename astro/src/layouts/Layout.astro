---
import '../styles/global.css'
import '../styles/site.css'

const SITE = 'https://www.biztechcs.com'

// Global schema present on every page (Organization + WebSite). Page-specific
// schema (Service, Article, JobPosting, FAQPage, …) is passed in via `jsonLd`.
const ORG_SCHEMA = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Biztech Consulting & Solutions',
  alternateName: 'BiztechCS',
  url: `${SITE}/`,
  logo: `${SITE}/wp-content/uploads/2023/05/biztech-logo.svg`,
  foundingDate: '2006',
  description: 'Enterprise software development & IT consulting since 2006 — AI, ERP, ecommerce and cloud — delivered with US & EU accountability and global engineering scale.',
  areaServed: ['US', 'GB', 'EU', 'AU', 'AE'],
  hasCredential: ['ISO 27001', 'ISO 9001'],
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '80', bestRating: '5' },
}
const WEBSITE_SCHEMA = { '@context': 'https://schema.org', '@type': 'WebSite', name: 'BiztechCS', url: `${SITE}/` }

interface Props {
  title?: string
  description?: string
  canonical?: string        // full URL; if omitted, derived from the page path
  ogImage?: string          // absolute or root-relative; defaults to brand image
  ogType?: string           // 'website' | 'article' | …
  jsonLd?: object[]         // page-specific schema objects to merge with the global Org/WebSite pair
}

const {
  title = 'Enterprise Software Development, Delivered With US & EU Accountability | BiztechCS',
  description = 'Custom enterprise software since 2006 — AI, ERP, ecommerce and cloud. 1,200+ projects, 98% client retention, ISO 27001/9001, IP you fully own. Book a 30-min call.',
  canonical,
  ogImage = `${SITE}/wp-content/uploads/2023/05/biztech-og.jpg`,
  ogType = 'website',
  jsonLd = [],
} = Astro.props

// Map the GitHub-Pages base path (/biztechcs-homepage/…) to a clean production URL.
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '')   // e.g. "/biztechcs-homepage"
const path = Astro.url.pathname.replace(BASE, '') || '/'
const canonicalUrl = canonical ?? `${SITE}${path === '/' ? '/' : path.replace(/\/$/, '/')}`

const schema = [ORG_SCHEMA, WEBSITE_SCHEMA, ...jsonLd]
---
<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/assets/biztech-icon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="BiztechCS" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@flaticon/flaticon-uicons@3.3.1/css/all/all.css" />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <slot name="head" />
  </head>
  <body>
    <slot />
    <script>
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target) }
        }
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' })
      const observe = () => document.querySelectorAll('[data-reveal]:not(.in)').forEach((el) => io.observe(el))
      observe()
      document.addEventListener('astro:after-swap', observe)

      /* Sticky-reveal footer: reserve space below the page shell equal to the footer's
         height so the content scrolls up and uncovers the fixed footer beneath it.
         Only on wide screens; below 1025px the footer is a normal static block. */
      const shell = document.querySelector('.page-shell')
      const footer = document.querySelector('.site-footer')
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      if (shell && footer && !reduce) {
        const sync = () => {
          if (window.innerWidth > 1024) {
            shell.style.marginBottom = footer.offsetHeight + 'px'
          } else {
            shell.style.marginBottom = ''
          }
        }
        sync()
        window.addEventListener('resize', sync, { passive: true })
        if (window.ResizeObserver) new ResizeObserver(sync).observe(footer)
      }

    </script>
  </body>
</html>
