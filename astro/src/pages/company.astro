<script>
  // Life @ Biztech — click to play the office-tour video inline
  const life = document.getElementById('coLife')
  if (life) {
    const play = life.querySelector('.co-life-play')
    play?.addEventListener('click', () => {
      const src = life.dataset.video
      const poster = life.querySelector('.co-life-poster')
      const v = document.createElement('video')
      v.src = src
      v.controls = true
      v.autoplay = true
      v.playsInline = true
      v.preload = 'metadata'
      if (poster) poster.replaceWith(v)
      life.classList.add('playing')
      v.play().catch(() => {})
    })
  }
</script>
