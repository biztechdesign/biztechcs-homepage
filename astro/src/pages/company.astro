---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import CtaButton from '../components/CtaButton.astro'
import Faq from '../components/Faq.astro'
import CtaBand from '../components/CtaBand.astro'

const BASE = import.meta.env.BASE_URL
const CDN = 'https://www.biztechcs.com/wp-content/uploads'

const CLIENTS = [
  { name: 'Forbes Marshall', src: `${CDN}/2023/05/forbes-marshall.png` },
  { name: 'Bonfiglioli', src: `${CDN}/2023/05/bonfiglioli.png` },
  { name: 'Ovivo', src: `${CDN}/2023/05/Ovivo.svg` },
  { name: 'Biorbyt', src: `${CDN}/2023/05/Biorbyt.svg` },
  { name: 'Medguard', src: `${CDN}/2023/05/medguard.png` },
]
const BADGES = [
  { name: 'Clutch', src: `${BASE}/assets/badges/clutch.svg` },
  { name: 'Google Premier Partner 2024', src: `${BASE}/assets/badges/google-partner.svg` },
  { name: 'GESIA Member', src: `${BASE}/assets/badges/gesia.svg` },
  { name: 'Salesforce ISV Partner', src: `${BASE}/assets/badges/salesforce-isv.svg` },
  { name: 'Top App Development Companies', src: `${BASE}/assets/badges/tadc.svg` },
  { name: 'SugarCRM ISV Partner', src: `${BASE}/assets/badges/sugarcrm.png` },
  { name: 'Techimply', src: `${BASE}/assets/badges/techimply.svg` },
  { name: 'TÜV certified', src: `${BASE}/assets/badges/tuv.svg` },
  { name: 'Great Place To Work', src: `${BASE}/assets/badges/gptw.svg` },
  { name: 'Odoo Partner', src: `${BASE}/assets/badges/odoo.svg` },
]

// ── By the numbers ──
const STATS = [
  { n: '19+', label: 'Years in business', sub: 'Engineering since 2006' },
  { n: '1300+', label: 'Projects delivered', sub: 'Across 40+ countries' },
  { n: '200+', label: 'Team members', sub: 'Engineers, designers & PMs' },
  { n: '98%', label: 'Client retention', sub: 'Teams that come back' },
  { n: '55+', label: 'Products built', sub: '10,300+ installations' },
  { n: '4.9/5', label: 'Rated on Clutch', sub: 'From verified reviews' },
]

// ── Ventures ──
const VENTURES = [
  { ic: 'fi-rr-print', name: 'PrintXpand', tag: 'Web-to-Print', desc: 'End-to-end web-to-print storefronts, design tools and print ERP — powering thousands of print stores.' },
  { ic: 'fi-rr-comment-user', name: 'CRMJetty', tag: 'Portals & CRM', desc: 'Customer & vendor portals for Salesforce, Dynamics, SuiteCRM and SugarCRM.' },
  { ic: 'fi-rr-apps-add', name: 'AppJetty', tag: 'Extensions', desc: 'A marketplace of ecommerce and CRM extensions used by businesses worldwide.' },
  { ic: 'fi-rr-headset', name: 'ServiceXpand', tag: 'Field Service', desc: 'Operations software that streamlines scheduling and delivery for service businesses.' },
]

// ── Global offices (img = representative city/country stock photo) ──
const OFFICES = [
  { code: 'us', name: 'USA', city: 'Wilmington, Delaware', accent: '#0EA5E9', img: 'https://images.unsplash.com/photo-1630848327020-e6666059e587?auto=format&fit=crop&w=600&q=70' },
  { code: 'in', name: 'India', city: 'Ahmedabad, Gujarat', accent: '#7C3AED', img: 'https://images.unsplash.com/photo-1631589984116-1d60a32f391b?auto=format&fit=crop&w=600&q=70' },
  { code: 'es', name: 'Spain', city: 'Barcelona', accent: '#10B981', img: 'https://images.unsplash.com/photo-1583422409516-2895a77efded?auto=format&fit=crop&w=600&q=70' },
  { code: 'de', name: 'Germany', city: 'Berlin', accent: '#F43F5E', img: 'https://images.unsplash.com/photo-1560969184-10fe8719e047?auto=format&fit=crop&w=600&q=70' },
]

// ── Life at Biztech (real culture/team photos) ──
const LIFE_PHOTOS = [
  { src: `${CDN}/2023/11/life-biztech-11-1.webp`, alt: 'The BiztechCS team together' },
  { src: `${CDN}/2023/11/life-biztech-3-1-1.webp`, alt: 'Inside the BiztechCS office' },
  { src: `${CDN}/2025/03/cricket-league-25-1.webp`, alt: 'BiztechCS cricket league' },
  { src: `${CDN}/2023/11/life-biztech-5-1-2.webp`, alt: 'A learning session at BiztechCS' },
  { src: `${CDN}/2023/11/life-biztech-4-1-1-1.webp`, alt: 'The BiztechCS game room' },
]

// ── Leadership ──
const T = `${BASE}/assets/team`
const LEADERS = [
  { name: 'Maulik Shah', role: 'Founder & CEO', img: `${T}/maulik.png` },
  { name: 'Amit Shah', role: 'Chief Financial Officer', img: `${T}/amit.png` },
  { name: 'Kinjal Shah', role: 'Chief Human Resources Officer', img: `${T}/kinjal.png` },
  { name: 'Parth Pandya', role: 'AVP — Marketing', img: `${T}/parth.png` },
  { name: 'Divyang Sonchhatra', role: 'AVP — Sales', img: `${T}/divyang.webp` },
  { name: 'Jay Jagani', role: 'Sr. Product Manager', img: `${T}/jay.png` },
]

// ── Values (5 pillars) ──
const VALUES = [
  { ic: 'fi-rr-heart', title: 'Customer first', desc: 'Every decision starts with the outcome for your business, not ours.' },
  { ic: 'fi-rr-graduation-cap', title: 'Always learning', desc: 'Continuous upskilling so our teams stay ahead of the technology curve.' },
  { ic: 'fi-rr-microchip', title: 'Advanced by default', desc: 'We adopt the best modern tools and engineering practices — early.' },
  { ic: 'fi-rr-shield-check', title: 'Quality mindset', desc: 'Quality is built into every process, project and product we ship.' },
  { ic: 'fi-rr-refresh', title: 'Continual improvement', desc: 'We refine how we work, relentlessly — in people, process and product.' },
]

// ── Why choose us (competitive advantages) ──
const WHYUS = [
  { ic: 'fi-rr-shield-check', title: 'US & EU accountability', desc: 'Senior project leads in your time zone, daily overlap, and clear ownership end to end.' },
  { ic: 'fi-rr-rocket-lunch', title: 'Real product DNA', desc: 'We build and run our own products — PrintXpand, CRMJetty and more. We engineer for the long haul.' },
  { ic: 'fi-rr-layers', title: 'Full-stack delivery', desc: 'Strategy, design, engineering, QA, DevOps and support — one accountable team, not handoffs.' },
  { ic: 'fi-rr-lock', title: 'IP you fully own', desc: 'Work-for-hire with full IP transfer on payment, backed by NDAs from day one.' },
  { ic: 'fi-rr-diploma', title: 'Certified & secure', desc: 'ISO 27001 & 9001 certified, with security and GDPR-aligned data handling built in.' },
  { ic: 'fi-rr-chart-line-up', title: 'Proven at scale', desc: '1,300+ projects across 40+ countries since 2006, with 98% client retention.' },
]

// ── Awards & recognition (titles + the badge logos above) ──
const AWARDS = [
  'TÜV ISO 27001 & 9001 certified', 'Google Premier Partner 2024', 'Salesforce ISV Partner',
  'Great Place To Work certified', 'Clutch — Top B2B (4.9/5)', 'Top App Development Companies',
  'GESIA IT Association member', 'Techimply — Top eCommerce dev',
]

// ── Testimonials ──
const TESTIMONIALS = [
  { quote: 'Biztech has been a genuine technology partner — they understand the product, not just the tickets.', name: 'Adam Harvey', role: 'Co-founder & CEO, Proofed Inc', av: 'AH' },
  { quote: 'We can always count on Team Biztech. They feel like an extension of our own team.', name: 'Fernando Delgado', role: 'CIO, El Camino Real Charter High School', av: 'FD' },
  { quote: 'It was a pleasant journey — I am very happy with the results and the way they delivered.', name: 'Alexander', role: 'BigFoot B.V', av: 'AX' },
]

// ── Company FAQ ──
const FAQS = [
  { q: 'Where are your offices?', a: 'We have offices in the USA (Wilmington, Delaware), Spain (Barcelona), Germany (Berlin) and our engineering core in Ahmedabad, India — so you get local accountability with global scale.' },
  { q: 'How do you handle time-zone differences?', a: 'We maintain daily working-hour overlap with US and European clients and have local project leads in both regions — real-time collaboration during your day, plus progress overnight.' },
  { q: 'Is my data and IP safe?', a: 'Yes. We\'re ISO 27001 and 9001 certified, with encryption, strict access controls and GDPR-aligned handling. You own all IP via work-for-hire agreements backed by NDAs.' },
  { q: 'How big is your team and can you scale?', a: '200+ engineers, designers and project managers across four offices. We scale teams up or down to match your roadmap — from a single specialist to a full multi-pod squad.' },
  { q: 'How do we start working together?', a: 'Book a free 30-minute call with a senior engineer. We\'ll scope your needs and most engagements begin within 1–2 weeks.' },
]

const TITLE = 'About BiztechCS | Software Development Company'
const DESCRIPTION = 'About BiztechCS — an enterprise software development company since 2006. 200+ engineers across 4 offices, 1,300+ projects, ISO 27001/9001. Meet the team.'

const JSONLD = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: FAQS.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
]
---
<Layout title={TITLE} description={DESCRIPTION} jsonLd={JSONLD}>
  <Header />
  <div class="page-shell">

    <!-- ───────── HERO ───────── -->
    <section class="co-hero relative overflow-hidden" id="top">
      <span class="co-hero-grid" aria-hidden="true"></span>
      <span class="co-hero-glow" aria-hidden="true"></span>
      <div class="wrap relative">
        <div class="co-hero-grid-cols">
          <div>
            <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk">
              <i class="fi fi-rr-building text-teal"></i> About BiztechCS
            </span>
            <h1 data-reveal style="--d:.06s" class="mt-6 text-[clamp(34px,5.2vw,60px)] font-black tracking-[-0.04em] leading-[1.06] text-ink">
              Reinventing success <span class="accent">with digital solutions.</span>
            </h1>
            <p data-reveal style="--d:.12s" class="mt-7 text-[clamp(16px,1.3vw,18px)] leading-[1.65] text-muted max-w-[540px]">
              What began in 2006 as one person's vision is now a 200+ strong team across the US, Europe and India — building enterprise software with craft, accountability and a customers-first mindset.
            </p>
            <div data-reveal style="--d:.18s" class="mt-9 flex flex-wrap gap-3">
              <CtaButton href="#cta" label="Work with us" variant="dark" />
              <a href="#ventures" class="co-ghost">Our ventures <i class="fi fi-rr-arrow-down"></i></a>
            </div>
            <div data-reveal style="--d:.26s" class="co-hero-clients">
              <span class="co-hc-label">Trusted by <b>200+</b> companies</span>
              <ul class="co-hc-logos">{CLIENTS.map((c) => <li><img src={c.src} alt={c.name} loading="lazy" /></li>)}</ul>
            </div>
          </div>

          <!-- company snapshot -->
          <div data-reveal style="--d:.16s" class="co-snap" role="img" aria-label="BiztechCS at a glance">
            <div class="co-snap-main">
              <img src={`${BASE}/assets/biztech-icon.svg`} alt="" class="co-snap-mark" />
              <b>Since 2006</b>
              <span>Integrating Business &amp; Technology</span>
            </div>
            <span class="co-badge co-b1"><b>1300+</b> projects</span>
            <span class="co-badge co-b2"><b>200+</b> team</span>
            <span class="co-badge co-b3"><b>4</b> global offices</span>
            <span class="co-badge co-b4"><i class="fi fi-rr-shield-check"></i> ISO 27001</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ───────── TRUST BOX ───────── -->
    <section id="trust" aria-label="Certifications and track record" class="pt-[clamp(16px,2vw,28px)] pb-[clamp(8px,1vw,16px)]">
      <div class="wrap">
        <div data-reveal class="co-trustbox">
          <div class="co-tx-left">
            <span class="co-tbx-label"><i class="fi fi-rr-shield-check"></i> Recognized<br/>&amp; certified</span>
            <div class="co-tx-track">
              <div class="co-tx-row">
                {BADGES.map((b) => <span class="co-tx-logo"><img src={b.src} alt={b.name} title={b.name} loading="lazy" /></span>)}
                {BADGES.map((b) => <span class="co-tx-logo" aria-hidden="true"><img src={b.src} alt="" loading="lazy" /></span>)}
              </div>
            </div>
          </div>
          <div class="co-tx-right">
            <div class="co-tb-item"><div class="co-tn accent">1300+</div><div class="co-tl">Projects</div></div>
            <div class="co-tb-item"><div class="co-tn accent">98%</div><div class="co-tl">Retention</div></div>
            <div class="co-tb-item"><div class="co-tn accent">4.9</div><div class="co-tl">Clutch rating</div></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ───────── MISSION + STORY ───────── -->
    <section class="py-[var(--section-y)]">
      <div class="wrap">
        <div class="co-mission-grid">
          <div>
            <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk"><i class="fi fi-rr-compass-alt text-teal"></i> Our story</span>
            <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(26px,3.6vw,44px)] font-black tracking-[-0.04em] leading-[1.06]">From one engineer to an <span class="accent">IT powerhouse.</span></h2>
            <p data-reveal style="--d:.12s" class="mt-6 text-[15px] leading-[1.7] text-muted max-w-[520px]">In 2006, Maulik Shah founded Biztech with a simple vision — bridge the gap between business and technology. Nineteen years on, that one-person startup is a global team that has delivered 1,300+ projects and launched four product ventures, while keeping the same customers-first values it started with.</p>
            <div data-reveal style="--d:.18s" class="mt-7 flex flex-col gap-4">
              <div class="co-mv"><span class="co-mv-ic"><i class="fi fi-rr-bullseye-arrow"></i></span><div><b class="block text-[15px] font-extrabold text-ink">Mission</b><p class="text-[14px] text-muted leading-[1.55] mt-0.5">Bring positive change to people's lives by delivering best-in-class digital solutions.</p></div></div>
              <div class="co-mv"><span class="co-mv-ic"><i class="fi fi-rr-telescope"></i></span><div><b class="block text-[15px] font-extrabold text-ink">Vision</b><p class="text-[14px] text-muted leading-[1.55] mt-0.5">To be a top-three IT enterprise in our segment across the Americas, Europe and Asia.</p></div></div>
            </div>
          </div>
          <!-- by the numbers -->
          <div data-reveal style="--d:.14s" class="co-num-grid">
            {STATS.map((s) => (
              <div class="co-num">
                <div class="co-num-n accent">{s.n}</div>
                <div class="co-num-l">{s.label}</div>
                <div class="co-num-s">{s.sub}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ───────── LIFE @ BIZTECH (office tour video) ───────── -->
    <section class="py-[var(--section-y)]">
      <div class="wrap">
        <figure data-reveal class="co-life" id="coLife" data-video={`${CDN}/2023/05/Biztechcs-1.mp4`}>
          <img class="co-life-poster" src={`${CDN}/2023/05/Biztech-office-tour_b-1.webp`} alt="The BiztechCS team at our office" loading="lazy" />
          <button class="co-life-play" type="button" aria-label="Play the BiztechCS office tour">
            <span class="co-life-ring" aria-hidden="true"></span>
            <i class="fi fi-sr-play"></i>
          </button>
          <figcaption class="co-life-cap">
            <span class="co-life-label"><i class="fi fi-rr-play-circle"></i> Take a tour</span>
            <p>200+ dreamers and doers — one culture, four offices, building together since 2006.</p>
          </figcaption>
        </figure>
      </div>
    </section>

    <!-- ───────── VENTURES (dark band) ───────── -->
    <section id="ventures" class="surface-dark py-[var(--section-y)]">
      <div class="wrap">
        <div class="text-center mb-[clamp(36px,4vw,52px)]">
          <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em]"><i class="fi fi-rr-rocket-lunch"></i> Our ventures</span>
          <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(28px,4vw,48px)] font-black tracking-[-0.04em] leading-[1.05] text-white max-w-[680px] mx-auto">We don't just build software — <span class="accent-l">we ship products.</span></h2>
          <p data-reveal style="--d:.12s" class="mt-5 text-[clamp(15px,1.2vw,17px)] leading-[1.6] text-white/55 max-w-[560px] mx-auto">Four product ventures, built and run in-house — proof we engineer for the long haul, not just the project.</p>
        </div>
        <div class="grid grid-cols-4 gap-[16px] max-[900px]:grid-cols-2 max-[480px]:grid-cols-1">
          {VENTURES.map((v, i) => (
            <div data-reveal style={`--d:${(0.1 + i * 0.06).toFixed(2)}s`} class="co-venture group">
              <span class="co-venture-ic"><i class={`fi ${v.ic}`}></i></span>
              <span class="co-venture-tag">{v.tag}</span>
              <h3 class="mt-2 text-[19px] font-extrabold tracking-[-0.02em] text-white">{v.name}</h3>
              <p class="mt-2 text-[13.5px] leading-[1.55] text-white/60">{v.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ───────── GLOBAL PRESENCE ───────── -->
    <section class="py-[var(--section-y)]">
      <div class="wrap">
        <div class="flex flex-wrap items-end justify-between gap-6 mb-[clamp(36px,4vw,52px)]">
          <div class="max-w-[640px]">
            <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk"><i class="fi fi-rr-globe text-teal"></i> Global presence</span>
            <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(28px,4vw,48px)] font-black tracking-[-0.04em] leading-[1.05]">Four offices, <span class="accent">one team.</span></h2>
          </div>
          <p data-reveal style="--d:.12s" class="text-[14px] font-semibold text-muted max-w-[320px] max-[680px]:max-w-none">Time-zone-aligned delivery with US &amp; EU project leads and a global engineering core in India.</p>
        </div>
        <div class="grid grid-cols-4 gap-[16px] max-[820px]:grid-cols-2 max-[480px]:grid-cols-1">
          {OFFICES.map((o, i) => (
            <div data-reveal style={`--d:${(0.1 + i * 0.06).toFixed(2)}s;--accent:${o.accent}`} class="co-office group">
              <div class="co-office-img">
                <img src={o.img} alt={`${o.name} office location`} loading="lazy" />
                <img class="co-office-flag" src={`https://flagcdn.com/w80/${o.code}.png`} alt={`${o.name} flag`} loading="lazy" />
              </div>
              <div class="co-office-body">
                <h3 class="text-[19px] font-extrabold tracking-[-0.02em] text-ink">{o.name}</h3>
                <p class="mt-1 text-[13.5px] text-muted flex items-center gap-1.5"><i class="fi fi-rr-marker text-[12px]" style={`color:${o.accent}`}></i> {o.city}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ───────── LEADERSHIP ───────── -->
    <section class="surface-tint py-[var(--section-y)]">
      <div class="wrap">
        <!-- team strength banner — premium panel -->
        <div data-reveal class="co-team-card">
          <span class="co-team-orb" aria-hidden="true"></span>
          <div class="co-team-banner">
            <div class="co-team-copy">
              <span class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk"><i class="fi fi-rr-users-alt text-teal"></i> Our team</span>
              <h2 class="mt-5 leading-[.9]"><span class="co-team-num accent">200+</span><span class="block mt-2 text-[clamp(22px,3vw,34px)] font-black tracking-[-0.04em] text-ink">people. One team, four offices.</span></h2>
              <p class="mt-5 text-[15px] leading-[1.65] text-muted max-w-[460px]">From a one-person startup in 2006 to <b class="text-ink">200+ engineers, designers and project managers</b> across the US, Europe and India — dreamers and doers who innovate every day.</p>
              <ul class="co-team-meta">
                <li><i class="fi fi-rr-globe"></i> 4 global offices</li>
                <li><i class="fi fi-rr-graduation-cap"></i> 80% senior engineers</li>
                <li><i class="fi fi-rr-calendar"></i> 19+ years strong</li>
              </ul>
            </div>
            <div class="co-team-visual">
              <div class="co-avatars">
                {LEADERS.map((p) => <span class="co-av"><img src={p.img} alt="" loading="lazy" /></span>)}
                <span class="co-av co-av-more">+200</span>
              </div>
              <p class="co-team-cap">The people you'll actually work with.</p>
            </div>
          </div>
        </div>

        <!-- leadership -->
        <div class="flex flex-wrap items-end justify-between gap-6 mt-[clamp(48px,6vw,72px)] mb-[clamp(28px,3.4vw,40px)]">
          <h3 data-reveal class="text-[clamp(20px,2.4vw,28px)] font-black tracking-[-0.03em] text-ink">Meet the <span class="accent">leadership.</span></h3>
          <a data-reveal style="--d:.06s" href={`${BASE}/leadership`} class="co-all inline-flex items-center gap-2 text-[14.5px] font-bold text-ink whitespace-nowrap">View full team <i class="fi fi-rr-arrow-right"></i></a>
        </div>
        <div class="grid grid-cols-6 gap-[16px] max-[900px]:grid-cols-3 max-[520px]:grid-cols-2">
          {LEADERS.map((p, i) => (
            <article data-reveal style={`--d:${(0.1 + i * 0.06).toFixed(2)}s`} class="co-leader rounded-3xl bg-white border border-line overflow-hidden">
              <div class="co-leader-photo"><img src={p.img} alt={p.name} loading="lazy" /></div>
              <div class="px-4 py-3.5">
                <b class="block text-[14px] font-extrabold tracking-[-0.01em] text-ink leading-tight">{p.name}</b>
                <span class="mt-0.5 block text-[12px] font-semibold text-muted leading-snug">{p.role}</span>
              </div>
            </article>
          ))}
        </div>

        <!-- life at biztech — real team photos -->
        <div class="flex items-end justify-between gap-6 mt-[clamp(48px,6vw,72px)] mb-[clamp(24px,3vw,36px)]">
          <div>
            <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk"><i class="fi fi-rr-confetti text-teal"></i> Life at Biztech</span>
            <h3 data-reveal style="--d:.06s" class="mt-3 text-[clamp(20px,2.4vw,28px)] font-black tracking-[-0.03em] text-ink">Where work feels <span class="accent">like family.</span></h3>
          </div>
          <a data-reveal style="--d:.06s" href="https://www.biztechcs.com/life-at-biztech/" target="_blank" rel="noopener" class="co-all inline-flex items-center gap-2 text-[14.5px] font-bold text-ink whitespace-nowrap max-[640px]:hidden">See more <i class="fi fi-rr-arrow-right"></i></a>
        </div>
        <div class="co-gallery">
