---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Hero from '../components/Hero.astro'
import TrustBand from '../components/TrustBand.astro'
import WhatWeDo from '../components/WhatWeDo.astro'
import AiNative from '../components/AiNative.astro'
import Industries from '../components/Industries.astro'
import About from '../components/About.astro'
import Leadership from '../components/Leadership.astro'
import WhyBiztech from '../components/WhyBiztech.astro'
import Process from '../components/Process.astro'
import EngagementModels from '../components/EngagementModels.astro'
import Testimonials from '../components/Testimonials.astro'
import SuccessStories from '../components/SuccessStories.astro'
import Results from '../components/Results.astro'
import CaseStudy from '../components/CaseStudy.astro'
import Blog from '../components/Blog.astro'
import TechStack from '../components/TechStack.astro'
import Faq from '../components/Faq.astro'
import Contact from '../components/Contact.astro'
import GlobalOffices from '../components/GlobalOffices.astro'
import Footer from '../components/Footer.astro'

const TITLE = 'Enterprise Software Development Company | BiztechCS'
const DESCRIPTION = 'Custom enterprise software since 2006 — AI, ERP, ecommerce and cloud. 1,200+ projects, 98% retention, ISO 27001/9001, IP you fully own. Book a 30-min call.'

const JSONLD = [
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'How do you handle time-zone differences?', acceptedAnswer: { '@type': 'Answer', text: 'We maintain daily working-hour overlap with US and European clients and have local offices in both regions — real-time collaboration during your day, plus progress overnight.' } },
      { '@type': 'Question', name: 'Who owns the intellectual property?', acceptedAnswer: { '@type': 'Answer', text: 'You do. We use US-style work-for-hire agreements with full IP transfer on payment, backed by NDAs and clear code ownership from day one.' } },
      { '@type': 'Question', name: 'How do you protect our data and stay compliant?', acceptedAnswer: { '@type': 'Answer', text: "We're ISO 27001 and 9001 certified, with encryption, strict access controls, and GDPR-aligned data handling built into our processes." } },
      { '@type': 'Question', name: 'What engagement models do you offer?', acceptedAnswer: { '@type': 'Answer', text: 'Dedicated teams, fixed-scope projects, or staff augmentation — all with transparent estimates and Agile delivery to avoid cost overruns.' } },
      { '@type': 'Question', name: 'How quickly can we get started?', acceptedAnswer: { '@type': 'Answer', text: "Most engagements begin within 1–2 weeks of a scoping call. Book a free 30-minute call and we'll outline a plan." } },
    ],
  },
]
---
<Layout title={TITLE} description={DESCRIPTION} jsonLd={JSONLD}>
  <Header />
  <div class="page-shell">
    <Hero />
    <TrustBand />
    <WhyBiztech />
    <WhatWeDo />
    <AiNative />
    <Industries />
    <Testimonials />
    <SuccessStories />
    <Results />
    <Leadership />
    <CaseStudy />
    <About />
    <GlobalOffices />
    <Process />
    <EngagementModels />
    <TechStack />
    <Blog />
    <Faq />
    <Contact />
  </div>
  <Footer />
</Layout>
