---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import CtaButton from '../components/CtaButton.astro'
import TrustBand from '../components/TrustBand.astro'
import Faq from '../components/Faq.astro'
import CtaBand from '../components/CtaBand.astro'

const BASE = import.meta.env.BASE_URL
const CDN = 'https://www.biztechcs.com/wp-content/uploads'
const APPLY = 'https://career.biztechcs.com/'

// hero proof stats
const STATS = [
  { n: '200+', label: 'Team members' },
  { n: '4', label: 'Global offices' },
  { n: '5-day', label: 'Work week' },
  { n: '19+', label: 'Years strong' },
]

// ── Why join (the pitch) ──
const WHYJOIN = [
  { ic: 'fi-rr-rocket-lunch', t: 'Enterprise-level projects', d: 'Work on real products and platforms used by businesses in 40+ countries — not throwaway tickets.' },
  { ic: 'fi-rr-graduation-cap', t: 'Sponsored certifications', d: 'We pay for the certifications and courses that move your career forward — learning is part of the job.' },
  { ic: 'fi-rr-users-alt', t: 'Senior mentorship', d: 'Learn directly from senior engineers and operators. 80% of our team is senior — you grow fast here.' },
  { ic: 'fi-rr-microchip', t: 'Advanced tech, early', d: 'Access to modern tools, AI tooling and the best engineering practices — adopted early, by default.' },
  { ic: 'fi-rr-chart-line-up', t: 'Future leaders', d: 'We hire for personality and potential, then promote from within. Many leads started as juniors.' },
  { ic: 'fi-rr-heart', t: 'Work that feels worth it', d: 'A culture where Monday blues turn into fun conversations over coffee — and real impact.' },
]

// ── Perks & benefits (from the live careers page) ──
const PERKS = [
  { ic: 'fi-rr-calendar', t: '5-day work week' },
  { ic: 'fi-rr-apps', t: 'Enterprise projects' },
  { ic: 'fi-rr-confetti', t: 'Regular leisure activities' },
  { ic: 'fi-rr-diploma', t: 'Sponsored certifications' },
  { ic: 'fi-rr-chalkboard-user', t: 'Training from experts' },
  { ic: 'fi-rr-trophy', t: 'Annual awards' },
  { ic: 'fi-rr-balloons', t: 'Fun events & celebrations' },
  { ic: 'fi-rr-chair-office', t: 'Ergonomic infrastructure' },
  { ic: 'fi-rr-bulb', t: 'Advanced technologies' },
  { ic: 'fi-rr-refresh', t: 'Agile learning org' },
]

// ── Open roles (link to the real apply flow) ──
const ROLES = [
  { title: 'Senior Software Engineer', dept: 'Engineering', loc: 'Ahmedabad, India', type: 'Full-time' },
  { title: 'AI / ML Engineer', dept: 'AI & Data', loc: 'Ahmedabad, India', type: 'Full-time' },
  { title: 'Salesforce Developer', dept: 'Enterprise Platforms', loc: 'Ahmedabad, India', type: 'Full-time' },
  { title: 'Odoo Consultant', dept: 'ERP', loc: 'Ahmedabad / Remote', type: 'Full-time' },
  { title: 'UI/UX Designer', dept: 'Design', loc: 'Ahmedabad, India', type: 'Full-time' },
  { title: 'Project Manager', dept: 'Delivery', loc: 'Ahmedabad, India', type: 'Full-time' },
]

// ── Hiring process ──
const STEPS = [
  { n: '01', t: 'Apply', d: 'Send your CV through our careers portal — tell us what you want to build, not just what you\'ve done.' },
  { n: '02', t: 'Tech screen', d: 'A focused conversation with senior engineers about how you think and solve real problems.' },
  { n: '03', t: 'Team & culture fit', d: 'Meet the people you\'d work with day to day — we hire for personality as much as skill.' },
  { n: '04', t: 'Offer & onboard', d: 'A clear offer, a structured onboarding, and a mentor from day one.' },
]

// ── Life at Biztech (real culture photos) ──
const LIFE_PHOTOS = [
  { src: `${CDN}/2023/11/life-biztech-11-1.webp`, alt: 'The BiztechCS team together' },
  { src: `${CDN}/2023/11/life-biztech-3-1-1.webp`, alt: 'Inside the BiztechCS office' },
  { src: `${CDN}/2025/03/cricket-league-25-1.webp`, alt: 'BiztechCS cricket league' },
  { src: `${CDN}/2023/11/life-biztech-5-1-2.webp`, alt: 'A learning session at BiztechCS' },
  { src: `${CDN}/2023/11/life-biztech-4-1-1-1.webp`, alt: 'The BiztechCS game room' },
]

// ── Careers FAQ ──
const FAQS = [
  { q: 'Do you hire freshers or only experienced engineers?', a: 'Both. We hire for personality and potential as much as experience — many of our leads started as juniors and grew through sponsored learning and senior mentorship.' },
  { q: 'Is the role remote, hybrid or in-office?', a: 'Most engineering roles are based at our Ahmedabad office with hybrid flexibility; some roles offer remote. The location is listed on each opening.' },
  { q: 'What does the hiring process look like?', a: 'Apply → a focused technical screen with senior engineers → a team & culture-fit conversation → offer and structured onboarding with a mentor from day one.' },
  { q: 'What benefits do you offer?', a: 'A 5-day work week, sponsored certifications, expert-led training, enterprise-level projects, annual awards, regular leisure activities and ergonomic infrastructure — among others.' },
  { q: 'I don\'t see a role that fits. Can I still apply?', a: 'Yes — we\'re always keen to meet great people. Send us your CV through the careers portal and tell us what you\'d love to build.' },
]
---
<Layout>
  <Header />
  <div class="page-shell">

    <!-- ───────── HERO ───────── -->
    <section class="cr-hero relative overflow-hidden" id="top">
      <span class="cr-hero-grid" aria-hidden="true"></span>
      <span class="cr-hero-glow" aria-hidden="true"></span>
      <div class="wrap relative">
        <div class="cr-hero-cols">
          <div>
            <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk">
              <i class="fi fi-rr-briefcase text-teal"></i> Careers at BiztechCS
            </span>
            <h1 data-reveal style="--d:.06s" class="mt-6 text-[clamp(34px,5.2vw,60px)] font-black tracking-[-0.045em] leading-[1.04] text-ink max-w-[640px]">
              Build a career worth <span class="accent">working for.</span>
            </h1>
            <p data-reveal style="--d:.12s" class="mt-7 text-[clamp(16px,1.3vw,18px)] leading-[1.65] text-muted max-w-[540px]">
              Join 200+ engineers, designers and PMs building enterprise software since 2006. We hire for personality and potential — then back you with senior mentorship, sponsored learning and real projects.
            </p>
            <div data-reveal style="--d:.18s" class="mt-9 flex flex-wrap gap-3">
              <CtaButton href="#openings" label="See open roles" variant="dark" />
              <a href={APPLY} target="_blank" rel="noopener" class="cr-ghost">Apply now <i class="fi fi-rr-arrow-up-right"></i></a>
            </div>
            <div data-reveal style="--d:.26s" class="cr-stats">
              {STATS.map((s, i) => (
                <div class="cr-stat">
                  <div class="cr-stat-n">{s.n}</div>
                  <div class="cr-stat-l">{s.label}</div>
                  {i < STATS.length - 1 && <span class="cr-stat-div" aria-hidden="true"></span>}
                </div>
              ))}
            </div>
          </div>

          <!-- culture photo collage -->
          <div data-reveal style="--d:.16s" class="cr-hero-art">
            <figure class="cr-art-main"><img src={LIFE_PHOTOS[0].src} alt={LIFE_PHOTOS[0].alt} loading="lazy" /></figure>
            <figure class="cr-art-side cr-art-s1"><img src={LIFE_PHOTOS[2].src} alt={LIFE_PHOTOS[2].alt} loading="lazy" /></figure>
            <figure class="cr-art-side cr-art-s2"><img src={LIFE_PHOTOS[4].src} alt={LIFE_PHOTOS[4].alt} loading="lazy" /></figure>
            <span class="cr-art-badge"><i class="fi fi-rr-confetti"></i> Great Place To Work</span>
          </div>
        </div>
      </div>
    </section>

    <!-- recognized & certified (shared) -->
    <TrustBand />

    <!-- ───────── WHY JOIN ───────── -->
    <section id="why" class="py-[var(--section-y)]">
      <div class="wrap">
        <div class="text-center mb-[clamp(36px,4vw,52px)]">
          <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk"><i class="fi fi-rr-diamond text-teal"></i> Why BiztechCS</span>
          <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(28px,4vw,48px)] font-black tracking-[-0.04em] leading-[1.05] max-w-[720px] mx-auto">A place that grows <span class="accent">with you.</span></h2>
          <p data-reveal style="--d:.12s" class="mt-5 text-muted text-[clamp(15px,1.2vw,17px)] leading-[1.6] max-w-[580px] mx-auto">We invest in our people as much as our products — because the team that ships great software is the one that keeps getting better.</p>
        </div>
        <div class="grid grid-cols-3 gap-[18px] max-[860px]:grid-cols-2 max-[520px]:grid-cols-1">
          {WHYJOIN.map((w, i) => (
            <article data-reveal style={`--d:${(0.06 + (i % 3) * 0.06).toFixed(2)}s`} class="cr-card group">
              <span class="cr-card-spot" aria-hidden="true"></span>
              <span class="cr-card-ic"><i class={`fi ${w.ic}`}></i></span>
              <h3 class="cr-card-title">{w.t}</h3>
              <p class="cr-card-desc">{w.d}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ───────── PERKS (dark band) ───────── -->
    <section id="perks" class="surface-dark py-[var(--section-y)]">
      <div class="wrap">
        <div class="text-center mb-[clamp(36px,4vw,52px)]">
          <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em]"><i class="fi fi-rr-gift"></i> Perks &amp; benefits</span>
          <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(28px,4vw,48px)] font-black tracking-[-0.04em] leading-[1.05] text-white max-w-[680px] mx-auto">More than a paycheck — <span class="accent-l">a place to belong.</span></h2>
        </div>
        <ul data-reveal style="--d:.1s" class="cr-perks">
          {PERKS.map((p) => (
            <li class="cr-perk">
              <span class="cr-perk-ic"><i class={`fi ${p.ic}`}></i></span>
              <span class="cr-perk-t">{p.t}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ───────── OPEN ROLES ───────── -->
    <section id="openings" class="py-[var(--section-y)]">
      <div class="wrap">
        <div class="flex flex-wrap items-end justify-between gap-6 mb-[clamp(36px,4vw,52px)]">
          <div class="max-w-[640px]">
            <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk"><i class="fi fi-rr-megaphone text-teal"></i> Open roles</span>
            <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(28px,4vw,48px)] font-black tracking-[-0.04em] leading-[1.05]">Find your <span class="accent">next role.</span></h2>
          </div>
          <a data-reveal style="--d:.1s" href={APPLY} target="_blank" rel="noopener" class="cr-all inline-flex items-center gap-2 text-[14.5px] font-bold text-ink whitespace-nowrap">View all on careers portal <i class="fi fi-rr-arrow-up-right"></i></a>
        </div>
        <ul class="cr-roles">
          {ROLES.map((r, i) => (
            <li data-reveal style={`--d:${(0.06 + (i % 3) * 0.05).toFixed(2)}s`}>
              <a href={APPLY} target="_blank" rel="noopener" class="cr-role group">
                <div class="cr-role-main">
                  <h3 class="cr-role-title">{r.title}</h3>
                  <div class="cr-role-meta">
                    <span><i class="fi fi-rr-apps"></i> {r.dept}</span>
                    <span><i class="fi fi-rr-marker"></i> {r.loc}</span>
                    <span><i class="fi fi-rr-clock"></i> {r.type}</span>
                  </div>
                </div>
                <span class="cr-role-cta">Apply <i class="fi fi-rr-arrow-right"></i></span>
              </a>
            </li>
          ))}
        </ul>
        <p data-reveal class="cr-roles-note">Don't see a fit? <a href={APPLY} target="_blank" rel="noopener">Send us your CV anyway</a> — we're always keen to meet great people.</p>
      </div>
    </section>

    <!-- ───────── HIRING PROCESS ───────── -->
    <section id="process" class="surface-tint py-[var(--section-y)]">
      <div class="wrap">
        <div class="flex flex-wrap items-end justify-between gap-6 mb-[clamp(36px,4vw,52px)]">
          <div class="max-w-[640px]">
            <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk"><i class="fi fi-rr-workflow text-teal"></i> How we hire</span>
            <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(28px,4vw,48px)] font-black tracking-[-0.04em] leading-[1.05]">A fair, fast <span class="accent">process.</span></h2>
          </div>
          <p data-reveal style="--d:.12s" class="text-[14px] font-semibold text-muted max-w-[320px] max-[680px]:max-w-none">Four clear steps, real conversations with the people you'd actually work with — no black boxes.</p>
        </div>
        <div class="grid grid-cols-4 gap-[18px] max-[860px]:grid-cols-2 max-[480px]:grid-cols-1">
          {STEPS.map((s, i) => (
            <div data-reveal style={`--d:${(0.1 + i * 0.07).toFixed(2)}s`} class="cr-step rounded-3xl bg-white border border-line p-7">
              <span class="cr-step-n">{s.n}</span>
              <h3 class="mt-5 text-[17px] font-extrabold tracking-[-0.02em] text-ink">{s.t}</h3>
              <p class="mt-2 text-[13.5px] leading-[1.55] text-muted">{s.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ───────── LIFE AT BIZTECH ───────── -->
    <section id="life" class="py-[var(--section-y)]">
      <div class="wrap">
        <div class="flex items-end justify-between gap-6 mb-[clamp(24px,3vw,36px)]">
          <div>
            <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk"><i class="fi fi-rr-confetti text-teal"></i> Life at Biztech</span>
            <h2 data-reveal style="--d:.06s" class="mt-3 text-[clamp(28px,4vw,48px)] font-black tracking-[-0.04em] leading-[1.05]">Where work feels <span class="accent">like family.</span></h2>
          </div>
          <a data-reveal style="--d:.06s" href="https://www.biztechcs.com/life-at-biztech/" target="_blank" rel="noopener" class="cr-all inline-flex items-center gap-2 text-[14.5px] font-bold text-ink whitespace-nowrap max-[640px]:hidden">See more <i class="fi fi-rr-arrow-up-right"></i></a>
        </div>
        <div class="cr-gallery">
          <figure data-reveal class="cr-g-main"><img src={LIFE_PHOTOS[0].src} alt={LIFE_PHOTOS[0].alt} loading="lazy" /></figure>
          <div class="cr-g-side">
            {LIFE_PHOTOS.slice(1).map((p, i) => (
              <figure data-reveal style={`--d:${(0.06 + i * 0.05).toFixed(2)}s`} class="cr-g-cell"><img src={p.src} alt={p.alt} loading="lazy" /></figure>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ───────── FAQ (shared component) ───────── -->
    <Faq
      items={FAQS}
      eyebrow="Questions, answered"
      heading="Working at"
      accent="BiztechCS."
      sub="Everything you want to know before you apply — straight answers, no fluff."
      ctaHref={APPLY}
      ctaLabel="Apply now"
    />

    <!-- ───────── CTA (shared component) ───────── -->
    <CtaBand
      badge="Join us"
      heading="Your next role starts"
      accent="with a hello."
      sub="Send us your CV through our careers portal — tell us what you'd love to build, and let's talk."
      primaryLabel="Apply now"
      primaryHref={APPLY}
      mailHref="mailto:hr@biztechcs.com"
      mailLabel="or email HR"
      chips={[['fi-rr-calendar', '5-day week'], ['fi-rr-diploma', 'Sponsored learning'], ['fi-rr-confetti', 'Great Place To Work']]}
    />

  </div>
  <Footer />
</Layout>

<style>
  .accent { background: linear-gradient(100deg, #0ea5e9, #0369a1); -webkit-background-clip: text; background-clip: text; color: transparent; padding-bottom: 0.12em; }
  .accent-l { background: linear-gradient(100deg, #7dd3fc, #38bdf8); -webkit-background-clip: text; background-clip: text; color: transparent; padding-bottom: 0.12em; }

  /* First-paint hardening: promote shell to its own paint layer so the fixed
     sticky-reveal footer can't bleed through transparent sections before first repaint. */
  :global(.page-shell) { transform: translateZ(0); }

  /* ===== hero ===== */
  .cr-hero { position: relative; padding-top: clamp(118px,11vw,156px); padding-bottom: clamp(40px,5vw,64px);
    background: radial-gradient(70% 60% at 12% -10%, rgba(117,209,249,.16), transparent 60%),
      radial-gradient(60% 55% at 100% 0%, rgba(61,101,255,.07), transparent 58%), linear-gradient(180deg, #F4F8FD, #EEF3F9); }
  .cr-hero-grid { position: absolute; inset: 0; pointer-events: none; opacity: .5;
    background-image: linear-gradient(rgba(15,23,42,.04) 1px, transparent 1px), linear-gradient(90deg, rgba(15,23,42,.04) 1px, transparent 1px);
    background-size: 46px 46px; -webkit-mask-image: radial-gradient(70% 60% at 50% 30%, #000, transparent 80%); mask-image: radial-gradient(70% 60% at 50% 30%, #000, transparent 80%); }
  .cr-hero-glow { position: absolute; right: -8%; top: -20%; width: 55%; height: 120%; border-radius: 50%; background: radial-gradient(circle, rgba(56,189,248,.16), transparent 65%); pointer-events: none; }
  .cr-hero-cols { display: grid; grid-template-columns: 1.08fr 0.92fr; gap: clamp(32px,5vw,72px); align-items: center; }
  @media (max-width: 940px) { .cr-hero-cols { grid-template-columns: 1fr; } }

  .cr-ghost { display: inline-flex; align-items: center; gap: 8px; padding: 16px 24px; border-radius: 999px; border: 1px solid var(--line); background: #fff; color: var(--ink); font-weight: 600; font-size: 15px; transition: border-color .25s, transform .25s, color .25s; }
  .cr-ghost:hover { border-color: rgba(14,165,233,.5); color: var(--teal-dk); transform: translateY(-1px); } .cr-ghost i { line-height: 0; }

  .cr-stats { margin-top: clamp(30px,3.4vw,42px); display: flex; flex-wrap: wrap; align-items: center; gap: 8px 0; }
  .cr-stat { position: relative; display: flex; flex-direction: column; padding-right: clamp(18px,2.4vw,34px); }
  .cr-stat-n { font-size: clamp(24px,2.8vw,34px); font-weight: 900; letter-spacing: -.04em; line-height: 1;
    background: linear-gradient(120deg, #0ea5e9, #6366f1); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .cr-stat-l { margin-top: 7px; font-size: 12.5px; font-weight: 700; color: var(--muted); }
  .cr-stat-div { position: absolute; right: 0; top: 4px; bottom: 4px; width: 1px; background: var(--line); }
  @media (max-width: 560px) { .cr-stat { flex-basis: 50%; padding: 12px 0; } .cr-stat-div { display: none; } }

  /* hero culture collage */
  .cr-hero-art { position: relative; width: min(440px,100%); margin-inline: auto; aspect-ratio: 1 / 0.92; }
  .cr-art-main, .cr-art-side { position: absolute; margin: 0; overflow: hidden; border-radius: 20px; border: 1px solid var(--line); background: #eef2f7; box-shadow: 0 24px 56px -34px rgba(15,23,42,.5); }
  .cr-art-main img, .cr-art-side img { width: 100%; height: 100%; object-fit: cover; transition: transform .6s cubic-bezier(.16,1,.3,1); }
  .cr-art-main:hover img, .cr-art-side:hover img { transform: scale(1.06); }
  .cr-art-main { left: 0; top: 4%; width: 62%; height: 78%; z-index: 1; }
  .cr-art-s1 { right: 0; top: 0; width: 42%; height: 46%; z-index: 2; }
  .cr-art-s2 { right: 6%; bottom: 0; width: 50%; height: 44%; z-index: 2; }
  .cr-art-badge { position: absolute; left: 8%; bottom: 2%; z-index: 3; display: inline-flex; align-items: center; gap: 7px; padding: 9px 14px; border-radius: 999px; background: #fff; border: 1px solid var(--line); box-shadow: 0 14px 34px -18px rgba(35,38,46,.4); font-size: 12.5px; font-weight: 800; color: var(--ink); white-space: nowrap; }
  .cr-art-badge i { color: var(--teal); font-size: 13px; line-height: 0; }
  @media (prefers-reduced-motion: no-preference) { .cr-art-badge { animation: crFloat 4.5s ease-in-out infinite; } }
  @keyframes crFloat { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-7px); } }

  /* ===== why-join cards ===== */
  .cr-card { --mx: 50%; --my: 50%; position: relative; overflow: hidden; border-radius: 22px; background: #fff; border: 1px solid var(--line); padding: 28px; box-shadow: 0 10px 30px -22px rgba(35,38,46,.22); transition: transform .35s cubic-bezier(.16,1,.3,1), box-shadow .35s, border-color .35s; }
  .cr-card:hover { transform: translateY(-4px); border-color: rgba(14,165,233,.4); box-shadow: 0 26px 56px -28px rgba(14,165,233,.32); }
  .cr-card-spot { position: absolute; inset: 0; z-index: 0; pointer-events: none; opacity: 0; transition: opacity .35s; background: radial-gradient(320px circle at var(--mx) var(--my), rgba(56,189,248,.16), transparent 60%); }
  .cr-card:hover .cr-card-spot { opacity: 1; }
  .cr-card-ic { position: relative; z-index: 1; display: grid; place-items: center; width: 52px; height: 52px; border-radius: 15px; font-size: 22px; line-height: 0; background: rgba(14,165,233,.1); border: 1px solid rgba(14,165,233,.2); color: var(--teal-dk); transition: background .3s, color .3s, border-color .3s, transform .3s; }
  .cr-card:hover .cr-card-ic { background: var(--teal); color: #fff; border-color: transparent; transform: rotate(-6deg); }
  .cr-card-title { position: relative; z-index: 1; margin-top: 20px; font-size: 18.5px; font-weight: 800; letter-spacing: -.02em; color: var(--ink); }
  .cr-card-desc { position: relative; z-index: 1; margin-top: 9px; font-size: 14.5px; line-height: 1.55; color: var(--muted); }

  /* ===== perks (dark) ===== */
  .cr-perks { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; list-style: none; margin: 0; padding: 0; }
  @media (max-width: 960px) { .cr-perks { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 560px) { .cr-perks { grid-template-columns: 1fr 1fr; } }
  .cr-perk { display: flex; flex-direction: column; align-items: flex-start; gap: 14px; padding: 22px; border-radius: 18px; background: rgba(255,255,255,.04); border: 1px solid rgba(125,211,252,.16); transition: border-color .3s, background .3s, transform .3s; }
  .cr-perk:hover { border-color: rgba(125,211,252,.4); background: rgba(125,211,252,.07); transform: translateY(-3px); }
