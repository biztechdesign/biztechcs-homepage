---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import CtaButton from '../../components/CtaButton.astro'
import CtaBand from '../../components/CtaBand.astro'

const BASE = import.meta.env.BASE_URL

// real client logos (same set the homepage uses)
const CDN = 'https://www.biztechcs.com/wp-content/uploads'
const CLIENTS = [
  { name: 'Forbes Marshall', src: `${CDN}/2023/05/forbes-marshall.png` },
  { name: 'Bonfiglioli', src: `${CDN}/2023/05/bonfiglioli.png` },
  { name: 'Ovivo', src: `${CDN}/2023/05/Ovivo.svg` },
  { name: 'Biorbyt', src: `${CDN}/2023/05/Biorbyt.svg` },
  { name: 'Medguard', src: `${CDN}/2023/05/medguard.png` },
]
const BADGES = [
  { name: 'Clutch', src: `${BASE}/assets/badges/clutch.svg` },
  { name: 'Google Premier Partner 2024', src: `${BASE}/assets/badges/google-partner.svg` },
  { name: 'GESIA Member', src: `${BASE}/assets/badges/gesia.svg` },
  { name: 'Salesforce ISV Partner', src: `${BASE}/assets/badges/salesforce-isv.svg` },
  { name: 'Top App Development Companies', src: `${BASE}/assets/badges/tadc.svg` },
  { name: 'SugarCRM ISV Partner', src: `${BASE}/assets/badges/sugarcrm.png` },
  { name: 'Techimply', src: `${BASE}/assets/badges/techimply.svg` },
  { name: 'TÜV certified', src: `${BASE}/assets/badges/tuv.svg` },
  { name: 'Great Place To Work', src: `${BASE}/assets/badges/gptw.svg` },
  { name: 'Odoo Partner', src: `${BASE}/assets/badges/odoo.svg` },
]

// ── Printing solutions (bento showcase) ──
const SOLUTIONS = [
  { ic: 'fi-rr-shopping-cart', title: 'Web-to-Print Storefronts', desc: 'Branded online print shops with catalogs, templates, quantity pricing, coupons and a fast mobile checkout.', big: true },
  { ic: 'fi-rr-palette', title: 'Product Design Tool', desc: 'A live, multi-user customizer for text, art, layers and uploads — with print-ready output.' },
  { ic: 'fi-rr-apps', title: 'Print ERP & Automation', desc: 'Bulk pricing, imposition, preflight, invoicing and variable-data printing — automated.' },
  { ic: 'fi-rr-boxes', title: 'Order & Production', desc: 'Order capture to job tickets, status tracking and shop-floor workflows in one flow.' },
  { ic: 'fi-rr-database', title: 'Variable Data Printing', desc: 'Personalise text and images from customer data at scale — without slowing the press.' },
  { ic: 'fi-rr-share', title: 'Storefront × ERP / CRM', desc: 'Connect your shop to Odoo, Dynamics, Salesforce and ecommerce into one real-time system.', big: true },
  { ic: 'fi-rr-layers', title: 'Headless & Custom Commerce', desc: 'Bespoke storefronts on Magento, Shopify or headless — built for your catalog.', big: true },
  { ic: 'fi-rr-megaphone', title: 'Marketing & SEO', desc: 'Built-in CMS, blog, SEO and portfolio tools to grow orders, not just take them.' },
  { ic: 'fi-rr-headset', title: '24/7 Support & SLAs', desc: 'Post-launch maintenance, monitoring and technical support that keeps stores selling.' },
]

// ── Print products / segments we power ──
const SEGMENTS = [
  { ic: 'fi-rr-tshirt', name: 'Apparel & T-shirts', desc: 'Custom apparel, hoodies & uniforms.' },
  { ic: 'fi-rr-mug-hot', name: 'Drinkware & Mugs', desc: 'Mugs, bottles & personalised gifts.' },
  { ic: 'fi-rr-box', name: 'Packaging & Labels', desc: 'Boxes, labels & custom packaging.' },
  { ic: 'fi-rr-flag', name: 'Signage & Large Format', desc: 'Banners, posters & display graphics.' },
  { ic: 'fi-rr-gift', name: 'Promotional Products', desc: 'Branded merch & corporate gifts.' },
  { ic: 'fi-rr-document', name: 'Stationery & Cards', desc: 'Business cards, flyers & brochures.' },
  { ic: 'fi-rr-picture', name: 'Photo & Décor', desc: 'Photo books, canvases & wall art.' },
  { ic: 'fi-rr-sticker', name: 'Stickers & Decals', desc: 'Die-cut stickers, decals & wraps.' },
]

// ── Why BiztechCS for printing ──
const REASONS = [
  { ic: 'fi-rr-trophy', title: '50+ printing projects', desc: 'Nearly two decades building web-to-print, design tools and print ERP for printers worldwide.' },
  { ic: 'fi-rr-rocket-lunch', title: 'We own a print product', desc: 'PrintXpand — our own web-to-print platform — powers thousands of stores. We build what we sell.' },
  { ic: 'fi-rr-apps', title: 'Storefront + tool + ERP', desc: 'Design tool, storefront, automation and ERP/CRM integration from one accountable team.' },
  { ic: 'fi-rr-shield-check', title: 'US/EU accountable', desc: 'Senior leads, time-zone-aligned delivery, ISO 27001/9001 and IP you fully own.' },
]

// ── Process ──
const STEPS = [
  { n: '01', title: 'Discovery & catalog fit', desc: 'We map your products, print methods and workflows — and define what success looks like.' },
  { n: '02', title: 'Design & prototype', desc: 'Storefront UX, the customizer and a working prototype you can click before we build.' },
  { n: '03', title: 'Build & integrate', desc: 'Storefront, design tool and ERP/CRM/ecommerce integrations, engineered to scale.' },
  { n: '04', title: 'Launch & support', desc: 'Go-live, monitoring and ongoing support so the store keeps taking orders.' },
]

// ── Tech & integrations (dark band) — real official brand logos via simple-icons ──
const SIC = 'https://cdn.jsdelivr.net/npm/simple-icons@v13/icons'
const TECH = [
  { name: 'Magento', logo: `${SIC}/magento.svg` },
  { name: 'Shopify', logo: `${SIC}/shopify.svg` },
  { name: 'WooCommerce', logo: `${SIC}/woocommerce.svg` },
  { name: 'BigCommerce', logo: `${SIC}/bigcommerce.svg` },
  { name: 'Odoo', logo: `${SIC}/odoo.svg` },
  { name: 'Dynamics 365', ic: 'fi-rr-cloud' },
  { name: 'Salesforce', logo: `${SIC}/salesforce.svg` },
  { name: 'React', logo: `${SIC}/react.svg` },
  { name: 'Angular', logo: `${SIC}/angular.svg` },
  { name: 'Next.js', logo: `${SIC}/nextdotjs.svg` },
  { name: '.NET', logo: `${SIC}/dotnet.svg` },
  { name: 'PHP', logo: `${SIC}/php.svg` },
  { name: 'Node.js', logo: `${SIC}/nodedotjs.svg` },
  { name: 'AWS', logo: `${SIC}/amazonwebservices.svg` },
  { name: 'Azure', ic: 'fi-rr-cloud' },
  { name: 'Stripe', logo: `${SIC}/stripe.svg` },
  { name: 'PayPal', logo: `${SIC}/paypal.svg` },
]

// ── Engagement models ──
const MODELS = [
  { ic: 'fi-rr-bullseye-arrow', title: 'Fixed-scope store', desc: 'A defined web-to-print storefront with a fixed quote and timeline.', featured: false },
  { ic: 'fi-rr-users-alt', title: 'Dedicated print team', desc: 'A senior squad for an evolving print platform and roadmap.', featured: true },
  { ic: 'fi-rr-user-add', title: 'Staff augmentation', desc: 'Add web-to-print & integration specialists to your existing team.', featured: false },
]

// ── FAQ ──
const FAQS = [
  { q: 'Can I customize any range of products?', a: 'Yes. We build design tools that handle apparel, drinkware, packaging, signage, stationery, promotional products and more — with print-ready output for each method (DTG, screen, sublimation, offset, large-format).' },
  { q: 'How long does it take to set up a web-to-print store?', a: 'A focused storefront can launch in a few weeks; a fully custom platform with a design tool and ERP integration takes longer. We give you a fixed timeline after a scoping call — no surprises.' },
  { q: 'Do you integrate with our existing ERP and ecommerce?', a: 'Yes — Magento, Shopify, WooCommerce on the storefront side, and Odoo, Dynamics 365 Business Central, Salesforce and Dynamics CRM on the back office, connected in real time.' },
  { q: 'Can you build a custom product design tool?', a: 'Absolutely. We build multi-user customizers with text, image, clipart, layers, upload and live preview — plus the print-ready file generation your production team needs.' },
  { q: 'Do you provide maintenance and support?', a: 'Yes — post-launch maintenance, monitoring and 24/7 technical support, with SLAs, so your store keeps selling.' },
]
---
<Layout>
  <Header />
  <div class="page-shell">

    <!-- ───────── HERO ───────── -->
    <section class="prn-hero relative overflow-hidden" id="top">
      <span class="prn-hero-grid" aria-hidden="true"></span>
      <span class="prn-hero-glow" aria-hidden="true"></span>
      <div class="wrap relative">
        <div class="prn-hero-grid-cols">
          <div>
            <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk">
              <i class="fi fi-rr-print text-teal"></i> Printing &amp; Web-to-Print
            </span>
            <h1 data-reveal style="--d:.06s" class="mt-6 text-[clamp(34px,5.2vw,60px)] font-black tracking-[-0.04em] leading-[1.06] text-ink">
              Personalised printing, <span class="accent">made effortless.</span>
            </h1>
            <p data-reveal style="--d:.12s" class="mt-7 text-[clamp(16px,1.3vw,18px)] leading-[1.65] text-muted max-w-[540px]">
              Web-to-print storefronts, live product design tools and print ERP — built end to end by the team behind <b>PrintXpand</b>. US &amp; EU accountability, IP you fully own.
            </p>
            <div data-reveal style="--d:.18s" class="mt-9 flex flex-wrap gap-3">
              <CtaButton href="#cta" label="Plan your print store" variant="dark" />
              <a href="#solutions" class="prn-ghost">See what we build <i class="fi fi-rr-arrow-down"></i></a>
            </div>
            <div data-reveal style="--d:.26s" class="prn-hero-clients">
              <span class="prn-hc-label">Trusted by <b>200+</b> companies</span>
              <ul class="prn-hc-logos">
                {CLIENTS.map((c) => <li><img src={c.src} alt={c.name} loading="lazy" /></li>)}
              </ul>
            </div>
          </div>

          <!-- web-to-print storefront mockup -->
          <div data-reveal style="--d:.16s" class="prn-mock" role="img" aria-label="A web-to-print product customizer storefront">
            <div class="prn-mock-bar"><span></span><span></span><span></span><em>yourstore.com / customize</em></div>
            <div class="prn-mock-body">
              <div class="prn-mock-stage">
                <i class="fi fi-rr-tshirt"></i>
                <span class="prn-mock-art">YOUR<br/>LOGO</span>
                <span class="prn-badge prn-badge-1"><i class="fi fi-rr-text"></i> Add text</span>
                <span class="prn-badge prn-badge-2"><i class="fi fi-rr-picture"></i> Upload art</span>
                <span class="prn-badge prn-badge-3"><i class="fi fi-rr-check-circle"></i> Print-ready</span>
              </div>
              <div class="prn-mock-tools">
                <div class="prn-swatches"><b></b><b></b><b></b><b></b><b></b></div>
                <div class="prn-tool-btns"><span><i class="fi fi-rr-layers"></i></span><span><i class="fi fi-rr-text"></i></span><span><i class="fi fi-rr-picture"></i></span><span><i class="fi fi-rr-resize"></i></span></div>
                <div class="prn-mock-cta">Add to cart · $24.00</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ───────── TRUST BOX (certs + stats) ───────── -->
    <section id="trust" aria-label="Certifications and track record" class="pt-[clamp(16px,2vw,28px)] pb-[clamp(8px,1vw,16px)]">
      <div class="wrap">
        <div data-reveal class="prn-trustbox">
          <div class="prn-tx-left">
            <span class="prn-tbx-label"><i class="fi fi-rr-shield-check"></i> Recognized<br/>&amp; certified</span>
            <div class="prn-tx-track">
              <div class="prn-tx-row">
                {BADGES.map((b) => <span class="prn-tx-logo"><img src={b.src} alt={b.name} title={b.name} loading="lazy" /></span>)}
                {BADGES.map((b) => <span class="prn-tx-logo" aria-hidden="true"><img src={b.src} alt="" loading="lazy" /></span>)}
              </div>
            </div>
          </div>
          <div class="prn-tx-right">
            <div class="prn-tb-item"><div class="prn-tn accent">50+</div><div class="prn-tl">Printing projects</div></div>
            <div class="prn-tb-item"><div class="prn-tn accent">98%</div><div class="prn-tl">Client retention</div></div>
            <div class="prn-tb-item"><div class="prn-tn accent">19+</div><div class="prn-tl">Years in print</div></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ───────── SOLUTIONS (bento) ───────── -->
    <section id="solutions" class="py-[var(--section-y)]">
      <div class="wrap">
        <div class="text-center mb-[clamp(36px,4vw,52px)]">
          <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk"><i class="fi fi-rr-apps text-teal"></i> What we build</span>
          <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(28px,4vw,48px)] font-black tracking-[-0.04em] leading-[1.05] max-w-[720px] mx-auto">Everything to sell &amp; produce <span class="accent">custom print.</span></h2>
          <p data-reveal style="--d:.12s" class="mt-5 text-muted text-[clamp(15px,1.2vw,17px)] leading-[1.6] max-w-[560px] mx-auto">From the storefront and design tool to ERP automation — one team for the whole web-to-print stack.</p>
        </div>
        <div class="prn-bento" id="prnBento">
          {SOLUTIONS.map((b, i) => (
            <article data-reveal style={`--d:${(0.08 + i * 0.05).toFixed(2)}s`} class:list={["prn-bcard group", b.big && "prn-bcard-big"]}>
              <span class="prn-bcard-spot" aria-hidden="true"></span>
              <span class="prn-bcard-ic"><i class={`fi ${b.ic}`}></i></span>
              <div class="prn-bcard-body">
                <h3 class="prn-bcard-title">{b.title}</h3>
                <p class="prn-bcard-desc">{b.desc}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ───────── PRINTXPAND (dark band) ───────── -->
    <section class="surface-dark py-[var(--section-y)]">
      <div class="wrap">
        <div class="prn-px-grid">
          <div>
            <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em]"><i class="fi fi-rr-rocket-lunch"></i> Our own print product</span>
            <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(28px,4vw,46px)] font-black tracking-[-0.04em] leading-[1.05] text-white">We don't just build web-to-print — <span class="accent-l">we ship it.</span></h2>
            <p data-reveal style="--d:.12s" class="mt-5 text-[clamp(15px,1.2vw,17px)] leading-[1.6] text-white/65 max-w-[560px]">
              <b class="text-white">PrintXpand</b> (formerly Brush Your Ideas) is our own web-to-print platform powering thousands of print stores worldwide. When you work with us, you get a team that lives and breathes printing — not a generic dev shop.
            </p>
            <div data-reveal style="--d:.2s" class="mt-8"><CtaButton href="#cta" label="Talk to a print expert" variant="light" /></div>
          </div>
          <div data-reveal style="--d:.16s" class="prn-px-stats">
            <div class="prn-px-stat"><div class="prn-px-n accent-l">1000s</div><div class="prn-px-l">Print stores powered</div></div>
            <div class="prn-px-stat"><div class="prn-px-n accent-l">100+</div><div class="prn-px-l">Print integrations shipped</div></div>
            <div class="prn-px-stat"><div class="prn-px-n accent-l">All</div><div class="prn-px-l">Print methods supported</div></div>
            <div class="prn-px-stat"><div class="prn-px-n accent-l">Since '06</div><div class="prn-px-l">Building for printers</div></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ───────── SEGMENTS ───────── -->
    <section class="py-[var(--section-y)]">
      <div class="wrap">
        <div class="text-center mb-[clamp(32px,4vw,48px)]">
          <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk"><i class="fi fi-rr-grid text-teal"></i> Products you can sell</span>
          <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(26px,3.6vw,44px)] font-black tracking-[-0.04em] leading-[1.05] max-w-[660px] mx-auto">One platform, <span class="accent">every print product.</span></h2>
        </div>
        <div class="prn-seg-grid">
          {SEGMENTS.map((s, i) => (
            <div data-reveal style={`--d:${(0.06 + i * 0.04).toFixed(2)}s`} class="prn-seg-card group">
              <span class="prn-seg-ic"><i class={`fi ${s.ic}`}></i></span>
              <div><h3 class="prn-seg-name">{s.name}</h3><p class="prn-seg-desc">{s.desc}</p></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ───────── WHY US ───────── -->
    <section class="surface-tint py-[var(--section-y)]">
      <div class="wrap">
        <div class="text-center mb-[clamp(36px,4vw,52px)]">
          <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk"><i class="fi fi-rr-badge-check text-teal"></i> Why BiztechCS for print</span>
          <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(28px,4vw,48px)] font-black tracking-[-0.04em] leading-[1.05] max-w-[680px] mx-auto">Print is in our <span class="accent">DNA.</span></h2>
        </div>
        <div class="grid grid-cols-4 gap-[16px] max-[900px]:grid-cols-2 max-[480px]:grid-cols-1">
          {REASONS.map((r, i) => (
            <div data-reveal style={`--d:${(0.1 + i * 0.06).toFixed(2)}s`} class="rounded-3xl bg-white border border-line p-7">
              <span class="grid place-items-center w-12 h-12 rounded-xl bg-teal/10 border border-teal/20 text-teal text-[19px]"><i class={`fi ${r.ic}`}></i></span>
              <h3 class="mt-5 text-[16px] font-extrabold tracking-[-0.02em] text-ink">{r.title}</h3>
              <p class="mt-2 text-[13.5px] leading-[1.5] text-muted">{r.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ───────── PROCESS ───────── -->
    <section class="py-[var(--section-y)]">
      <div class="wrap">
        <div class="flex flex-wrap items-end justify-between gap-6 mb-[clamp(36px,4vw,52px)]">
          <div class="max-w-[640px]">
            <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk"><i class="fi fi-rr-workflow text-teal"></i> How we deliver</span>
            <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(28px,4vw,48px)] font-black tracking-[-0.04em] leading-[1.05]">From idea to a <span class="accent">live print store.</span></h2>
          </div>
          <p data-reveal style="--d:.12s" class="text-[14px] font-semibold text-muted max-w-[300px] max-[680px]:max-w-none">Senior-led delivery with transparent estimates — no cost overruns.</p>
        </div>
        <div class="grid grid-cols-4 gap-[18px] max-[860px]:grid-cols-2 max-[480px]:grid-cols-1">
          {STEPS.map((s, i) => (
            <div data-reveal style={`--d:${(0.1 + i * 0.07).toFixed(2)}s`} class="prn-step rounded-3xl bg-white border border-line p-7">
              <span class="prn-step-n">{s.n}</span>
              <h3 class="mt-5 text-[17px] font-extrabold tracking-[-0.02em] text-ink">{s.title}</h3>
              <p class="mt-2 text-[13.5px] leading-[1.5] text-muted">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ───────── TECH & INTEGRATIONS (dark band) ───────── -->
    <section class="surface-dark py-[var(--section-y)]">
      <div class="wrap text-center">
        <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em]"><i class="fi fi-rr-plug"></i> Platforms &amp; integrations</span>
        <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(26px,3.6vw,44px)] font-black tracking-[-0.04em] leading-[1.05] text-white max-w-[680px] mx-auto">Built on the tools your <span class="accent-l">print business runs on.</span></h2>
        <ul data-reveal style="--d:.12s" class="mt-9 flex flex-wrap items-center justify-center gap-2.5">
          {TECH.map((t) => (
            <li class="prn-chip">
              {t.logo ? <img src={t.logo} alt="" loading="lazy" /> : <i class={`fi ${t.ic}`}></i>}
              {t.name}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ───────── PROOF ───────── -->
    <section class="py-[var(--section-y)]">
      <div class="wrap">
        <div class="text-center mb-[clamp(32px,4vw,48px)]">
          <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk"><i class="fi fi-rr-comment-quote text-teal"></i> Proof</span>
          <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(28px,4vw,48px)] font-black tracking-[-0.04em] leading-[1.05]">Trusted by printers <span class="accent">worldwide.</span></h2>
        </div>
        <div class="prn-proof-grid">
          <blockquote data-reveal class="prn-quote rounded-3xl bg-ink text-white p-9 flex flex-col">
            <i class="fi fi-rr-quote-right text-[28px] text-teal-300"></i>
            <p class="mt-5 text-[clamp(18px,1.8vw,24px)] font-semibold leading-[1.45]">"They understand printing — not just code. The web-to-print store and design tool they built run exactly how our production team needs them to."</p>
            <div class="mt-7 flex items-center gap-3">
              <span class="prn-q-avatar">PX</span>
              <span class="leading-tight"><b class="block text-[14.5px] font-extrabold">Print &amp; Ecommerce Lead</b><span class="block text-[13px] text-white/55">Custom print &amp; merchandise brand</span></span>
            </div>
          </blockquote>
          <div data-reveal style="--d:.08s" class="grid grid-cols-2 gap-[18px] max-[420px]:grid-cols-1">
            <div class="prn-stat rounded-3xl bg-white border border-line p-7 flex flex-col justify-center text-center"><div class="prn-stat-n accent">50+</div><div class="mt-2 text-[14px] font-bold text-ink">Printing projects</div></div>
            <div class="prn-stat rounded-3xl bg-white border border-line p-7 flex flex-col justify-center text-center"><div class="prn-stat-n accent">1000s</div><div class="mt-2 text-[14px] font-bold text-ink">Stores powered</div></div>
            <div class="prn-stat rounded-3xl bg-white border border-line p-7 flex flex-col justify-center text-center"><div class="prn-stat-n accent">PrintXpand</div><div class="mt-2 text-[14px] font-bold text-ink">Our web-to-print product</div></div>
