---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import CtaButton from '../components/CtaButton.astro'
import CtaBand from '../components/CtaBand.astro'
import TrustBand from '../components/TrustBand.astro'
import EngagementModels from '../components/EngagementModels.astro'
import Faq from '../components/Faq.astro'

const BASE = import.meta.env.BASE_URL

const STATS = [
  { n: '19+', label: 'Years shipping' },
  { n: '1,200+', label: 'Projects delivered' },
  { n: '98%', label: 'Client retention' },
  { n: '200+', label: 'Senior engineers' },
]

// the four guarantees that remove a buyer's biggest fears (hero promise card)
const PROMISE = [
  { ic: 'fi-rr-document-signed', t: 'IP you fully own', d: 'Work-for-hire + NDAs, full transfer on payment.' },
  { ic: 'fi-rr-shield-check', t: 'ISO 27001 & 9001', d: 'Encryption, access controls, GDPR-aligned.' },
  { ic: 'fi-rr-chart-pie', t: 'No cost overruns', d: 'Transparent estimates, Agile, weekly standups.' },
  { ic: 'fi-rr-clock', t: 'US & EU overlap', d: 'Daily working-hour overlap, local offices.' },
]

// what working with us actually removes / gives you
const DIFF = [
  { ic: 'fi-rr-document-signed', t: 'You own everything you pay for', d: 'US-style work-for-hire agreements with full IP transfer on payment, backed by NDAs and clear code ownership from day one. No lock-in.' },
  { ic: 'fi-rr-shield-check', t: 'Security & compliance, certified', d: 'ISO 27001 & 9001, encryption, strict access controls and GDPR-aligned data handling — security testing baked into how we ship.' },
  { ic: 'fi-rr-chart-pie', t: 'No cost overruns', d: 'Transparent fixed estimates, Agile delivery and weekly standups keep scope, budget and timeline honest.' },
  { ic: 'fi-rr-users-alt', t: 'Senior-led, not a sales deck', d: 'Real senior engineers run your build — 200+ across USA, Europe and India — with a single accountable lead in your time zone.' },
  { ic: 'fi-rr-rocket-lunch', t: 'We ship our own products', d: 'PrintXpand and other ventures run in production. We build what we sell — so we feel every shortcut you would.' },
  { ic: 'fi-rr-headset', t: 'Aligned to your hours', d: 'Daily working-hour overlap with US & EU clients during your day, plus progress overnight from global teams.' },
]

// accountability model tiles (dark band)
const ACCOUNT = [
  { ic: 'fi-rr-marker', t: 'Offices in 3 regions', d: 'USA, Europe and India — local presence where you are, engineering scale where it counts.' },
  { ic: 'fi-rr-clock', t: 'Daily time-zone overlap', d: 'Real-time collaboration during your working day, momentum overnight.' },
  { ic: 'fi-rr-user-headset', t: 'One accountable lead', d: 'A senior point of contact who owns the outcome end to end — no hand-off roulette.' },
  { ic: 'fi-rr-globe', t: '40+ countries served', d: 'Delivery experience across regulated and fast-moving markets worldwide.' },
]

// how we work
const STEPS = [
  { n: '01', t: 'Discovery & scoping', d: 'We map goals, scope and success metrics — then hand you a transparent estimate before anything is built.' },
  { n: '02', t: 'Co-engineering', d: 'Your team and ours run as one: weekly standups, a shared backlog and full visibility into every sprint.' },
  { n: '03', t: 'Build & QA', d: 'Senior-led development with CI/CD plus static, dynamic and mobile testing for hardened, bug-free apps.' },
  { n: '04', t: 'Launch & support', d: 'Go-live, monitoring and ongoing support with SLAs — we stay accountable long after handoff.' },
]

const PROOF = [
  { n: '4.9/5', label: 'Clutch rating' },
  { n: '98%', label: 'Client retention' },
  { n: '1,200+', label: 'Projects delivered' },
  { n: '40+', label: 'Countries served' },
]

const TITLE = 'Why Choose BiztechCS | US & EU Accountability'
const DESCRIPTION = 'Why choose BiztechCS — US & EU software accountability, IP you fully own, ISO 27001/9001, no cost overruns and 98% client retention. See what sets us apart.'

const JSONLD = [
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'How do you handle time-zone differences?', acceptedAnswer: { '@type': 'Answer', text: 'We maintain daily working-hour overlap with US and European clients and have local offices in both regions — real-time collaboration during your day, plus progress overnight.' } },
      { '@type': 'Question', name: 'Who owns the intellectual property?', acceptedAnswer: { '@type': 'Answer', text: 'You do. We use US-style work-for-hire agreements with full IP transfer on payment, backed by NDAs and clear code ownership from day one.' } },
      { '@type': 'Question', name: 'How do you protect our data and stay compliant?', acceptedAnswer: { '@type': 'Answer', text: "We're ISO 27001 and 9001 certified, with encryption, strict access controls, and GDPR-aligned data handling built into our processes." } },
      { '@type': 'Question', name: 'What engagement models do you offer?', acceptedAnswer: { '@type': 'Answer', text: 'Dedicated teams, fixed-scope projects, or staff augmentation — all with transparent estimates and Agile delivery to avoid cost overruns.' } },
      { '@type': 'Question', name: 'How quickly can we get started?', acceptedAnswer: { '@type': 'Answer', text: "Most engagements begin within 1–2 weeks of a scoping call. Book a free 30-minute call and we'll outline a plan." } },
    ],
  },
]
---
<Layout title={TITLE} description={DESCRIPTION} jsonLd={JSONLD}>
  <Header />
  <div class="page-shell">

    <!-- ───────── HERO ───────── -->
    <section class="wb-hero relative overflow-hidden" id="top">
      <span class="wb-hero-grid" aria-hidden="true"></span>
      <span class="wb-hero-glow" aria-hidden="true"></span>
      <div class="wrap relative">
        <div class="wb-hero-cols">
          <div>
            <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk">
              <i class="fi fi-rr-badge-check text-teal"></i> Why BiztechCS
            </span>
            <h1 data-reveal style="--d:.06s" class="mt-6 text-[clamp(34px,5.2vw,60px)] font-black tracking-[-0.045em] leading-[1.04] text-ink max-w-[620px]">
              Enterprise software, delivered with <span class="accent">US &amp; EU accountability.</span>
            </h1>
            <p data-reveal style="--d:.12s" class="mt-7 text-[clamp(16px,1.3vw,18px)] leading-[1.65] text-muted max-w-[540px]">
              Since 2006 we've shipped <b class="text-ink">1,200+ projects</b> for companies in 40+ countries — senior-led, security-certified, and built so you own every line. See <a href={`${BASE}/case-studies`} class="wb-inline">the proof</a> or <a href={`${BASE}/leadership`} class="wb-inline">meet the team</a>.
            </p>
            <div data-reveal style="--d:.18s" class="mt-9 flex flex-wrap gap-3">
              <CtaButton href="#cta" label="Book a 30-min call" variant="dark" />
              <a href="#approach" class="wb-ghost">See how we work <i class="fi fi-rr-arrow-down"></i></a>
            </div>
            <div data-reveal style="--d:.26s" class="wb-stats">
              {STATS.map((s, i) => (
                <div class="wb-stat">
                  <div class="wb-stat-n">{s.n}</div>
                  <div class="wb-stat-l">{s.label}</div>
                  {i < STATS.length - 1 && <span class="wb-stat-div" aria-hidden="true"></span>}
                </div>
              ))}
            </div>
          </div>

          <!-- promise card -->
          <aside data-reveal style="--d:.16s" class="wb-promise">
            <span class="wb-promise-h"><i class="fi fi-rr-shield-check"></i> Our promise to you</span>
            <ul class="wb-promise-list">
              {PROMISE.map((p) => (
                <li>
                  <span class="wb-promise-ic"><i class={`fi ${p.ic}`}></i></span>
                  <div><b>{p.t}</b><span>{p.d}</span></div>
                </li>
              ))}
            </ul>
            <a href="#cta" class="wb-promise-cta">Start a conversation <i class="fi fi-rr-arrow-right"></i></a>
          </aside>
        </div>
      </div>
    </section>

    <!-- ───────── DIFFERENTIATORS ───────── -->
    <section id="difference" class="py-[var(--section-y)]">
      <div class="wrap">
        <div class="text-center mb-[clamp(36px,4vw,52px)]">
          <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk"><i class="fi fi-rr-diamond text-teal"></i> The difference</span>
          <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(28px,4vw,48px)] font-black tracking-[-0.04em] leading-[1.05] max-w-[720px] mx-auto">It's not what we build — it's <span class="accent">how we deliver.</span></h2>
          <p data-reveal style="--d:.12s" class="mt-5 text-muted text-[clamp(15px,1.2vw,17px)] leading-[1.6] max-w-[580px] mx-auto">The same things that worry every buyer of custom software — ownership, security, budget, accountability — are exactly the things we remove.</p>
        </div>
        <div class="wb-grid" id="wbGrid">
          {DIFF.map((d, i) => (
            <article data-reveal style={`--d:${(0.06 + (i % 3) * 0.06).toFixed(2)}s`} class="wb-card group">
              <span class="wb-card-spot" aria-hidden="true"></span>
              <span class="wb-card-ic"><i class={`fi ${d.ic}`}></i></span>
              <h3 class="wb-card-title">{d.t}</h3>
              <p class="wb-card-desc">{d.d}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ───────── ACCOUNTABILITY MODEL ───────── -->
    <section id="accountability" class="surface-dark py-[var(--section-y)]">
      <div class="wrap">
        <div class="wb-acc-grid">
          <div>
            <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em]"><i class="fi fi-rr-handshake"></i> The accountability model</span>
            <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(28px,4vw,46px)] font-black tracking-[-0.04em] leading-[1.05] text-white">One accountable team, <span class="accent-l">two time zones.</span></h2>
            <p data-reveal style="--d:.12s" class="mt-5 text-[clamp(15px,1.2vw,17px)] leading-[1.65] text-white/65 max-w-[520px]">
              You get senior leadership and ownership aligned to your hours in the US and Europe — backed by the engineering scale of 200+ specialists. One point of accountability, not a vendor you chase across time zones.
            </p>
            <div data-reveal style="--d:.2s" class="mt-8"><CtaButton href="#cta" label="Talk to a senior lead" variant="light" /></div>
          </div>
          <div data-reveal style="--d:.16s" class="wb-acc-tiles">
            {ACCOUNT.map((a) => (
              <div class="wb-acc-tile">
                <span class="wb-acc-ic"><i class={`fi ${a.ic}`}></i></span>
                <h3 class="wb-acc-t">{a.t}</h3>
                <p class="wb-acc-d">{a.d}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ───────── HOW WE WORK ───────── -->
    <section id="approach" class="py-[var(--section-y)]">
      <div class="wrap">
        <div class="flex flex-wrap items-end justify-between gap-6 mb-[clamp(36px,4vw,52px)]">
          <div class="max-w-[640px]">
            <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk"><i class="fi fi-rr-workflow text-teal"></i> How we work</span>
            <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(28px,4vw,48px)] font-black tracking-[-0.04em] leading-[1.05]">Co-engineering, not <span class="accent">black boxes.</span></h2>
          </div>
          <p data-reveal style="--d:.12s" class="text-[14px] font-semibold text-muted max-w-[320px] max-[680px]:max-w-none">Weekly standups, a shared backlog and transparent estimates — you see every sprint, no surprises at the end.</p>
        </div>
        <div class="grid grid-cols-4 gap-[18px] max-[860px]:grid-cols-2 max-[480px]:grid-cols-1">
          {STEPS.map((s, i) => (
            <div data-reveal style={`--d:${(0.1 + i * 0.07).toFixed(2)}s`} class="wb-step rounded-3xl bg-white border border-line p-7">
              <span class="wb-step-n">{s.n}</span>
              <h3 class="mt-5 text-[17px] font-extrabold tracking-[-0.02em] text-ink">{s.t}</h3>
              <p class="mt-2 text-[13.5px] leading-[1.55] text-muted">{s.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ───────── PROOF ───────── -->
    <section id="proof" class="surface-tint py-[var(--section-y)]">
      <div class="wrap">
        <div class="text-center mb-[clamp(32px,4vw,48px)]">
          <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk"><i class="fi fi-rr-comment-quote text-teal"></i> Proof, not promises</span>
          <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(28px,4vw,48px)] font-black tracking-[-0.04em] leading-[1.05] max-w-[640px] mx-auto">Trusted by teams who <span class="accent">don't take risks.</span></h2>
        </div>
        <div class="wb-proof-grid">
          <blockquote data-reveal class="wb-quote">
            <i class="fi fi-rr-quote-right wb-quote-mark" aria-hidden="true"></i>
            <p>They felt like an extension of our own team — senior people, honest estimates, and we owned the code the whole way. After two years we're still shipping together.</p>
            <footer><span class="wb-quote-avatar">VP</span><span class="wb-quote-by"><b>VP of Engineering</b><span>B2B SaaS company</span></span></footer>
          </blockquote>
          <div data-reveal style="--d:.08s" class="wb-proof-stats">
            {PROOF.map((p) => (
              <div class="wb-proof-stat"><div class="wb-proof-n">{p.n}</div><div class="wb-proof-l">{p.label}</div></div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- recognized & certified badges (shared) -->
    <TrustBand />

    <!-- engagement models (shared interactive planner) -->
    <EngagementModels />

    <!-- FAQ (shared, buyer-trust questions) -->
    <Faq
      eyebrow="Questions, answered"
      heading="What buyers ask us"
      accent="before they commit."
      sub="Ownership, security, time zones, engagement — the things that actually matter. Straight answers from a senior engineer."
    />

    <!-- ───────── CTA (shared component) ───────── -->
    <CtaBand
      badge="Let's build"
      heading="See why 200+ companies trust us"
      accent="with their software."
      sub="Book a free 30-minute call with a senior engineer. We'll map the outcome, scope and timeline — and you'll own everything we build."
      chips={[['fi-rr-gift', '100% free'], ['fi-rr-comment-check', 'No sales pressure'], ['fi-rr-shield-check', 'IP you fully own']]}
    />

  </div>
  <Footer />
</Layout>

<style>
  /* padding-bottom extends the clipped gradient down so descenders (y, g, p) aren't cut off */
  .accent { background: linear-gradient(100deg, #0ea5e9, #0369a1); -webkit-background-clip: text; background-clip: text; color: transparent; padding-bottom: 0.12em; }
  .wb-inline { font-weight: 700; color: var(--teal-dk); text-decoration: underline; text-underline-offset: 2px; text-decoration-thickness: 1px; }
  .wb-inline:hover { color: var(--teal); }
  .accent-l { background: linear-gradient(100deg, #7dd3fc, #38bdf8); -webkit-background-clip: text; background-clip: text; color: transparent; padding-bottom: 0.12em; }

  /* First-paint hardening (this page only): promote the shell to its own paint layer
     so the fixed sticky-reveal footer can't bleed through transparent sections before
     the first repaint. Safe — .page-shell has no position:fixed descendants. */
  :global(.page-shell) { transform: translateZ(0); }

  /* ===== hero ===== */
  .wb-hero { position: relative; padding-top: clamp(118px,11vw,156px); padding-bottom: clamp(40px,5vw,64px);
    background: radial-gradient(70% 60% at 12% -10%, rgba(117,209,249,.16), transparent 60%),
      radial-gradient(60% 55% at 100% 0%, rgba(61,101,255,.07), transparent 58%), linear-gradient(180deg, #F4F8FD, #EEF3F9); }
  .wb-hero-grid { position: absolute; inset: 0; pointer-events: none; opacity: .5;
    background-image: linear-gradient(rgba(15,23,42,.04) 1px, transparent 1px), linear-gradient(90deg, rgba(15,23,42,.04) 1px, transparent 1px);
    background-size: 46px 46px; -webkit-mask-image: radial-gradient(70% 60% at 50% 30%, #000, transparent 80%); mask-image: radial-gradient(70% 60% at 50% 30%, #000, transparent 80%); }
  .wb-hero-glow { position: absolute; right: -8%; top: -20%; width: 55%; height: 120%; border-radius: 50%; background: radial-gradient(circle, rgba(56,189,248,.16), transparent 65%); pointer-events: none; }
  .wb-hero-cols { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: clamp(32px,5vw,72px); align-items: center; }
  @media (max-width: 940px) { .wb-hero-cols { grid-template-columns: 1fr; } }

  .wb-ghost { display: inline-flex; align-items: center; gap: 8px; padding: 16px 24px; border-radius: 999px; border: 1px solid var(--line); background: #fff; color: var(--ink); font-weight: 600; font-size: 15px; transition: border-color .25s, transform .25s, color .25s; }
  .wb-ghost:hover { border-color: rgba(14,165,233,.5); color: var(--teal-dk); transform: translateY(-1px); } .wb-ghost i { line-height: 0; }

  .wb-stats { margin-top: clamp(30px,3.4vw,42px); display: flex; flex-wrap: wrap; align-items: center; gap: 8px 0; }
  .wb-stat { position: relative; display: flex; flex-direction: column; padding-right: clamp(18px,2.4vw,34px); padding-left: 0; }
  .wb-stat:first-child { padding-left: 0; }
  .wb-stat-n { font-size: clamp(24px,2.8vw,34px); font-weight: 900; letter-spacing: -.04em; line-height: 1;
    background: linear-gradient(120deg, #0ea5e9, #6366f1); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .wb-stat-l { margin-top: 7px; font-size: 12.5px; font-weight: 700; color: var(--muted); }
  .wb-stat-div { position: absolute; right: 0; top: 4px; bottom: 4px; width: 1px; background: var(--line); }
  @media (max-width: 560px) { .wb-stat { flex-basis: 50%; padding: 12px 0; } .wb-stat-div { display: none; } }

  /* ===== hero promise card ===== */
  .wb-promise { border-radius: 26px; background: #fff; border: 1px solid var(--line); box-shadow: 0 30px 70px -40px rgba(15,23,42,.4); padding: clamp(24px,2.6vw,32px); display: flex; flex-direction: column; gap: 18px; }
  .wb-promise-h { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-mono); font-size: 11px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); }
  .wb-promise-h i { color: var(--teal); font-size: 14px; line-height: 0; }
  .wb-promise-list { display: flex; flex-direction: column; gap: 16px; list-style: none; margin: 0; padding: 0; }
  .wb-promise-list li { display: flex; align-items: flex-start; gap: 13px; }
  .wb-promise-ic { flex: none; display: grid; place-items: center; width: 42px; height: 42px; border-radius: 13px; background: rgba(14,165,233,.1); border: 1px solid rgba(14,165,233,.2); color: var(--teal-dk); font-size: 18px; line-height: 0; }
  .wb-promise-list div b { display: block; font-size: 15px; font-weight: 800; letter-spacing: -.01em; color: var(--ink); }
  .wb-promise-list div span { display: block; margin-top: 2px; font-size: 13px; line-height: 1.5; color: var(--muted); }
  .wb-promise-cta { margin-top: 2px; display: inline-flex; align-items: center; gap: 7px; font-size: 14.5px; font-weight: 800; color: var(--teal-dk); }
  .wb-promise-cta i { line-height: 0; transition: transform .3s; }
  .wb-promise-cta:hover i { transform: translateX(4px); }

  /* ===== differentiators grid ===== */
  .wb-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(14px,1.6vw,18px); }
  @media (max-width: 860px) { .wb-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .wb-grid { grid-template-columns: 1fr; } }
  .wb-card { --mx: 50%; --my: 50%; position: relative; overflow: hidden; border-radius: 22px; background: #fff; border: 1px solid var(--line); padding: 28px; box-shadow: 0 10px 30px -22px rgba(35,38,46,.22); transition: transform .35s cubic-bezier(.16,1,.3,1), box-shadow .35s, border-color .35s; }
  .wb-card:hover { transform: translateY(-4px); border-color: rgba(14,165,233,.4); box-shadow: 0 26px 56px -28px rgba(14,165,233,.32); }
  .wb-card-spot { position: absolute; inset: 0; z-index: 0; pointer-events: none; opacity: 0; transition: opacity .35s; background: radial-gradient(320px circle at var(--mx) var(--my), rgba(56,189,248,.16), transparent 60%); }
  .wb-card:hover .wb-card-spot { opacity: 1; }
  .wb-card-ic { position: relative; z-index: 1; display: grid; place-items: center; width: 52px; height: 52px; border-radius: 15px; font-size: 22px; line-height: 0; background: rgba(14,165,233,.1); border: 1px solid rgba(14,165,233,.2); color: var(--teal-dk); transition: background .3s, color .3s, border-color .3s, transform .3s; }
  .wb-card:hover .wb-card-ic { background: var(--teal); color: #fff; border-color: transparent; transform: rotate(-6deg); }
  .wb-card-title { position: relative; z-index: 1; margin-top: 20px; font-size: 18.5px; font-weight: 800; letter-spacing: -.02em; color: var(--ink); }
  .wb-card-desc { position: relative; z-index: 1; margin-top: 9px; font-size: 14.5px; line-height: 1.55; color: var(--muted); }

  /* ===== accountability band ===== */
  .wb-acc-grid { display: grid; grid-template-columns: 1fr 1.05fr; gap: clamp(32px,5vw,64px); align-items: center; }
  @media (max-width: 900px) { .wb-acc-grid { grid-template-columns: 1fr; } }
  .wb-acc-tiles { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  @media (max-width: 480px) { .wb-acc-tiles { grid-template-columns: 1fr; } }
  .wb-acc-tile { padding: 24px; border-radius: 20px; background: rgba(255,255,255,.04); border: 1px solid rgba(125,211,252,.16); transition: border-color .3s, background .3s, transform .3s; }
  .wb-acc-tile:hover { border-color: rgba(125,211,252,.4); background: rgba(125,211,252,.07); transform: translateY(-3px); }
  .wb-acc-ic { display: grid; place-items: center; width: 46px; height: 46px; border-radius: 13px; background: rgba(125,211,252,.12); border: 1px solid rgba(125,211,252,.25); color: #7dd3fc; font-size: 19px; line-height: 0; }
  .wb-acc-t { margin-top: 16px; font-size: 16px; font-weight: 800; letter-spacing: -.01em; color: #fff; }
  .wb-acc-d { margin-top: 7px; font-size: 13.5px; line-height: 1.55; color: rgba(255,255,255,.6); }

  /* ===== process steps ===== */
  .wb-step { box-shadow: 0 10px 30px -20px rgba(35,38,46,.18); transition: transform .3s cubic-bezier(.16,1,.3,1), box-shadow .3s, border-color .3s; }
  .wb-step:hover { transform: translateY(-4px); border-color: rgba(14,165,233,.35); box-shadow: 0 22px 46px -26px rgba(14,165,233,.3); }
