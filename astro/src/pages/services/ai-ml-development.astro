                <i class={`fi ${ic} text-sky-300 text-[13px]`}></i> {label}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

  </div>
  <Footer />
</Layout>

<style>
  .accent { background: linear-gradient(100deg, #0ea5e9, #0369a1); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .accent-l { background: linear-gradient(100deg, #7dd3fc, #38bdf8); -webkit-background-clip: text; background-clip: text; color: transparent; }

  /* seamless transition into the dark footer — end gradient on footer's top color (#0B1220),
     not the lighter #111B2E, so no hairline shows at the seam */
  #cta.surface-dark { background: linear-gradient(180deg, #0B1220, #0F172A 55%, #0B1220); }

  /* ===== final CTA — glow panel ===== */
  .cta-card { isolation: isolate;
    background: linear-gradient(165deg, rgba(125,211,252,.10), rgba(15,23,42,.30) 55%, rgba(11,18,32,.20));
    border: 1px solid rgba(125,211,252,.18);
    box-shadow: 0 40px 90px -50px rgba(2,8,23,.9), inset 0 1px 0 rgba(255,255,255,.06);
    overflow: hidden; }
  .cta-card::before { content: ""; position: absolute; inset: 0; pointer-events: none; z-index: 0;
    background-image: linear-gradient(rgba(125,211,252,.05) 1px, transparent 1px),
                      linear-gradient(90deg, rgba(125,211,252,.05) 1px, transparent 1px);
    background-size: 38px 38px;
    -webkit-mask-image: radial-gradient(120% 90% at 50% 0%, #000 35%, transparent 75%);
            mask-image: radial-gradient(120% 90% at 50% 0%, #000 35%, transparent 75%); }
  .cta-card::after { content: ""; position: absolute; left: 0; right: 0; top: 0; height: 1px; z-index: 1;
    background: linear-gradient(90deg, transparent, rgba(125,211,252,.65), transparent); }
  .cta-orb { position: absolute; z-index: 0; left: 50%; top: -40%; width: 620px; max-width: 120%; aspect-ratio: 1;
    transform: translateX(-50%); pointer-events: none;
    background: radial-gradient(circle, rgba(14,165,233,.30), rgba(56,189,248,.10) 45%, transparent 70%);
    filter: blur(8px); animation: ctaGlow 7s ease-in-out infinite; }
  .cta-dot { width: 7px; height: 7px; border-radius: 999px; background: #7dd3fc; box-shadow: 0 0 0 0 rgba(125,211,252,.6);
    animation: ctaPulse 2s ease-out infinite; }
  .cta-chip { background: rgba(255,255,255,.05); border: 1px solid rgba(125,211,252,.16);
    backdrop-filter: blur(6px); transition: border-color .25s, background .25s, transform .25s; }
  .cta-chip:hover { border-color: rgba(125,211,252,.4); background: rgba(125,211,252,.10); transform: translateY(-2px); }
  @keyframes ctaPulse { 0% { box-shadow: 0 0 0 0 rgba(125,211,252,.55); } 70% { box-shadow: 0 0 0 9px rgba(125,211,252,0); } 100% { box-shadow: 0 0 0 0 rgba(125,211,252,0); } }
  @keyframes ctaGlow { 0%, 100% { opacity: .85; transform: translateX(-50%) scale(1); } 50% { opacity: 1; transform: translateX(-50%) scale(1.08); } }
  @media (prefers-reduced-motion: reduce) { .cta-orb, .cta-dot { animation: none; } .cta-chip { transition: none; } }

  /* hero two-column grid (raw CSS — Tailwind v4 doesn't emit grid-cols-[1.1fr_0.9fr]) */
  .svc-hero-grid-cols { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: clamp(32px, 5vw, 72px); align-items: center; }
  @media (max-width: 900px) { .svc-hero-grid-cols { grid-template-columns: 1fr; } }
  .svc-proof-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 18px; align-items: stretch; }
  @media (max-width: 820px) { .svc-proof-grid { grid-template-columns: 1fr; } }

  /* ===== merged trust box: 50/50 — certs (left) + numbers/reviews (right) ===== */
  .svc-trustbox { border-radius: 24px; background: #fff; border: 1px solid var(--line);
    box-shadow: 0 18px 48px -30px rgba(35,38,46,.26); overflow: hidden; }
  .svc-trustbox-split { display: grid; grid-template-columns: 60fr 40fr; align-items: stretch; }
  @media (max-width: 860px) { .svc-trustbox-split { grid-template-columns: 1fr; } }

  /* left: cert logos — single-line right-to-left marquee (compact, matches homepage box height) */
  .svc-tx-left { display: flex; align-items: center; gap: clamp(16px,2vw,28px);
    padding: clamp(14px,1.6vw,20px) clamp(20px,2.4vw,32px); position: relative; min-width: 0; }
  .svc-tx-left::after { content: ""; position: absolute; right: 0; top: 16px; bottom: 16px; width: 1px; background: var(--line); }
  @media (max-width: 860px) { .svc-tx-left::after { right: 22px; left: 22px; top: auto; bottom: 0; width: auto; height: 1px; } }
  .svc-tbx-label { flex: none; display: inline-flex; align-items: center; gap: 8px; max-width: 130px;
    font-family: var(--font-mono); font-size: 10.5px; font-weight: 600; line-height: 1.35; letter-spacing: .1em;
    text-transform: uppercase; color: var(--muted); }
  .svc-tbx-label i { color: var(--teal); font-size: 14px; line-height: 0; flex: none; }
  .svc-tx-track { flex: 1; min-width: 0; overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
            mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent); }
  .svc-tx-row { display: flex; align-items: center; gap: clamp(26px,3vw,46px); width: max-content; }
  .svc-tx-logo { display: inline-flex; align-items: center; flex: none; }
  .svc-tx-logo img { width: auto; max-height: 40px; object-fit: contain; opacity: .8; filter: saturate(.92); }
  @media (prefers-reduced-motion: no-preference) {
    .svc-tx-row { animation: svcMarquee 40s linear infinite; }
    .svc-tx-track:hover .svc-tx-row { animation-play-state: paused; }
  }
  @keyframes svcMarquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* right: key numbers, single row */
  .svc-tx-right { display: grid; grid-template-columns: repeat(3, 1fr); align-items: stretch; }
  .svc-tb-item { display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;
    gap: 4px; padding: clamp(14px,1.6vw,20px) 10px; position: relative; }
  .svc-tx-right .svc-tb-item + .svc-tb-item::before { content: ""; position: absolute; left: 0; top: 14px; bottom: 14px; width: 1px; background: var(--line); }
  .svc-tn { font-size: clamp(22px,2.3vw,30px); font-weight: 900; letter-spacing: -0.04em; line-height: 1; }
  .svc-tl { font-size: 11.5px; font-weight: 700; color: var(--muted); }
  @media (max-width: 520px) {
    .svc-tx-right .svc-tb-item:nth-child(3n+1)::before { display: none; }
    .svc-tx-right .svc-tb-item:nth-child(n+4) { border-top: 1px solid var(--line); } }

  /* ===== multimodal AI bento ===== */
  .svc-bento { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  @media (max-width: 980px) { .svc-bento { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .svc-bento { grid-template-columns: 1fr; } }

  .svc-bcard { --mx: 50%; --my: 50%; position: relative; display: flex; flex-direction: column; overflow: hidden;
    border-radius: 22px; background: #fff; border: 1px solid var(--line); padding: 26px;
    box-shadow: 0 10px 30px -22px rgba(35,38,46,.22);
    transition: transform .35s cubic-bezier(.16,1,.3,1), box-shadow .35s, border-color .35s; }
  .svc-bcard:hover { transform: translateY(-4px); border-color: rgba(14,165,233,.4); box-shadow: 0 26px 56px -28px rgba(14,165,233,.32); }
  /* spotlight glow that follows the cursor (same as homepage AI-Native cards) */
  .svc-bcard-spot { position: absolute; inset: 0; z-index: 0; pointer-events: none; opacity: 0; transition: opacity .35s;
    background: radial-gradient(300px circle at var(--mx) var(--my), rgba(56,189,248,.18), transparent 60%); }
  .svc-bcard:hover .svc-bcard-spot { opacity: 1; }
  /* bright reactive border that lights up near the cursor */
  .svc-bcard::before { content: ""; position: absolute; inset: 0; border-radius: inherit; padding: 1px; pointer-events: none; z-index: 1;
    background: radial-gradient(220px circle at var(--mx) var(--my), rgba(14,165,233,.85), transparent 60%);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor; mask-composite: exclude;
    opacity: 0; transition: opacity .35s; }
  .svc-bcard:hover::before { opacity: 1; }
  /* big featured cards span 2 cols — white like the rest, just wider */
  .svc-bcard-big { grid-column: span 2; background: #fff; }
  @media (max-width: 520px) { .svc-bcard-big { grid-column: span 1; } }

  .svc-bcard-top { position: relative; z-index: 1; display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .svc-bcard-ic { display: grid; place-items: center; width: 50px; height: 50px;
    border-radius: 14px; font-size: 21px; line-height: 0; flex: none;
    background: rgba(14,165,233,.1); border: 1px solid rgba(14,165,233,.2); color: var(--teal-dk);
    transition: background .3s, color .3s, border-color .3s, transform .3s; }
  .svc-bcard:hover .svc-bcard-ic { background: var(--teal); color: #fff; border-color: transparent; transform: rotate(-6deg); }
  .svc-bcard-big .svc-bcard-ic { background: rgba(14,165,233,.12); border-color: rgba(14,165,233,.25); color: var(--teal-dk); }
  .svc-bcard-big:hover .svc-bcard-ic { background: var(--teal); color: #fff; border-color: transparent; }

  /* ===== per-card AI micro-animations (Gemini-style) ===== */
  .svc-viz { --c: #0ea5e9; position: relative; width: 56px; height: 34px; flex: none;
    display: flex; align-items: center; justify-content: center; gap: 4px; opacity: .9; }
  @media (prefers-reduced-motion: reduce) { .svc-viz i { animation: none !important; } }

  /* chat — typing dots */
  .svc-viz-chat i { width: 7px; height: 7px; border-radius: 50%; background: var(--c); animation: vChat 1.3s ease-in-out infinite; }
  .svc-viz-chat i:nth-child(2) { animation-delay: .18s; } .svc-viz-chat i:nth-child(3) { animation-delay: .36s; }
  @keyframes vChat { 0%,60%,100% { transform: translateY(0); opacity: .35; } 30% { transform: translateY(-6px); opacity: 1; } }

  /* voice — waveform bars */
  .svc-viz-voice { align-items: center; gap: 3px; }
  .svc-viz-voice i { width: 3px; height: 8px; border-radius: 2px; background: var(--c); animation: vWave 1s ease-in-out infinite; }
  .svc-viz-voice i:nth-child(2){animation-delay:.15s} .svc-viz-voice i:nth-child(3){animation-delay:.3s} .svc-viz-voice i:nth-child(4){animation-delay:.45s} .svc-viz-voice i:nth-child(5){animation-delay:.6s}
  @keyframes vWave { 0%,100% { height: 7px; } 50% { height: 24px; } }

  /* chart — rising bars */
