---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import CtaButton from '../../components/CtaButton.astro'

const BASE = import.meta.env.BASE_URL

// real client logos (same set the homepage uses for "Trusted by 200+ companies")
const CDN = 'https://www.biztechcs.com/wp-content/uploads'
const CLIENTS = [
  { name: 'Forbes Marshall', src: `${CDN}/2023/05/forbes-marshall.png` },
  { name: 'Bonfiglioli', src: `${CDN}/2023/05/bonfiglioli.png` },
  { name: 'Ovivo', src: `${CDN}/2023/05/Ovivo.svg` },
  { name: 'Biorbyt', src: `${CDN}/2023/05/Biorbyt.svg` },
  { name: 'Medguard', src: `${CDN}/2023/05/medguard.png` },
]

// recognition badges (same set as the homepage TrustBand)
const BADGES = [
  { name: 'Clutch', src: `${BASE}/assets/badges/clutch.svg`, h: 30 },
  { name: 'Google Premier Partner 2024', src: `${BASE}/assets/badges/google-partner.svg`, h: 40 },
  { name: 'GESIA Member', src: `${BASE}/assets/badges/gesia.svg`, h: 38 },
  { name: 'Salesforce ISV Partner', src: `${BASE}/assets/badges/salesforce-isv.svg`, h: 28 },
  { name: 'Top App Development Companies', src: `${BASE}/assets/badges/tadc.svg`, h: 46 },
  { name: 'SugarCRM ISV Partner', src: `${BASE}/assets/badges/sugarcrm.png`, h: 30 },
  { name: 'Techimply', src: `${BASE}/assets/badges/techimply.svg`, h: 46 },
  { name: 'TÜV certified', src: `${BASE}/assets/badges/tuv.svg`, h: 38 },
  { name: 'Great Place To Work', src: `${BASE}/assets/badges/gptw.svg`, h: 40 },
  { name: 'Odoo Partner', src: `${BASE}/assets/badges/odoo.svg`, h: 28 },
]

// orbiting AI capability nodes for the animated hero visual (angle in deg around the core)
const ORBIT_NODES = [
  { ic: 'fi-rr-robot', label: 'Agents', angle: -90, ring: 'r1' },
  { ic: 'fi-rr-sparkles', label: 'GenAI', angle: 18, ring: 'r1' },
  { ic: 'fi-rr-search', label: 'RAG', angle: 126, ring: 'r1' },
  { ic: 'fi-rr-brain', label: 'ML', angle: -36, ring: 'r2' },
  { ic: 'fi-rr-share-square', label: 'Multi-agent', angle: 90, ring: 'r2' },
  { ic: 'fi-rr-settings', label: 'MLOps', angle: 210, ring: 'r2' },
]

// ── Multimodal AI systems we build (bento showcase, à la Gemini / Google Labs) ──
// each card carries a `viz` type → a small AI-themed animation rendered in the card
const BUILDS = [
  { ic: 'fi-rr-comment-alt', viz: 'chat', title: 'Conversational AI & Chatbots', desc: 'Chat assistants and copilots that understand context, hold a real conversation and take action across your systems.', big: true },
  { ic: 'fi-rr-picture', viz: 'image', title: 'Image Generation & Vision', desc: 'Generate, edit and analyse images — product visuals, OCR and defect detection.' },
  { ic: 'fi-rr-video-camera', viz: 'video', title: 'Video AI', desc: 'Generate, caption, summarise and search video at scale.' },
  { ic: 'fi-rr-document', viz: 'doc', title: 'Document & PDF Intelligence', desc: 'Extract, classify and answer questions across contracts, forms and reports.' },
  { ic: 'fi-rr-microphone', viz: 'voice', title: 'Voice & Speech AI', desc: 'Real-time transcription, voice agents and natural speech synthesis.' },
  { ic: 'fi-rr-search-alt', viz: 'research', title: 'Deep Research Agents', desc: 'Agents that browse, synthesise and cite across hundreds of sources — turning hours of research into minutes.', big: true },
  { ic: 'fi-rr-terminal', viz: 'code', title: 'Code Generation', desc: 'AI copilots that write, review and refactor code in your stack.' },
  { ic: 'fi-rr-chart-line-up', viz: 'chart', title: 'Predictive Analytics & ML', desc: 'Forecasting, scoring, recommendations and anomaly detection on your data.' },
  { ic: 'fi-rr-layers', viz: 'multi', title: 'Multimodal Copilots', desc: 'One assistant that blends text, image, voice and data — grounded in your knowledge, governed end to end.', big: true },
]

// ── Process ──
const STEPS = [
  { n: '01', title: 'Discovery & use-case fit', desc: 'We pressure-test the idea, define success metrics and pick the problems AI can actually solve.' },
  { n: '02', title: 'Data & prototype', desc: 'Assess your data, build a working prototype, and validate accuracy before you commit to a full build.' },
  { n: '03', title: 'Productionise', desc: 'Evals, guardrails, observability and cost controls — engineered to ship safely to real users.' },
  { n: '04', title: 'Monitor & improve', desc: 'Continuous evaluation, retraining and tuning so performance holds up as data and usage evolve.' },
]

// ── Outcomes / why us ──
const REASONS = [
  { ic: 'fi-rr-rocket-lunch', title: 'From pilot to production', desc: 'We specialise in the hard part — taking GenAI past the demo into something safe to run in front of customers.' },
  { ic: 'fi-rr-shield-check', title: 'Governed & compliant', desc: 'ISO 27001 & 9001 certified, with data privacy, access controls and AI governance built in from day one.' },
  { ic: 'fi-rr-users-alt', title: 'Senior, US/EU-accountable', desc: 'Senior AI engineers with US & EU project leads, time-zone-aligned delivery, and IP you fully own.' },
  { ic: 'fi-rr-chart-line-up', title: 'Outcome-focused', desc: 'We measure success in your numbers — automation, accuracy and cost saved — not models shipped.' },
]

// ── Real-world AI solutions we've shipped (from delivered work) ──
const SOLUTIONS = [
  { ic: 'fi-rr-time-check', title: 'Predictive Maintenance', industry: 'Manufacturing', metric: '↓40%', metricLabel: 'unplanned downtime', desc: 'Sensor & machine-log models that flag equipment failure before it happens.' },
  { ic: 'fi-rr-recycle', title: 'Dynamic Production Scheduling', industry: 'Manufacturing', metric: '↓25%', metricLabel: 'material waste', desc: 'Demand-matched scheduling that cuts over-production and idle capacity.' },
  { ic: 'fi-rr-shield-exclamation', title: 'Real-Time Fraud Detection', industry: 'Fintech · Insurance', metric: 'Real-time', metricLabel: 'anomaly flagging', desc: 'Transaction & claims models that catch irregular patterns the moment they occur.' },
  { ic: 'fi-rr-box-open', title: 'Smart Inventory Forecasting', industry: 'Retail · Ecommerce', metric: 'Seasonal', metricLabel: 'demand prediction', desc: 'Forecasts material needs from seasonality and sales patterns to avoid stockouts.' },
  { ic: 'fi-rr-calculator', title: 'Credit Scoring Automation', industry: 'Finance', metric: 'Alt-data', metricLabel: 'creditworthiness', desc: 'Assesses risk using alternative data — faster, fairer lending decisions.' },
  { ic: 'fi-rr-comment-alt', title: 'Support & Ops Copilots', industry: 'Cross-industry', metric: '24/7', metricLabel: 'AI assistance', desc: 'RAG-grounded agents that resolve tickets and surface answers from your own docs.' },
]

// ── Industries we build AI for (Flaticon fi-rr icons) ──
const INDUSTRIES = [
  { ic: 'fi-rr-industry-windows', name: 'Manufacturing', desc: 'Predictive maintenance, quality vision & production scheduling.' },
  { ic: 'fi-rr-coins', name: 'Fintech', desc: 'Fraud detection, credit scoring & real-time risk modelling.' },
  { ic: 'fi-rr-umbrella', name: 'Insurance', desc: 'Claims automation, fraud flagging & smarter underwriting.' },
  { ic: 'fi-rr-stethoscope', name: 'Healthcare & Life Sciences', desc: 'Clinical document AI, diagnostics support & compliance.' },
  { ic: 'fi-rr-shopping-cart', name: 'Retail & Ecommerce', desc: 'Demand forecasting, recommendations & visual search.' },
  { ic: 'fi-rr-bank', name: 'Finance', desc: 'Forecasting, anomaly detection & reporting automation.' },
  { ic: 'fi-rr-graduation-cap', name: 'Education', desc: 'Adaptive learning, auto-grading & student-risk prediction.' },
  { ic: 'fi-rr-home', name: 'Real Estate', desc: 'Valuation models, lead scoring & document parsing.' },
  { ic: 'fi-rr-plane', name: 'Travel & Hospitality', desc: 'Dynamic pricing, AI concierge & demand forecasting.' },
  { ic: 'fi-rr-print', name: 'Printing & Web-to-Print', desc: 'Design automation, OCR & order intelligence.' },
  { ic: 'fi-rr-truck-side', name: 'Logistics', desc: 'Route optimisation, ETA prediction & demand planning.' },
  { ic: 'fi-rr-laptop-code', name: 'IT & Software', desc: 'Code copilots, support agents & ops automation.' },
]

// ── Tech stack (incl. real agent frameworks we use) ──
// official brand marks via Simple Icons CDN (white-tinted for the dark section);
// items without a clean brand mark fall back to a Flaticon glyph.
const SIC = 'https://cdn.jsdelivr.net/npm/simple-icons@v13/icons'
const STACK = [
  { name: 'OpenAI', logo: `${SIC}/openai.svg` },
  { name: 'Claude', logo: `${SIC}/anthropic.svg` },
  { name: 'Gemini', logo: `${SIC}/googlegemini.svg` },
  { name: 'Llama', logo: `${SIC}/meta.svg` },
  { name: 'Mistral', logo: `${SIC}/mistralai.svg` },
  { name: 'LangChain', logo: `${SIC}/langchain.svg` },
  { name: 'LangGraph', logo: `${SIC}/langgraph.svg` },
  { name: 'CrewAI', logo: `${SIC}/crewai.svg` },
  { name: 'AutoGen', ic: 'fi-rr-comments' },
  { name: 'Semantic Kernel', ic: 'fi-rr-share-square' },
  { name: 'OpenAI Agents SDK', logo: `${SIC}/openai.svg` },
  { name: 'LlamaIndex', logo: `${SIC}/llamaindex.svg` },
  { name: 'n8n', logo: `${SIC}/n8n.svg` },
  { name: 'Power Automate', ic: 'fi-rr-bolt' },
  { name: 'Pinecone', logo: `${SIC}/pinecone.svg` },
  { name: 'Weaviate', logo: `${SIC}/weaviate.svg` },
  { name: 'pgvector', logo: `${SIC}/postgresql.svg` },
  { name: 'Hugging Face', logo: `${SIC}/huggingface.svg` },
  { name: 'PyTorch', logo: `${SIC}/pytorch.svg` },
  { name: 'TensorFlow', logo: `${SIC}/tensorflow.svg` },
  { name: 'AWS Bedrock', logo: `${SIC}/amazonwebservices.svg` },
  { name: 'Azure AI', ic: 'fi-rr-cloud' },
  { name: 'Vertex AI', logo: `${SIC}/googlecloud.svg` },
  { name: 'Ray', ic: 'fi-rr-microchip' },
]

// ── Engagement models ──
const MODELS = [
  { ic: 'fi-rr-bullseye-arrow', title: 'AI Proof-of-Concept', desc: 'A fixed-scope prototype to validate feasibility and ROI before a full build.', featured: false },
  { ic: 'fi-rr-users-alt', title: 'Dedicated AI Team', desc: 'A senior squad embedded with yours for ongoing AI product development.', featured: true },
  { ic: 'fi-rr-user-add', title: 'AI Staff Augmentation', desc: 'Plug ML/LLM specialists into your team to close a specific capability gap.', featured: false },
]

// ── FAQ ──
const FAQS = [
  { q: 'Can you take our GenAI pilot to production?', a: 'Yes — that\'s our specialism. We add evaluations, guardrails, observability, access controls and cost monitoring so a promising demo becomes something you can safely ship to real users.' },
  { q: 'Do we need a large dataset to start?', a: 'Not always. RAG and foundation-model approaches work with modest data; for custom ML we\'ll assess what you have in discovery and tell you honestly whether it\'s enough — or how to get there.' },
  { q: 'How do you keep AI accurate and safe?', a: 'Every build includes an evaluation harness, guardrails and human-in-the-loop where needed, plus continuous monitoring so we catch drift and regressions before your users do.' },
  { q: 'Who owns the models and IP?', a: 'You do. Work-for-hire with full IP transfer on payment, backed by NDAs — including model weights, prompts, pipelines and code.' },
  { q: 'Which models and clouds do you work with?', a: 'OpenAI, Anthropic Claude, Google Gemini, open-source Llama/Mistral, and managed platforms like AWS Bedrock, Azure AI and Vertex AI — we pick what fits your accuracy, cost and compliance needs.' },
]
---
<Layout>
  <Header />
  <div class="page-shell">

    <!-- ───────── HERO (light theme) ───────── -->
    <section class="svc-hero relative overflow-hidden" id="top">
      <span class="svc-hero-grid" aria-hidden="true"></span>
      <span class="svc-hero-glow" aria-hidden="true"></span>
      <div class="wrap relative">
        <div class="svc-hero-grid-cols mt-[clamp(28px,4vw,44px)]">
          <div>
            <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk">
              <i class="fi fi-rr-microchip-ai text-teal"></i> AI / ML Development
            </span>
            <h1 data-reveal style="--d:.06s" class="mt-6 text-[clamp(34px,5.2vw,60px)] font-black tracking-[-0.04em] leading-[1.06] text-ink">
              Build AI systems that <span class="accent">do the work</span> — not just demos.
            </h1>
            <p data-reveal style="--d:.12s" class="mt-7 text-[clamp(16px,1.3vw,18px)] leading-[1.65] text-muted max-w-[540px]">
              From GenAI pilots to production-grade autonomous agents. We design, evaluate and run AI you can trust in front of customers — with US &amp; EU accountability and IP you fully own.
            </p>
            <div data-reveal style="--d:.18s" class="mt-9 flex flex-wrap gap-3">
              <CtaButton href="#cta" label="Scope an AI build" variant="dark" />
              <a href="#capabilities" class="svc-ghost">See what we build <i class="fi fi-rr-arrow-down"></i></a>
            </div>

            <!-- trusted-by client logos (homepage style) -->
            <div data-reveal style="--d:.26s" class="svc-hero-clients">
              <span class="svc-hc-label">Trusted by <b>200+</b> companies</span>
              <ul class="svc-hc-logos">
                {CLIENTS.map((c) => <li><img src={c.src} alt={c.name} loading="lazy" /></li>)}
              </ul>
            </div>
          </div>
          <!-- animated AI core orbit visual -->
          <div data-reveal style="--d:.16s" class="svc-orbit" role="img" aria-label="An AI core surrounded by orbiting capabilities — agents, GenAI, RAG, ML, multi-agent and MLOps">
            <span class="svc-orbit-glow" aria-hidden="true"></span>
            <span class="svc-ring svc-ring-1" aria-hidden="true"></span>
            <span class="svc-ring svc-ring-2" aria-hidden="true"></span>
            <span class="svc-ring svc-ring-3" aria-hidden="true"></span>
            <!-- pulsing core -->
            <div class="svc-core">
              <i class="fi fi-rr-microchip-ai"></i>
              <span class="svc-core-pulse" aria-hidden="true"></span>
              <span class="svc-core-pulse svc-core-pulse-2" aria-hidden="true"></span>
            </div>
            <!-- orbiting capability nodes -->
            {ORBIT_NODES.map((n) => (
              <div class={`svc-node svc-node-${n.ring}`} style={`--a:${n.angle}deg`}>
                <div class="svc-node-chip" title={n.label}>
                  <i class={`fi ${n.ic}`}></i>
                  <span>{n.label}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ───────── TRUST: certified logos + stats/reviews merged in one box ───────── -->
    <section id="trust" aria-label="Certifications, track record and reviews" class="pt-[clamp(16px,2vw,28px)] pb-[clamp(8px,1vw,16px)]">
      <div class="wrap">
        <div data-reveal class="svc-trustbox svc-trustbox-split">
          <!-- LEFT 50%: recognized & certified — single-line right-to-left marquee -->
          <div class="svc-tx-left">
            <span class="svc-tbx-label"><i class="fi fi-rr-shield-check"></i> Recognized<br/>&amp; certified</span>
            <div class="svc-tx-track">
              <div class="svc-tx-row">
                {BADGES.map((b) => <span class="svc-tx-logo"><img src={b.src} alt={b.name} title={b.name} loading="lazy" /></span>)}
                {BADGES.map((b) => <span class="svc-tx-logo" aria-hidden="true"><img src={b.src} alt="" loading="lazy" /></span>)}
              </div>
            </div>
          </div>
          <!-- RIGHT 50%: key numbers, single row -->
          <div class="svc-tx-right">
            <div class="svc-tb-item"><div class="svc-tn accent">1200+</div><div class="svc-tl">Projects delivered</div></div>
            <div class="svc-tb-item"><div class="svc-tn accent">98%</div><div class="svc-tl">Client retention</div></div>
            <div class="svc-tb-item"><div class="svc-tn accent">80%</div><div class="svc-tl">Senior engineers</div></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ───────── MULTIMODAL AI SHOWCASE (bento) ───────── -->
    <section id="capabilities" class="py-[var(--section-y)]">
      <div class="wrap">
        <div class="text-center mb-[clamp(36px,4vw,52px)]">
          <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk"><i class="fi fi-rr-apps text-teal"></i> AI systems we build</span>
          <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(28px,4vw,48px)] font-black tracking-[-0.04em] leading-[1.05] max-w-[720px] mx-auto">From chat to vision to video — <span class="accent">one AI partner.</span></h2>
          <p data-reveal style="--d:.12s" class="mt-5 text-muted text-[clamp(15px,1.2vw,17px)] leading-[1.6] max-w-[560px] mx-auto">Text, image, voice, video, documents and data — we engineer the full spectrum of AI systems, governed and production-ready.</p>
        </div>
        <div class="svc-bento">
          {BUILDS.map((b, i) => (
            <article data-reveal style={`--d:${(0.08 + i * 0.05).toFixed(2)}s`} class:list={["svc-bcard group", b.big && "svc-bcard-big"]}>
              <span class="svc-bcard-spot" aria-hidden="true"></span>
              <div class="svc-bcard-top">
                <span class="svc-bcard-ic"><i class={`fi ${b.ic}`}></i></span>
                <span class={`svc-viz svc-viz-${b.viz}`} aria-hidden="true">
                  {b.viz === 'chat' && <><i></i><i></i><i></i></>}
                  {b.viz === 'voice' && <><i></i><i></i><i></i><i></i><i></i></>}
                  {b.viz === 'chart' && <><i></i><i></i><i></i><i></i></>}
                  {b.viz === 'code' && <><i></i><i></i><i></i></>}
                  {b.viz === 'research' && <><i></i><i></i><i></i></>}
                  {b.viz === 'image' && [0,1,2,3,4,5,6,7,8].map(() => <i></i>)}
                  {b.viz === 'video' && <><i></i><i></i><i></i></>}
                  {b.viz === 'doc' && <><i></i><i></i><i></i><i></i></>}
                  {b.viz === 'multi' && <><i></i><i></i><i></i></>}
                </span>
              </div>
              <div class="svc-bcard-body">
                <h3 class="svc-bcard-title">{b.title}</h3>
                <p class="svc-bcard-desc">{b.desc}</p>
              </div>
              <span class="svc-bcard-arrow"><i class="fi fi-rr-arrow-right"></i></span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ───────── AI SOLUTIONS (real shipped work, dark showcase) ───────── -->
    <section id="solutions" class="surface-dark py-[var(--section-y)]">
      <div class="wrap">
        <div class="flex flex-wrap items-end justify-between gap-6 mb-[clamp(36px,4vw,52px)]">
          <div class="max-w-[640px]">
            <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em]"><i class="fi fi-rr-bulb"></i> AI solutions we've shipped</span>
            <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(28px,4vw,48px)] font-black tracking-[-0.04em] leading-[1.05] text-white whitespace-nowrap max-[520px]:whitespace-normal">Real AI, real <span class="accent-l">business outcomes.</span></h2>
          </div>
          <p data-reveal style="--d:.12s" class="text-[14px] font-semibold text-white/55 max-w-[300px] max-[680px]:max-w-none">Not lab demos — production AI that moved measurable numbers for real clients.</p>
        </div>
        <div class="grid grid-cols-3 gap-[16px] max-[860px]:grid-cols-2 max-[520px]:grid-cols-1">
          {SOLUTIONS.map((s, i) => (
            <div data-reveal style={`--d:${(0.1 + i * 0.05).toFixed(2)}s`} class="svc-sol group flex flex-col rounded-3xl p-7 transition duration-300 hover:-translate-y-1.5">
              <div class="flex items-center justify-between gap-3">
                <span class="grid place-items-center w-12 h-12 rounded-xl bg-white/8 border border-white/12 text-teal-300 text-[19px] transition group-hover:bg-teal group-hover:text-white group-hover:border-transparent"><i class={`fi ${s.ic}`}></i></span>
                <span class="svc-sol-ind">{s.industry}</span>
              </div>
              <div class="mt-5 flex items-baseline gap-2">
                <span class="svc-sol-metric accent-l">{s.metric}</span>
                <span class="text-[12.5px] font-semibold text-white/55">{s.metricLabel}</span>
              </div>
              <h3 class="mt-3 text-[17px] font-extrabold tracking-[-0.02em] text-white">{s.title}</h3>
              <p class="mt-2 text-[13.5px] leading-[1.5] text-white/60">{s.desc}</p>
            </div>
          ))}
        </div>
        <p data-reveal style="--d:.4s" class="mt-7 text-center text-[13px] text-white/45">Metrics reflect outcomes on delivered projects. <a href="#cta" class="font-bold text-teal-300 underline-offset-4 hover:underline">Ask for the case studies →</a></p>
      </div>
    </section>

    <!-- ───────── INDUSTRIES ───────── -->
    <section class="py-[var(--section-y)]">
      <div class="wrap">
        <div class="text-center mb-[clamp(32px,4vw,48px)]">
          <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk"><i class="fi fi-rr-building text-teal"></i> Industries we serve</span>
          <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(26px,3.6vw,44px)] font-black tracking-[-0.04em] leading-[1.05] max-w-[560px] mx-auto">AI built for how your <span class="accent whitespace-nowrap">industry operates.</span></h2>
        </div>
        <div class="svc-ind-grid">
          {INDUSTRIES.map((ind, i) => (
            <div data-reveal style={`--d:${(0.06 + i * 0.04).toFixed(2)}s`} class="svc-ind-card group">
              <span class="svc-ind-ic"><i class={`fi ${ind.ic}`}></i></span>
              <div>
                <h3 class="svc-ind-name">{ind.name}</h3>
                <p class="svc-ind-desc">{ind.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ───────── WHY US ───────── -->
    <section class="surface-tint py-[var(--section-y)]">
      <div class="wrap">
        <div class="text-center mb-[clamp(36px,4vw,52px)]">
          <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk"><i class="fi fi-rr-badge-check text-teal"></i> Why BiztechCS for AI</span>
          <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(28px,4vw,48px)] font-black tracking-[-0.04em] leading-[1.05] max-w-[680px] mx-auto">AI that ships — and <span class="accent">keeps working.</span></h2>
        </div>
        <div class="grid grid-cols-4 gap-[16px] max-[900px]:grid-cols-2 max-[480px]:grid-cols-1">
          {REASONS.map((r, i) => (
            <div data-reveal style={`--d:${(0.1 + i * 0.06).toFixed(2)}s`} class="rounded-3xl bg-white border border-line p-7">
              <span class="grid place-items-center w-12 h-12 rounded-xl bg-teal/10 border border-teal/20 text-teal text-[19px]"><i class={`fi ${r.ic}`}></i></span>
              <h3 class="mt-5 text-[16px] font-extrabold tracking-[-0.02em] text-ink">{r.title}</h3>
              <p class="mt-2 text-[13.5px] leading-[1.5] text-muted">{r.desc}</p>
