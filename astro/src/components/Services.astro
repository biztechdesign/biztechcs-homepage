---
const SERVICES = [
  { h: 'AI / ML & GenAI', p: 'AI agents, LLM apps and intelligent automation, moved from experiments to production.', ic: 'fi-rr-brain', viz: 'arc', feature: true },
  { h: 'Custom Software', p: 'Web & mobile apps from MVP to scale, with clean, maintainable architecture.', ic: 'fi-rr-laptop-code', viz: 'ui', feature: false },
  { h: 'Enterprise & ERP', p: 'Odoo, Dynamics 365 and Salesforce — implementation, customization, integration.', ic: 'fi-rr-building', viz: 'blob', feature: false },
  { h: 'Ecommerce', p: 'Magento, Shopify and headless commerce built to convert and scale globally.', ic: 'fi-rr-shopping-cart', viz: 'blob', feature: false },
  { h: 'Cloud & DevOps', p: 'AWS & Azure architecture, CI/CD, SRE and security from day one.', ic: 'fi-rr-cloud', viz: 'wave', feature: false },
  { h: 'QA Engineering', p: 'Manual & automated testing in every sprint — ship fast without bugs.', ic: 'fi-rr-shield-check', viz: 'wave', feature: false },
]
const WAVE = [30, 52, 40, 68, 84, 60, 44, 72, 90, 56, 38, 64, 80, 50, 34, 58, 76, 46, 62, 42, 54, 36]
const ARC = ['fi-rr-database', 'fi-rr-cloud', 'fi-rr-brain', 'fi-rr-settings', 'fi-rr-shield-check']
---
<section id="services" class="relative py-[var(--section-y)]">
  <div class="mx-auto max-w-[1440px] px-8 max-[680px]:px-5">
    <!-- header -->
    <div class="flex flex-wrap items-end justify-between gap-9 mb-[clamp(40px,4.5vw,60px)]">
      <div>
        <span data-reveal class="inline-block rounded-full bg-white border border-line px-4 py-[7px] text-[13px] font-bold text-ink shadow-[0_6px_18px_-10px_rgba(35,38,46,0.25)]">Services</span>
        <h2 data-reveal style="--d:.06s" class="mt-[22px] text-[clamp(34px,4.6vw,60px)] font-black tracking-[-0.04em] leading-[1.02]">
          Enterprise software,<br /><span class="accent">built end to end.</span>
        </h2>
        <p data-reveal style="--d:.12s" class="mt-[18px] max-w-[460px] text-muted text-base leading-[1.55]">
          From AI agents to ERP, ecommerce to cloud — one senior team with US &amp; EU leads, full ownership, and IP you keep.
        </p>
      </div>
      <a data-reveal style="--d:.16s" href="#cta" class="explore inline-flex items-center gap-[10px] rounded-full bg-ink text-white px-[26px] py-[15px] text-[14.5px] font-bold whitespace-nowrap no-underline transition-transform duration-300 hover:-translate-y-0.5">
        Explore services <i class="fi fi-rr-arrow-right"></i>
      </a>
    </div>

    <!-- bento grid -->
    <div class="grid grid-cols-3 auto-rows-[minmax(220px,1fr)] gap-[18px] max-[1024px]:grid-cols-2 max-[680px]:grid-cols-1">
      {SERVICES.map((s, i) => (
        <a
          href="#cta"
          data-reveal
          style={`--d:${(i * 0.06).toFixed(2)}s`}
          class:list={[
            'card group relative flex flex-col gap-[18px] p-7 rounded-3xl bg-white border border-line overflow-hidden no-underline text-inherit transition duration-300 hover:-translate-y-1.5 hover:border-teal/40',
            s.feature && 'col-span-2 row-span-2 max-[1024px]:col-span-2 max-[1024px]:row-span-1 max-[680px]:col-span-1',
          ]}
        >
          <div class="flex gap-4 items-start">
            <span
              class:list={[
                'shrink-0 grid place-items-center rounded-2xl transition duration-300 group-hover:-rotate-6',
                s.feature
                  ? 'w-16 h-16 text-[28px] bg-teal text-white'
                  : 'w-[52px] h-[52px] text-[22px] text-teal bg-teal/10 border border-teal/20',
              ]}
            >
              <i class={`fi ${s.ic}`}></i>
            </span>
            <div>
              <h3 class:list={['font-extrabold tracking-[-0.02em] text-ink', s.feature ? 'text-[clamp(26px,2.6vw,34px)]' : 'text-xl']}>{s.h}</h3>
              <p class:list={['mt-[7px] leading-[1.55] text-muted', s.feature ? 'text-base max-w-[430px]' : 'text-sm']}>{s.p}</p>
            </div>
          </div>

          <div class:list={['viz', `viz-${s.viz}`, s.feature && 'is-feature']}>
            {s.viz === 'arc' && (
              <Fragment>
                <span class="arc-rail"></span>
                {ARC.map((ic, idx) => (
                  <span class={`arc-node n${idx}`}><i class={`fi ${ic}`}></i></span>
                ))}
              </Fragment>
            )}
            {s.viz === 'wave' && WAVE.map((h) => <span style={`height:${h}%`}></span>)}
            {s.viz === 'blob' && (
              <Fragment>
                <span class="blob-g"></span>
                <i class={`fi ${s.ic} blob-ic`}></i>
              </Fragment>
            )}
            {s.viz === 'ui' && (
              <Fragment>
                <span class="ui-ln w-[72%]"></span>
                <span class="ui-ln w-[92%]"></span>
                <span class="ui-ln w-[54%]"></span>
                <span class="ui-btn">Get a quote</span>
              </Fragment>
            )}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .accent { background: linear-gradient(100deg, #0ea5e9, #0369a1); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .explore:hover { box-shadow: 0 16px 36px -14px rgba(14, 165, 233, 0.5); }
  .explore i { transition: transform 0.3s; line-height: 0; }
  .explore:hover i { transform: translateX(4px); }
  .card:hover { box-shadow: 0 26px 60px -26px rgba(14, 165, 233, 0.35); }

  /* viz zones (bespoke illustrations) */
  .viz { position: relative; flex: 1; min-height: 96px; border-radius: 16px; background: #f8fafc; border: 1px solid #e2e8f0; overflow: hidden; }
  .viz.is-feature { min-height: 210px; }
  /* arc */
  .viz-arc { display: flex; align-items: center; justify-content: center; }
  .arc-rail { position: absolute; left: 10%; right: 10%; top: 50%; height: 2px; background: linear-gradient(90deg, transparent, rgba(14, 165, 233, 0.5), transparent); }
  .arc-node { position: relative; z-index: 1; width: 54px; height: 54px; margin: 0 16px; border-radius: 50%; display: grid; place-items: center; background: #0f172a; color: #fff; font-size: 18px; box-shadow: 0 12px 26px -10px rgba(35, 38, 46, 0.55); }
  .arc-node i { line-height: 0; }
  .arc-node.n0, .arc-node.n4 { transform: translateY(30px); width: 46px; height: 46px; font-size: 15px; }
  .arc-node.n1, .arc-node.n3 { transform: translateY(-6px); }
  .arc-node.n2 { background: linear-gradient(140deg, #0ea5e9, #0369a1); transform: translateY(-26px); width: 62px; height: 62px; font-size: 24px; }
  /* wave */
  .viz-wave { display: flex; align-items: center; justify-content: center; gap: 5px; padding: 0 20px; }
  .viz-wave span { width: 5px; border-radius: 4px; background: linear-gradient(180deg, #0ea5e9, #0369a1); opacity: 0.85; }
  /* blob */
  .viz-blob .blob-g { position: absolute; right: -22%; top: -34%; width: 78%; height: 160%; border-radius: 50%; background: radial-gradient(circle, rgba(14, 165, 233, 0.5), rgba(61, 101, 255, 0.28) 50%, transparent 72%); filter: blur(6px); }
  .viz-blob .blob-ic { position: absolute; left: 24px; bottom: 20px; font-size: 40px; color: #0369a1; line-height: 0; }
  /* mini mock UI */
  .viz-ui { display: flex; flex-direction: column; justify-content: center; padding: 22px; }
  .ui-ln { display: block; height: 9px; border-radius: 6px; background: #e2e8f0; margin-bottom: 11px; }
  .ui-btn { align-self: flex-start; margin-top: 6px; padding: 8px 16px; border-radius: 9px; background: #0f172a; color: #fff; font-size: 12px; font-weight: 700; }
</style>
