---
const DI = 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons'
const SI = 'https://cdn.jsdelivr.net/npm/simple-icons@v13/icons'
const AILOGO = 'https://www.biztechcs.com/wp-content/uploads/2025/09'
// orbiting capability nodes — what Biztech actually engineers (8 around the core, 45° apart)
const CAPS = [
  { label: 'AI / ML', logo: `${SI}/openai.svg`, angle: -90 },
  { label: 'ERP', logo: `${SI}/odoo.svg`, angle: -45 },
  { label: 'Ecommerce', logo: `${DI}/magento/magento-original.svg`, angle: 0 },
  { label: 'Frontend', logo: `${DI}/react/react-original.svg`, angle: 45 },
  { label: 'Cloud', logo: `${DI}/amazonwebservices/amazonwebservices-original-wordmark.svg`, angle: 90 },
  { label: 'Mobile', logo: `${DI}/flutter/flutter-original.svg`, angle: 135 },
  { label: 'CRM', logo: `${DI}/salesforce/salesforce-original.svg`, angle: 180 },
  { label: 'API', logo: `${DI}/graphql/graphql-plain.svg`, angle: 225 },
]
const CDN = 'https://www.biztechcs.com/wp-content/uploads'
// compact in-hero proof: a few recognizable client logos + key certifications
const CLIENTS = [
  ['Forbes Marshall', `${CDN}/2023/05/forbes-marshall.png`],
  ['Bonfiglioli', `${CDN}/2023/05/bonfiglioli.png`],
  ['Ovivo', `${CDN}/2023/05/Ovivo.svg`],
  ['Biorbyt', `${CDN}/2023/05/Biorbyt.svg`],
  ['Medguard', `${CDN}/2023/05/medguard.png`],
]
---
<section class="hero light" id="hero-sec">
  <span class="hero-grid"></span>
  <span class="hero-grain"></span>
  <div class="wrap hero-split">
    <!-- LEFT — editorial headline -->
    <div class="hero-copy">
      <span class="hero-pill"><span class="pdot"></span> Since 2006 <b>·</b> AI-Powered</span>

      <h1 class="display hero-h1">
        <span class="line"><span class="ln">Engineer the</span></span>
        <span class="line"><span class="ln"><span class="out">AI-powered</span></span></span>
        <span class="line"><span class="ln">software your</span></span>
        <span class="line"><span class="ln"><span class="tl">business runs on.</span></span></span>
      </h1>

      <p class="hero-intro">Custom enterprise software development — from <b>AI agents to ERP, ecommerce to cloud</b>. One senior team with US &amp; EU project leads, full accountability, and IP you fully own.</p>

      <div class="hero-cta-row">
        <a class="btn-labs" href="#cta">
          <span class="lbl"><span class="roll">
            <span class="top">{[...'Book a 30-min call'].map((c, i) => <span style={`--i:${i}`}>{c}</span>)}</span>
            <span class="bot">{[...'Book a 30-min call'].map((c, i) => <span style={`--i:${i}`}>{c}</span>)}</span>
          </span></span><span class="arrow"><i class="fi fi-rr-arrow-right"></i></span>
        </a>
        <a class="btn-labs ghost" href="#work">
          <span class="lbl"><span class="roll">
            <span class="top">{[...'See our work'].map((c, i) => <span style={`--i:${i}`}>{c}</span>)}</span>
            <span class="bot">{[...'See our work'].map((c, i) => <span style={`--i:${i}`}>{c}</span>)}</span>
          </span></span><span class="arrow"><i class="fi fi-rr-arrow-right"></i></span>
        </a>
      </div>

      <div class="hero-proof">
        <div class="hp-row hp-clients">
          <span class="hp-label">Trusted by <b>200+</b> companies</span>
          <ul class="hp-logos">
            {CLIENTS.map(([name, src]) => (
              <li><img src={src} alt={name} loading="lazy" /></li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- RIGHT — capability orbit + stat strip -->
    <div class="hero-right">
      <div class="hero-parallax-a">
        <div class="orbit" role="img" aria-label="The software Biztech engineers — AI, ERP, ecommerce, cloud and mobile">
          <span class="orbit-glow"></span>
          <span class="orbit-ring r1"></span>
          <span class="orbit-ring r2"></span>

          <!-- centre: Biztech mark -->
          <div class="orbit-core">
            <img src={`${import.meta.env.BASE_URL}/assets/biztech-icon.svg`} alt="Biztech" />
          </div>

          <!-- orbiting capability nodes (icon only) -->
          {CAPS.map((c, i) => (
            <div class={`orbit-node n${i + 1}`} style={`--a:${c.angle}deg`}>
              <div class="orbit-chip" title={c.label}>
                <img src={c.logo} alt={c.label} loading="lazy" />
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="hero-strip hero-parallax-b">
        <div class="hs"><b><span data-count="1200">0</span>+</b><span>Projects delivered</span></div>
        <div class="hs"><b><span data-count="98">0</span>%</b><span>Client retention</span></div>
        <div class="hs"><b><span data-count="80">0</span>%</b><span>Senior engineers</span></div>
      </div>

      <div class="hp-reviews hero-parallax-b">
        <a class="rcard" href="#work" aria-label="Rated 4.9 out of 5 on Clutch from 26 reviews">
          <span class="rcard-ic"><img src={`${import.meta.env.BASE_URL}/assets/badges/clutch-mark.png`} alt="" width="26" height="26" /></span>
          <span class="rcard-body">
            <span class="rcard-top"><b>4.9</b><span class="rcard-max">/5</span>
              <span class="rcard-stars" aria-hidden="true"><i class="fi fi-sr-star"></i><i class="fi fi-sr-star"></i><i class="fi fi-sr-star"></i><i class="fi fi-sr-star"></i><i class="fi fi-sr-star"></i></span>
            </span>
            <span class="rcard-sub">Clutch · 26 reviews</span>
          </span>
        </a>
        <a class="rcard" href="#work" aria-label="Rated 4.8 out of 5 on Google from 80+ reviews">
          <span class="rcard-ic"><svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path fill="#4285F4" d="M23.5 12.27c0-.79-.07-1.54-.2-2.27H12v4.51h6.47a5.53 5.53 0 0 1-2.4 3.58v3h3.86c2.26-2.09 3.57-5.17 3.57-8.82z"/><path fill="#34A853" d="M12 24c3.24 0 5.95-1.08 7.93-2.91l-3.86-3c-1.08.72-2.45 1.16-4.07 1.16-3.13 0-5.78-2.11-6.73-4.96H1.29v3.09A12 12 0 0 0 12 24z"/><path fill="#FBBC05" d="M5.27 14.29a7.2 7.2 0 0 1 0-4.58V6.62H1.29a12 12 0 0 0 0 10.76l3.98-3.09z"/><path fill="#EA4335" d="M12 4.75c1.77 0 3.35.61 4.6 1.8l3.42-3.42A11.96 11.96 0 0 0 12 0 12 12 0 0 0 1.29 6.62l3.98 3.09C6.22 6.86 8.87 4.75 12 4.75z"/></svg></span>
          <span class="rcard-body">
            <span class="rcard-top"><b>4.8</b><span class="rcard-max">/5</span>
              <span class="rcard-stars" aria-hidden="true"><i class="fi fi-sr-star"></i><i class="fi fi-sr-star"></i><i class="fi fi-sr-star"></i><i class="fi fi-sr-star"></i><i class="fi fi-sr-star"></i></span>
            </span>
            <span class="rcard-sub">Google · 80+ reviews</span>
          </span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  /* entrance (replaces framer-motion) */
  @media (prefers-reduced-motion: no-preference) {
    .hero-pill { opacity: 0; animation: hFade 0.7s cubic-bezier(0.16,1,0.3,1) 0.05s both; }
    .hero-h1 .ln { display: block; transform: translateY(110%); animation: hLine 0.95s cubic-bezier(0.16,1,0.3,1) both; }
    .hero-h1 .line:nth-child(1) .ln { animation-delay: 0.1s; }
    .hero-h1 .line:nth-child(2) .ln { animation-delay: 0.15s; }
    .hero-h1 .line:nth-child(3) .ln { animation-delay: 0.22s; }
    .hero-h1 .line:nth-child(4) .ln { animation-delay: 0.29s; }
    .hero-intro { opacity: 0; animation: hFade 0.7s cubic-bezier(0.16,1,0.3,1) 0.42s both; }
    .hero-cta-row { opacity: 0; animation: hFade 0.7s cubic-bezier(0.16,1,0.3,1) 0.52s both; }
    .hero-proof { opacity: 0; animation: hFade 0.7s cubic-bezier(0.16,1,0.3,1) 0.6s both; }
    .hero-right { opacity: 0; animation: hFade 0.7s cubic-bezier(0.16,1,0.3,1) 0.55s both; }
  }

  /* compact in-hero proof (client logos + certifications) */
  .hero-proof { margin-top: clamp(26px, 3vw, 36px); display: flex; flex-direction: column; gap: 16px; max-width: 580px; }
  .hp-row { display: flex; flex-direction: column; gap: 11px; }
  .hp-label { display: inline-flex; align-items: center; gap: 7px; font-family: var(--font-mono); font-size: 10px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--muted); }
  .hp-label b { color: var(--ink); font-weight: 700; }
  .hp-label i { color: var(--teal); line-height: 0; font-size: 12px; }
  .hp-logos { display: flex; align-items: center; flex-wrap: wrap; list-style: none; padding: 0; margin: 0; gap: 14px 26px; }
  .hp-logos li { display: inline-flex; align-items: center; }
  .hp-logos img { height: 24px; width: auto; max-width: 96px; object-fit: contain; filter: grayscale(1); opacity: 0.58; transition: filter 0.3s, opacity 0.3s; }
  .hp-logos li:hover img { filter: grayscale(0); opacity: 1; }

  /* review rating cards (Clutch / Google) — under the stat strip, right column */
  .hp-reviews { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .rcard { display: flex; align-items: center; gap: 12px; padding: 12px 14px; border-radius: 14px;
    background: #fff; border: 1px solid var(--line);
    box-shadow: 0 10px 30px -22px rgba(35,38,46,.3);
    transition: border-color .3s, transform .3s cubic-bezier(.16,1,.3,1), box-shadow .3s; }
  .rcard:hover { transform: translateY(-3px); border-color: rgba(14,165,233,.45); box-shadow: 0 18px 40px -22px rgba(14,165,233,.32); }
  .rcard-ic { flex: none; display: grid; place-items: center; width: 38px; height: 38px; border-radius: 11px; line-height: 0;
    background: #f8fafc; border: 1px solid var(--line); }
  .rcard-ic svg, .rcard-ic img { display: block; object-fit: contain; }
  .rcard-body { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
  .rcard-top { display: flex; align-items: baseline; gap: 4px; line-height: 1; }
  .rcard-top b { font-size: 20px; font-weight: 900; letter-spacing: -0.03em; color: var(--ink); }
  .rcard-max { font-size: 12px; font-weight: 700; color: var(--muted); }
  .rcard-stars { display: inline-flex; gap: 1px; margin-left: 5px; color: #f6a609; font-size: 11px; line-height: 0; align-self: center; }
  .rcard-stars i { line-height: 0; }
  .rcard-sub { font-size: 12px; font-weight: 600; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .rcard:hover .rcard-sub { color: var(--ink); }
  @media (max-width: 1100px) { .hp-reviews { grid-template-columns: 1fr; } }

  @media (max-width: 900px) { .hero-proof { margin-left: auto; margin-right: auto; } .hp-logos, .hp-reviews { justify-content: center; } .hp-label { justify-content: center; } }
  @media (prefers-reduced-motion: reduce) { .hp-logos img { transition: none; } }
  @keyframes hFade { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: none; } }
  @keyframes hLine { to { transform: translateY(0); } }

  /* ===== Capability orbit (replaces the chat panel) ===== */
  .orbit { position: relative; width: min(440px, 100%); aspect-ratio: 1; margin-inline: auto; }
  .orbit-glow { position: absolute; inset: 8%; border-radius: 50%;
    background: radial-gradient(circle, rgba(14,165,233,.22), transparent 68%); filter: blur(6px); }
  .orbit-ring { position: absolute; border-radius: 50%; border: 1px solid rgba(14,165,233,.2); }
  .orbit-ring.r1 { inset: 12%; }
  .orbit-ring.r2 { inset: 27%; border-style: dashed; border-color: rgba(14,165,233,.16); }

  .orbit-core { position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);
    width: 33%; aspect-ratio: 1; border-radius: 30px; display: grid; place-items: center; gap: 5px;
    background: #fff; border: 1px solid var(--line);
    box-shadow: 0 30px 70px -34px rgba(14,165,233,.5); z-index: 3; }
  .orbit-core img { width: 56%; height: auto; }

  /* each node sits at angle --a on the ring; --r is the orbit radius (px, not %) */
  .orbit { --r: 165px; }
  @media (max-width: 1100px) { .orbit { --r: 38vw; } }
  @media (max-width: 760px) { .orbit { --r: 140px; } }
  .orbit-node { position: absolute; left: 50%; top: 50%; width: 0; height: 0;
    transform: rotate(var(--a)) translateX(var(--r)) rotate(calc(-1 * var(--a)));
    z-index: 2; }
  /* clean icon-only box, logo clearly visible */
  .orbit-chip { display: grid; place-items: center;
    transform: translate(-50%, -50%);
    width: 66px; height: 66px; border-radius: 20px; background: #fff; border: 1px solid var(--line);
    box-shadow: 0 16px 40px -22px rgba(35,38,46,.45); }
  .orbit-chip img { width: 38px; height: 38px; object-fit: contain; }

  /* slow rotation of the whole constellation; chips counter-rotate to stay upright */
  @media (prefers-reduced-motion: no-preference) {
    .orbit-node { animation: orbitSpin 40s linear infinite; }
    .orbit-chip { animation: orbitSpinRev 40s linear infinite; }
  }
  @keyframes orbitSpin {
    to { transform: rotate(calc(var(--a) + 360deg)) translateX(var(--r)) rotate(calc(-1 * var(--a) - 360deg)); }
  }
  @keyframes orbitSpinRev { to { transform: translate(-50%, -50%) rotate(0deg); } }
</style>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
  const hero = document.querySelector('#hero-sec')
  if (hero) {
    /* ---- count-up stats ---- */
    const easeOut = (t) => 1 - Math.pow(1 - t, 3)
    const countUp = (el) => {
      const target = Number(el.dataset.count)
      if (reduce) { el.textContent = String(target); return }
      const dur = 1600, start = performance.now()
      const f = (now) => {
        const p = Math.min(1, (now - start) / dur)
        el.textContent = String(Math.round(easeOut(p) * target))
        if (p < 1) requestAnimationFrame(f)
      }
      requestAnimationFrame(f)
    }
    const cio = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { countUp(e.target); cio.unobserve(e.target) } })
    }, { threshold: 0.6 })
    hero.querySelectorAll('[data-count]').forEach((el) => cio.observe(el))

    /* ---- parallax ---- */
    if (!reduce) {
      const copy = hero.querySelector('.hero-copy')
      const pa = hero.querySelector('.hero-parallax-a')
      const pb = hero.querySelector('.hero-parallax-b')
      const grid = hero.querySelector('.hero-grid')
      let ticking = false
      const onScroll = () => {
        if (ticking) return
        ticking = true
        requestAnimationFrame(() => {
          const p = Math.min(1, Math.max(0, window.scrollY / (hero.offsetHeight || 1)))
          if (copy) copy.style.transform = `translateY(${p * 60}px)`
          if (pa) pa.style.transform = `translateY(${p * -50}px)`
          if (pb) pb.style.transform = `translateY(${p * -64}px)`
          if (grid) { grid.style.transform = `scale(${1 + p * 0.25})`; grid.style.opacity = String(1 - p * 0.6) }
          ticking = false
        })
      }
      window.addEventListener('scroll', onScroll, { passive: true })
      onScroll()
    }
  }
</script>
