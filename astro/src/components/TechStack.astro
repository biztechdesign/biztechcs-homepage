  ] },
  { cat: 'Tools', items: [
    { n: 'Git', logo: `${DI}/git/git-original.svg` },
    { n: 'GitHub', logo: `${SI}/github.svg` },
    { n: 'Jira', logo: `${DI}/jira/jira-original.svg` },
    { n: 'Bitbucket', logo: `${DI}/bitbucket/bitbucket-original.svg` },
    { n: 'Slack', logo: `${DI}/slack/slack-original.svg` },
  ] },
]
// flatten into one wall, de-duped, each item tagged with its category for filtering
const seen = new Set()
const ALL = STACK.flatMap((s) => s.items.map((it) => ({ ...it, cat: s.cat }))).filter((t) => {
  if (seen.has(t.n)) return false
  seen.add(t.n)
  return true
})
const total = ALL.length
const slug = (c) => c.toLowerCase().replace(/[^a-z0-9]+/g, '-')
---
<section id="tech" class="py-[var(--section-y)]">
  <div class="wrap">
    <div class="flex flex-wrap items-end justify-between gap-7 mb-[clamp(28px,3vw,40px)]">
      <div class="max-w-[640px]">
        <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk">
          <i class="fi fi-rr-apps text-teal"></i> Technologies
        </span>
        <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(30px,4vw,52px)] font-black tracking-[-0.04em] leading-[1.04]">
          The <span class="accent">technology stack</span> behind your software.
        </h2>
      </div>
      <p data-reveal style="--d:.12s" class="text-[14px] font-semibold text-muted whitespace-nowrap">
        <span class="text-ink font-black text-[18px]">{total}+</span> technologies · {STACK.length} domains
      </p>
    </div>

    <!-- category filter chips (top) -->
    <div data-reveal class="tech-filters flex flex-wrap gap-2.5 mb-[clamp(28px,3vw,40px)]" data-tech-filters>
      {STACK.map((s, i) => (
        <button class:list={["tfilter", i === 0 && "is-active"]} data-cat={slug(s.cat)}>{s.cat}</button>
      ))}
    </div>

    <!-- one compact wall -->
    <div data-reveal class="tech-wall grid gap-x-[clamp(16px,2.4vw,32px)] gap-y-7 has-filter" data-tech-wall>
      {ALL.filter((t) => t.logo).map((t) => (
        <div class="titem tlogo group flex flex-col items-center gap-2" data-cat={slug(t.cat)}>
          <img src={t.logo} alt={t.n} title={t.n} loading="lazy" class="logo-img h-[clamp(56px,6vw,72px)] w-auto max-w-[88px] object-contain" />
          <span class="tname text-[10.5px] font-semibold text-muted leading-none text-center transition-colors duration-300 group-hover:text-ink">{t.n}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .accent { background: linear-gradient(100deg, #0ea5e9, #0369a1); -webkit-background-clip: text; background-clip: text; color: transparent; }

  .tech-wall { grid-template-columns: repeat(10, minmax(0, 1fr)); }
  @media (max-width: 1100px) { .tech-wall { grid-template-columns: repeat(7, minmax(0, 1fr)); } }
  @media (max-width: 760px) { .tech-wall { grid-template-columns: repeat(5, minmax(0, 1fr)); } }
  @media (max-width: 480px) { .tech-wall { grid-template-columns: repeat(4, minmax(0, 1fr)); } }

  .logo-img { opacity: 0.85; transition: opacity 0.3s ease, transform 0.3s ease; }
  .tlogo:hover .logo-img { opacity: 1; transform: translateY(-4px); }
  @media (prefers-reduced-motion: reduce) { .logo-img { transition: none; } .tlogo:hover .logo-img { transform: none; } }
</style>

<script>
  const sec = document.querySelector('#tech')
  if (sec) {
    const wall = sec.querySelector('[data-tech-wall]')
    const filters = Array.from(sec.querySelectorAll('.tfilter'))
    const items = Array.from(sec.querySelectorAll('.titem'))
    const active = filters.find((f) => f.classList.contains('is-active'))
    let locked = active ? active.dataset.cat : 'all' // clicked category (defaults to first category)

    const apply = (cat) => {
      if (cat === 'all') {
        wall.classList.remove('has-filter')
        items.forEach((it) => it.classList.remove('match'))
        return
      }
      wall.classList.add('has-filter')
      items.forEach((it) => it.classList.toggle('match', it.dataset.cat === cat))
    }

    filters.forEach((f) => {
      // click locks the filter
      f.addEventListener('click', () => {
        locked = f.dataset.cat
        filters.forEach((x) => x.classList.toggle('is-active', x === f))
        apply(locked)
      })
      // hover previews (only when not overriding a lock to 'all')
      f.addEventListener('mouseenter', () => { if (f.dataset.cat !== 'all') apply(f.dataset.cat) })
      f.addEventListener('mouseleave', () => apply(locked))
    })

    apply(locked)
  }
</script>
