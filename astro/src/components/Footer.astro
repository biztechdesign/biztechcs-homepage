---
const BASE = import.meta.env.BASE_URL
const SITE = 'https://www.biztechcs.com'
const COMPANY = [
  ['About Us', `${BASE}/company`], ['Our Ventures', `${BASE}/company#ventures`], ['Our Team', `${BASE}/leadership`], ['Partnerships', `${BASE}/contact`],
  ['Our Engagement Model', `${BASE}/why-biztechcs#approach`], ['Success Stories', `${BASE}/case-studies`], ['Career', `${BASE}/careers`], ['Contact Us', `${BASE}/contact`],
]
const SERVICES = [
  ['Software Product Engineering', `${BASE}/contact`], ['Application Development', `${BASE}/contact`], ['Ecommerce Development', `${BASE}/contact`],
  ['AI/ML Development', `${BASE}/services/ai-ml-development`], ['DevOps Automation', `${BASE}/contact`], ['Odoo Development', `${BASE}/contact`],
  ['ERP Services', `${BASE}/contact`], ['CRM Services', `${BASE}/contact`],
]
const SOLUTIONS = [
  ['Web To Print', `${BASE}/industries/printing`], ['Portal', `${BASE}/contact`],
]
const HIRE = [
  ['Hire Magento Developers', `${BASE}/contact`], ['Hire Shopify Developers', `${BASE}/contact`], ['Hire Javascript Developers', `${BASE}/contact`],
  ['Hire iOS App Developers', `${BASE}/contact`], ['Hire Android Developers', `${BASE}/contact`], ['Hire Flutter Developers', `${BASE}/contact`],
  ['Hire ReactJS Developers', `${BASE}/contact`], ['Hire AngularJS Developers', `${BASE}/contact`], ['Hire Vue.JS Developers', `${BASE}/contact`],
  ['Hire Node.JS Developer', `${BASE}/contact`], ['Hire Laravel Developers', `${BASE}/contact`], ['Hire .Net Developers', `${BASE}/contact`],
  ['Hire PHP Developers', `${BASE}/contact`], ['Hire CakePHP developers', `${BASE}/contact`], ['Hire Salesforce Developers', `${BASE}/contact`],
  ['Hire Odoo Developers', `${BASE}/contact`],
]
const LEGAL = [
  ['Disclaimer', `${SITE}/disclaimer/`], ['Intermediary Compliance', `${SITE}/intermediary-compliance/`], ['Terms of Use', `${SITE}/terms-of-use/`], ['Privacy Policy', `${SITE}/privacy-policy/`],
]
---
<footer class="site-footer">
  <div class="wrap">
    <div class="foot-top">
      <div class="foot-cols">
        <div><h4>Company</h4><ul>{COMPANY.map(([t, h]) => <li><a href={h}>{t}</a></li>)}</ul></div>
        <div><h4>Services</h4><ul>{SERVICES.map(([t, h]) => <li><a href={h}>{t}</a></li>)}</ul></div>
        <div>
          <h4>Solutions</h4><ul>{SOLUTIONS.map(([t, h]) => <li><a href={h}>{t}</a></li>)}</ul>
        </div>
        <div class="foot-hire"><h4>Hire Developers</h4><ul>{HIRE.map(([t, h]) => <li><a href={h}>{t}</a></li>)}</ul></div>
      </div>
    </div>

    <div class="foot-bottom">
      <div>© Copyright 2006-2026. Biztech® IT Consultancy Pvt. Ltd.</div>
      <div class="foot-legal">{LEGAL.map(([t, h]) => <a href={h}>{t}</a>)}</div>
    </div>

    <!-- big centered wordmark -->
    <div class="foot-bigmark">
      <img src={`${import.meta.env.BASE_URL}/assets/biztech-tagline-white.svg`} alt="BiztechCS" />
    </div>
  </div>
</footer>
<style>
  .foot-cols { display: grid; grid-template-columns: 1fr 1fr 1fr 1.6fr; gap: 40px; }
  @media (max-width: 1024px) { .foot-cols { grid-template-columns: 1fr 1fr; gap: 32px 28px; } }
  @media (max-width: 520px) { .foot-cols { grid-template-columns: 1fr; } }

  .foot-bigmark { margin-top: clamp(24px, 3vw, 36px); display: flex; justify-content: center; }
  .foot-bigmark img { height: clamp(35px, 6.5vw, 75px); width: auto; opacity: .95; }
  /* Hire Developers has 16 links — split into two columns so it doesn't run tall */
  .foot-hire ul { display: grid; grid-template-columns: 1fr 1fr; gap: 18px 22px; }
  .foot-hire li { margin-bottom: 0; }
  @media (max-width: 1024px) { .foot-hire { grid-column: 1 / -1; } }
  @media (max-width: 520px) { .foot-hire ul { grid-template-columns: 1fr; } }
  .foot-legal { display: flex; flex-wrap: wrap; }
</style>
