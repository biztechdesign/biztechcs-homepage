---
const BASE = import.meta.env.BASE_URL
const COMPANY = [
  ['About Us', '#about'], ['Our Ventures', '#'], ['Our Team', '#about'], ['Partnerships', '#'],
  ['Our Engagement Model', '#engagement'], ['Success Stories', '#work'], ['Career', `${BASE}/careers`], ['Contact Us', '#cta'],
]
const SERVICES = [
  ['Software Product Engineering', '#services'], ['Application Development', '#services'], ['Ecommerce Development', '#services'],
  ['AI/ML Development', `${BASE}/services/ai-ml-development`], ['DevOps Automation', '#services'], ['Odoo Development', '#services'],
  ['ERP Services', '#services'], ['CRM Services', '#services'],
]
const SOLUTIONS = [
  ['Web To Print', `${BASE}/industries/printing`], ['Portal', '#services'],
]
const HIRE = [
  ['Hire Magento Developers', '#'], ['Hire Shopify Developers', '#'], ['Hire Javascript Developers', '#'],
  ['Hire iOS App Developers', '#'], ['Hire Android Developers', '#'], ['Hire Flutter Developers', '#'],
  ['Hire ReactJS Developers', '#'], ['Hire AngularJS Developers', '#'], ['Hire Vue.JS Developers', '#'],
  ['Hire Node.JS Developer', '#'], ['Hire Laravel Developers', '#'], ['Hire .Net Developers', '#'],
  ['Hire PHP Developers', '#'], ['Hire CakePHP developers', '#'], ['Hire Salesforce Developers', '#'],
  ['Hire Odoo Developers', '#'],
]
const LEGAL = [
  ['Disclaimer', '#'], ['Intermediary Compliance', '#'], ['Terms of Use', '#'], ['Privacy Policy', '#'],
]
---
<footer class="site-footer">
  <div class="wrap">
    <div class="foot-top">
      <div class="foot-cols">
        <div><h4>Company</h4><ul>{COMPANY.map(([t, h]) => <li><a href={h}>{t}</a></li>)}</ul></div>
        <div><h4>Services</h4><ul>{SERVICES.map(([t, h]) => <li><a href={h}>{t}</a></li>)}</ul></div>
        <div>
          <h4>Solutions</h4><ul>{SOLUTIONS.map(([t, h]) => <li><a href={h}>{t}</a></li>)}</ul>
        </div>
        <div class="foot-hire"><h4>Hire Developers</h4><ul>{HIRE.map(([t, h]) => <li><a href={h}>{t}</a></li>)}</ul></div>
      </div>
    </div>

    <div class="foot-bottom">
      <div>© Copyright 2006-2026. Biztech® IT Consultancy Pvt. Ltd.</div>
      <div class="foot-legal">{LEGAL.map(([t, h]) => <a href={h}>{t}</a>)}</div>
    </div>

    <!-- big centered wordmark -->
    <div class="foot-bigmark">
      <img src={`${import.meta.env.BASE_URL}/assets/biztech-tagline-white.svg`} alt="BiztechCS" />
    </div>
  </div>
</footer>
<style>
  .foot-cols { display: grid; grid-template-columns: 1fr 1fr 1fr 1.6fr; gap: 40px; }
  @media (max-width: 1024px) { .foot-cols { grid-template-columns: 1fr 1fr; gap: 32px 28px; } }
  @media (max-width: 520px) { .foot-cols { grid-template-columns: 1fr; } }

  .foot-bigmark { margin-top: clamp(24px, 3vw, 36px); display: flex; justify-content: center; }
  .foot-bigmark img { height: clamp(35px, 6.5vw, 75px); width: auto; opacity: .95; }
  /* Hire Developers has 16 links — split into two columns so it doesn't run tall */
  .foot-hire ul { display: grid; grid-template-columns: 1fr 1fr; gap: 18px 22px; }
  .foot-hire li { margin-bottom: 0; }
  @media (max-width: 1024px) { .foot-hire { grid-column: 1 / -1; } }
  @media (max-width: 520px) { .foot-hire ul { grid-template-columns: 1fr; } }
  .foot-legal { display: flex; flex-wrap: wrap; }
</style>
