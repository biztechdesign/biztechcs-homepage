---
const POINTS = [
  { ic: 'fi-rr-time-fast', title: 'A 30-minute call, free', desc: 'Talk to a senior engineer — not a sales rep — about scope, approach and fit.' },
  { ic: 'fi-rr-shield-check', title: 'Your IP, fully protected', desc: 'Work-for-hire with full IP transfer on payment, backed by NDAs from day one.' },
  { ic: 'fi-rr-rocket-lunch', title: 'Start in 1–2 weeks', desc: 'Most engagements kick off within two weeks of the scoping call.' },
]
const ctaChars = [...'Book a 30-min call']
---
<section id="cta" class="py-[var(--section-y)]">
  <div class="wrap grid grid-cols-[0.95fr_1.05fr] gap-[clamp(40px,5vw,72px)] items-start max-[900px]:grid-cols-1">

    <!-- left: pitch + details -->
    <div>
      <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk">
        <i class="fi fi-rr-paper-plane text-teal"></i> Contact us
      </span>
      <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(32px,4.4vw,56px)] font-black tracking-[-0.04em] leading-[1.03]">
        Let's build <span class="accent">something real.</span>
      </h2>
      <p data-reveal style="--d:.12s" class="mt-5 text-muted text-[clamp(15px,1.2vw,17px)] leading-[1.6] max-w-[480px]">
        Book a free 30-minute call with a senior engineer — no sales pressure, just a clear plan for your project.
      </p>

      <div data-reveal style="--d:.18s" class="mt-9 flex flex-col gap-5">
        {POINTS.map((p) => (
          <div class="flex items-start gap-4">
            <span class="shrink-0 grid place-items-center w-11 h-11 rounded-xl bg-teal/10 border border-teal/20 text-teal text-[17px]"><i class={`fi ${p.ic}`}></i></span>
            <div class="pt-0.5">
              <b class="block text-[15.5px] font-extrabold text-ink leading-tight">{p.title}</b>
              <p class="mt-1 text-[14px] leading-[1.5] text-muted max-w-[420px]">{p.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <div data-reveal style="--d:.24s" class="mt-9 flex flex-wrap items-center gap-x-6 gap-y-2 text-[13px] font-bold text-ink">
        <span class="inline-flex items-center gap-1.5"><i class="fi fi-sr-star text-teal"></i> 4.9/5 on Clutch</span>
        <span class="w-px h-4 bg-line"></span>
        <span>ISO 27001 &amp; 9001 certified</span>
        <span class="w-px h-4 bg-line"></span>
        <span>1,200+ projects delivered</span>
      </div>
    </div>

    <!-- right: form -->
    <form data-reveal style="--d:.14s" class="cform rounded-3xl bg-white border border-line p-8 max-[680px]:p-6" action="mailto:sales@biztechcs.com" method="post" enctype="text/plain">
      <div class="grid grid-cols-2 gap-4 max-[520px]:grid-cols-1">
        <label class="block">
          <span class="block text-[13px] font-bold text-ink mb-1.5">Full name</span>
          <input name="name" type="text" required placeholder="Jane Doe" class="field" />
        </label>
        <label class="block">
          <span class="block text-[13px] font-bold text-ink mb-1.5">Work email</span>
          <input name="email" type="email" required placeholder="jane@company.com" class="field" />
        </label>
      </div>
      <label class="block mt-4">
        <span class="block text-[13px] font-bold text-ink mb-1.5">Company</span>
        <input name="company" type="text" placeholder="Company name" class="field" />
      </label>
      <label class="block mt-4">
        <span class="block text-[13px] font-bold text-ink mb-1.5">How can we help?</span>
        <textarea name="message" rows="4" required placeholder="Tell us about your project…" class="field resize-none"></textarea>
      </label>
      <button type="submit" class="btn-labs w-full justify-center mt-6">
        <span class="lbl"><span class="roll">
          <span class="top">{ctaChars.map((c, i) => <span style={`--i:${i}`}>{c}</span>)}</span>
          <span class="bot">{ctaChars.map((c, i) => <span style={`--i:${i}`}>{c}</span>)}</span>
        </span></span>
        <span class="arrow"><i class="fi fi-rr-arrow-right"></i></span>
      </button>
      <p class="mt-3 text-center text-[12.5px] text-muted">We reply within one business day. Your details stay private.</p>
    </form>
  </div>
</section>

<style>
  .accent { background: linear-gradient(100deg, #0ea5e9, #0369a1); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .cdetail { box-shadow: 0 8px 24px -18px rgba(35, 38, 46, 0.2); }
  .cform { box-shadow: 0 20px 56px -28px rgba(35, 38, 46, 0.3); }
  .field { width: 100%; border: 1px solid #e2e8f0; border-radius: 12px; background: #f8fafc; padding: 12px 14px; font-size: 15px; color: #0f172a; transition: border-color .25s, box-shadow .25s, background .25s; }
  .field::placeholder { color: #94a3b8; }
  .field:focus { outline: none; border-color: #0ea5e9; background: #fff; box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.15); }
</style>
