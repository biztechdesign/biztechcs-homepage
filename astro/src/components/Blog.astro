---
const CDN = 'https://www.biztechcs.com/wp-content/uploads/2026/06'
const POSTS = [
  { tag: 'AI & ML', read: '7 min read', title: 'How Custom AI/ML Development Services Help Businesses Scale Faster', excerpt: 'Where bespoke AI and machine-learning models deliver measurable scale — and how to pick the right problems to solve first.', img: `${CDN}/How-Custom-AIML-Development-Services-Help-Businesses-Banner-Image-scaled.png`, href: 'https://www.biztechcs.com/blog/ai-ml-development-services/' },
  { tag: 'ERP', read: '8 min read', title: 'Odoo ERP Customization: Top Industries Getting the Most Out of It', img: `${CDN}/Banner-Image-Odoo-ERP-Customization-By-Industry-1-scaled.png`, href: 'https://www.biztechcs.com/blog/odoo-erp-customization/' },
  { tag: 'Migration', read: '6 min read', title: 'Odoo Migration: How to Move Your ERP Data Without Losing a Single Record', img: `${CDN}/Three-stage-Odoo-migration-journey-scaled.webp`, href: 'https://www.biztechcs.com/blog/odoo-migration-services-without-losing-record/' },
]
---
<section id="resources" class="surface-tint py-[var(--section-y)]">
  <div class="wrap">
    <div class="flex flex-wrap items-end justify-between gap-9 mb-[clamp(40px,5vw,60px)]">
      <div>
        <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk">
          <i class="fi fi-rr-pen-nib text-teal"></i> Resources
        </span>
        <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(26px,3.4vw,52px)] font-black tracking-[-0.04em] leading-[1.04] whitespace-nowrap">
          Tech updates from <span class="accent">Team BiztechCS.</span>
        </h2>
      </div>
      <a data-reveal style="--d:.12s" href="https://www.biztechcs.com/blog/" target="_blank" rel="noopener" class="seeall inline-flex items-center gap-2 text-[14.5px] font-bold text-ink whitespace-nowrap">View all articles <i class="fi fi-rr-arrow-right"></i></a>
    </div>

    <div class="grid grid-cols-3 gap-[clamp(18px,2.4vw,28px)] items-stretch max-[860px]:grid-cols-1 max-[860px]:max-w-[560px] max-[860px]:mx-auto">
      {POSTS.map((p, i) => (
        <a href={p.href} target="_blank" rel="noopener" data-reveal style={`--d:${(0.1 + i * 0.08).toFixed(2)}s`} class="bfeat group flex flex-col rounded-3xl bg-white border border-line overflow-hidden no-underline text-inherit transition duration-300 hover:-translate-y-1.5 hover:border-teal/40">
          <div class="cover relative shrink-0 aspect-[3/2] overflow-hidden bg-paper-2">
            <img src={p.img} alt={p.title} loading="lazy" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            <span class="absolute left-4 bottom-4 text-[11px] font-extrabold uppercase tracking-[0.06em] text-teal-dk px-3 py-1.5 rounded-full bg-white/90 backdrop-blur-sm">{p.tag}</span>
          </div>
          <div class="flex flex-col flex-1 p-6 max-[680px]:p-5">
            <h3 class="bclamp-2 text-[17px] font-extrabold tracking-[-0.02em] leading-[1.35] text-ink">{p.title}</h3>
            <div class="mt-auto pt-5 flex items-center justify-between">
              <span class="inline-flex items-center gap-2 text-[12.5px] font-semibold text-muted"><i class="fi fi-rr-clock"></i> {p.read}</span>
              <span class="inline-flex items-center gap-2 text-[13px] font-bold text-teal-dk">Read now <i class="fi fi-rr-arrow-right transition-transform duration-300 group-hover:translate-x-1"></i></span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .accent { background: linear-gradient(100deg, #0ea5e9, #0369a1); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .seeall i { transition: transform .3s; line-height: 0; }
  .seeall:hover i { transform: translateX(4px); }
  .seeall:hover { color: #0369a1; }
  .bfeat { box-shadow: 0 10px 30px -20px rgba(35, 38, 46, 0.25); }
  .bfeat:hover { box-shadow: 0 26px 60px -26px rgba(14, 165, 233, 0.3); }
  .brow .text-line, .brow-all + * .text-line { color: #cbd5e1; }
  /* clamp titles & excerpt to 2 lines */
  .bclamp-2 { display: -webkit-box; -webkit-line-clamp: 2; line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>
