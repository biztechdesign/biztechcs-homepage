---
import CtaButton from './CtaButton.astro'
// Tier-2: AI-Native Engineering — the decade differentiator.
// Maps to Gartner 2026 trends (agentic AI, multi-agent systems, domain-specific LLMs).
// Dark band so it reads as a distinct "this is the future" statement.
const CAPS = [
  {
    ic: 'fi-rr-robot', title: 'AI Agents & Automation',
    desc: 'Autonomous agents that execute multi-step workflows — triaging, deciding and acting inside your systems, not just answering questions.',
    tag: 'Agentic AI',
  },
  {
    ic: 'fi-rr-share-square', title: 'Multi-Agent Systems',
    desc: 'Specialised agents that collaborate — one plans, one retrieves, one verifies — for complex tasks a single model can\'t reliably handle.',
    tag: 'Orchestration',
  },
  {
    ic: 'fi-rr-sparkles', title: 'GenAI → Production',
    desc: 'We take GenAI past the pilot: evaluations, guardrails, observability and cost controls that make it safe to ship to real users.',
    tag: 'Productionisation',
  },
  {
    ic: 'fi-rr-brain-circuit', title: 'Domain-Specific LLMs',
    desc: 'Models fine-tuned and RAG-grounded on your data and industry — higher accuracy, compliance and trust than a generic chatbot.',
    tag: 'Fine-tuning + RAG',
  },
]
const STACK = [
  'OpenAI', 'Claude', 'Gemini', 'Llama', 'Mistral', 'LangChain', 'LangGraph', 'LlamaIndex',
  'CrewAI', 'Pinecone', 'Weaviate', 'Qdrant', 'pgvector', 'Hugging Face', 'PyTorch', 'TensorFlow',
  'AWS Bedrock', 'Azure AI', 'Vertex AI', 'Ollama', 'vLLM', 'Triton', 'LangSmith', 'Ray',
]
// decorative AI sparkles scattered across the band — {x%, y%, size px, animation delay s, duration s}
const SPARKLES = [
  { x: 6, y: 18, s: 26, d: 0, t: 3.4 },
  { x: 17, y: 62, s: 16, d: 1.1, t: 4.2 },
  { x: 30, y: 30, s: 12, d: 2.0, t: 3.8 },
  { x: 44, y: 78, s: 20, d: .6, t: 4.6 },
  { x: 55, y: 14, s: 14, d: 1.6, t: 3.2 },
  { x: 67, y: 56, s: 22, d: .3, t: 4.0 },
  { x: 78, y: 24, s: 16, d: 2.3, t: 3.6 },
  { x: 88, y: 68, s: 28, d: 1.0, t: 4.4 },
  { x: 94, y: 38, s: 12, d: 1.8, t: 3.0 },
  { x: 38, y: 50, s: 10, d: 2.6, t: 4.8 },
  { x: 72, y: 84, s: 13, d: .9, t: 3.5 },
  { x: 22, y: 88, s: 18, d: 1.4, t: 4.1 },
]
---
<section id="ai-native" class="surface-dark py-[var(--section-y)]">
  <!-- decorative AI sparkle field (background) -->
  <div class="ai-sparkles" aria-hidden="true">
    {SPARKLES.map((sp) => (
      <svg class="ai-spark" viewBox="0 0 32 32" style={`left:${sp.x}%;top:${sp.y}%;width:${sp.s}px;height:${sp.s}px;--sd:${sp.d}s;--st:${sp.t}s`}>
        <path d="M16 2c1 7.6 3.4 10 11 11-7.6 1-10 3.4-11 11-1-7.6-3.4-10-11-11C12.6 12 15 9.6 16 2Z" />
      </svg>
    ))}
  </div>
  <div class="wrap">
    <!-- header -->
    <div class="flex flex-wrap items-end justify-between gap-9 mb-[clamp(36px,4vw,56px)]">
      <div class="max-w-[760px]">
        <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em]">
          <i class="fi fi-rr-microchip-ai"></i> AI-native engineering
        </span>
        <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(30px,4vw,52px)] font-black tracking-[-0.04em] leading-[1.04]">
          Beyond chatbots — <span class="accent-l">AI systems that do the work.</span>
        </h2>
        <p data-reveal style="--d:.12s" class="mt-5 text-[clamp(15px,1.2vw,17px)] leading-[1.6] text-white/65 max-w-[620px]">
          From GenAI pilots to production-grade autonomous agents. We design, evaluate and run AI you can actually trust in front of customers.
        </p>
      </div>
      <span data-reveal style="--d:.12s"><CtaButton href="#cta" label="Scope an AI build" variant="light" /></span>
    </div>

    <!-- capability cards -->
    <div class="grid grid-cols-4 gap-[16px] max-[1000px]:grid-cols-2 max-[560px]:grid-cols-1" id="aicGrid">
      {CAPS.map((c, i) => (
        <div data-reveal style={`--d:${(0.1 + i * 0.07).toFixed(2)}s`} class="aic group relative flex flex-col rounded-3xl p-7 overflow-hidden transition duration-300 hover:-translate-y-1.5">
          <span class="aic-spot" aria-hidden="true"></span>
          <span class="relative grid place-items-center w-[52px] h-[52px] rounded-2xl text-[22px] aic-ic">
            <i class={`fi ${c.ic}`}></i>
            <span class="aic-ic-ring" aria-hidden="true"></span>
          </span>
          <span class="relative mt-5 inline-flex self-start items-center rounded-full px-2.5 py-1 text-[10.5px] font-bold uppercase tracking-[0.06em] aic-tag">{c.tag}</span>
          <h3 class="relative mt-3 text-[18px] font-extrabold tracking-[-0.02em] text-white">{c.title}</h3>
          <p class="relative mt-2 text-[13.5px] leading-[1.55] text-white/60 flex-1">{c.desc}</p>
        </div>
      ))}
    </div>

    <!-- AI stack strip -->
    <div data-reveal style="--d:.34s" class="mt-[clamp(28px,3vw,40px)] flex flex-wrap items-center gap-x-5 gap-y-3">
      <span class="text-[11px] font-bold uppercase tracking-[0.14em] text-white/45 shrink-0">Built with</span>
      <ul class="flex flex-wrap items-center gap-2">
        {STACK.map((s) => (
          <li class="ai-chip">{s}</li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .accent-l { background: linear-gradient(100deg, #7dd3fc, #38bdf8); -webkit-background-clip: text; background-clip: text; color: transparent; }

  /* ===== background AI sparkle field ===== */
  #ai-native > .ai-sparkles { position: absolute; inset: 0; z-index: 0; pointer-events: none; overflow: hidden; }
  .ai-spark { position: absolute; transform: translate(-50%, -50%); opacity: .18; }
  .ai-spark path { fill: #7dd3fc; }
  @media (prefers-reduced-motion: no-preference) {
    .ai-spark { animation: aiTwinkle var(--st, 4s) ease-in-out var(--sd, 0s) infinite; }
  }
  @keyframes aiTwinkle {
    0%, 100% { opacity: .1; transform: translate(-50%, -50%) scale(.65) rotate(0deg); }
    50% { opacity: .5; transform: translate(-50%, -50%) scale(1) rotate(45deg); }
  }
  /* keep section content above the sparkles */
  #ai-native > .wrap { position: relative; z-index: 1; }

  .aic { background: rgba(255,255,255,.04); border: 1px solid rgba(125,211,252,.14);
    --mx: 50%; --my: 50%; transition: transform .3s cubic-bezier(.16,1,.3,1), border-color .3s, background .3s; }
  /* spotlight: a soft radial glow that follows the cursor (--mx/--my set by JS) */
  .aic-spot { position: absolute; inset: 0; pointer-events: none; opacity: 0; transition: opacity .35s;
    background: radial-gradient(280px circle at var(--mx) var(--my), rgba(56,189,248,.22), transparent 60%); }
  .aic:hover { border-color: rgba(125,211,252,.5); background: rgba(125,211,252,.06); }
  .aic:hover .aic-spot { opacity: 1; }
  /* bright reactive border that lights up near the cursor */
  .aic::after { content: ""; position: absolute; inset: 0; border-radius: inherit; padding: 1px; pointer-events: none;
    background: radial-gradient(220px circle at var(--mx) var(--my), rgba(125,211,252,.85), transparent 60%);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor; mask-composite: exclude;
    opacity: 0; transition: opacity .35s; }
  .aic:hover::after { opacity: 1; }

  .aic-ic { position: relative; background: rgba(125,211,252,.12); border: 1px solid rgba(125,211,252,.25); color: #7dd3fc;
    transition: background .3s, border-color .3s, color .3s, transform .3s cubic-bezier(.16,1,.3,1); }
  .aic-ic > i { position: relative; z-index: 1; display: flex; align-items: center; justify-content: center; line-height: 0; }
  .aic-ic > i::before { display: block; line-height: 1; }
  .aic:hover .aic-ic { background: #0ea5e9; border-color: transparent; color: #fff; transform: rotate(-6deg) scale(1.06); }

  /* ===== AI icon animation: a gentle pulsing ring that radiates from the icon ===== */
  .aic-ic-ring { position: absolute; inset: 0; border-radius: inherit; pointer-events: none;
    border: 1px solid rgba(125,211,252,.5); }
  @media (prefers-reduced-motion: no-preference) {
    .aic-ic-ring { animation: aiPulse 2.8s cubic-bezier(.16,1,.3,1) infinite; }
    .aic:hover .aic-ic-ring { animation-duration: 1.4s; }
    /* the glyph itself breathes + glows */
    .aic-ic > i { animation: aiGlow 3.2s ease-in-out infinite; }
    .aic .aic-ic { animation: aiFloat 4s ease-in-out infinite; }
    .aic:hover .aic-ic { animation-play-state: paused; }
  }
  @keyframes aiPulse {
    0% { transform: scale(1); opacity: .7; }
    70% { transform: scale(1.55); opacity: 0; }
    100% { transform: scale(1.55); opacity: 0; }
  }
  @keyframes aiGlow {
    0%, 100% { filter: drop-shadow(0 0 0 rgba(125,211,252,0)); }
    50% { filter: drop-shadow(0 0 6px rgba(125,211,252,.7)); }
  }
  @keyframes aiFloat { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-3px); } }

  .aic-tag { background: rgba(125,211,252,.1); border: 1px solid rgba(125,211,252,.22); color: #7dd3fc; }

  /* "Built with" tech chips */
  .ai-chip { display: inline-flex; align-items: center; padding: 5px 12px; border-radius: 999px;
    font-size: 12.5px; font-weight: 600; color: rgba(255,255,255,.72);
    background: rgba(255,255,255,.05); border: 1px solid rgba(125,211,252,.16);
    transition: color .25s, background .25s, border-color .25s, transform .25s cubic-bezier(.16,1,.3,1); }
  .ai-chip:hover { color: #fff; background: rgba(125,211,252,.14); border-color: rgba(125,211,252,.45); transform: translateY(-2px); }
</style>

<script>
  // spotlight glow: track cursor inside each AI card, feed --mx/--my to the radial gradients
  const grid = document.getElementById('aicGrid')
  if (grid && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    grid.querySelectorAll('.aic').forEach((card) => {
      card.addEventListener('pointermove', (e) => {
        const r = card.getBoundingClientRect()
        card.style.setProperty('--mx', `${e.clientX - r.left}px`)
        card.style.setProperty('--my', `${e.clientY - r.top}px`)
      })
    })
  }
</script>
