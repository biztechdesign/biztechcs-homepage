---
const U = 'https://www.biztechcs.com/wp-content/uploads'
const CASES = [
  { name: 'PaceX', tag: 'Mobility · Flutter', desc: 'A cross-platform driver rewards & engagement app, built end to end with Flutter and Laravel.', img: `${U}/2023/05/PaceX-jpg.webp` },
  { name: 'Seem', tag: 'Wellness · Flutter', desc: 'A consumer wellness app designed and shipped to the app stores from a single Flutter codebase.', img: `${U}/2023/05/seem-jpg.webp` },
  { name: 'Shhh', tag: 'Ecommerce · Shopify', desc: 'A conversion-focused Shopify storefront with a bespoke HTML5 front end and headless content.', img: `${U}/2022/09/shhhshop-jpg-webp.webp` },
]
---
<section id="work" class="py-[var(--section-y)]">
  <div class="wrap">
    <div class="flex flex-wrap items-end justify-between gap-9 mb-[clamp(40px,5vw,60px)]">
      <div>
        <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk">
          <i class="fi fi-rr-trophy text-teal"></i> Selected work
        </span>
        <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(30px,4vw,52px)] font-black tracking-[-0.04em] leading-[1.04] max-w-[720px]">
          A portfolio of <span class="accent">digital transformation.</span>
        </h2>
      </div>
      <a data-reveal style="--d:.12s" href="#cta" class="seeall inline-flex items-center gap-2 text-[14.5px] font-bold text-ink whitespace-nowrap">Start your project <i class="fi fi-rr-arrow-right"></i></a>
    </div>

    <div class="grid grid-cols-3 gap-[18px] max-[900px]:grid-cols-1 max-[900px]:max-w-[560px] max-[900px]:mx-auto">
      {CASES.map((c, i) => (
        <div data-reveal style={`--d:${(0.1 + i * 0.08).toFixed(2)}s`} class="cs-card group flex flex-col rounded-3xl bg-white border border-line overflow-hidden transition duration-300 hover:-translate-y-1.5">
          <div class="cover relative aspect-[16/10] overflow-hidden bg-paper-2">
            <img src={c.img} alt={c.name} loading="lazy" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.05]" />
            <span class="absolute left-4 top-4 text-[11px] font-extrabold uppercase tracking-[0.06em] text-teal-dk px-3 py-1.5 rounded-full bg-white/90 backdrop-blur-sm">{c.tag}</span>
          </div>
          <div class="flex flex-col flex-1 p-7">
            <h3 class="text-[21px] font-extrabold tracking-[-0.02em] text-ink">{c.name}</h3>
            <p class="mt-2 text-[14px] leading-[1.55] text-muted flex-1">{c.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .accent { background: linear-gradient(100deg, #0ea5e9, #0369a1); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .seeall i { transition: transform .3s; line-height: 0; }
  .seeall:hover i { transform: translateX(4px); }
  .seeall:hover { color: #0369a1; }
  .cs-card:hover { box-shadow: 0 18px 44px -26px rgba(15, 23, 42, 0.18); border-color: rgba(15, 23, 42, 0.16); }
</style>
