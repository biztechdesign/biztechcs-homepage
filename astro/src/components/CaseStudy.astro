---
const U = 'https://www.biztechcs.com/wp-content/uploads'
const CASES = [
  {
    client: 'PaceX',
    tag: 'Mobility · Cross-platform app',
    title: 'A driver rewards platform that scaled to thousands of trips a day.',
    poster: `${U}/2023/05/PaceX-jpg.webp`,
    challenge: 'PaceX needed a single rewards and engagement app for drivers across iOS and Android — fast to ship, cheap to maintain, and able to handle live trip data without lag.',
    solution: 'We built one Flutter codebase backed by a Laravel API, with a real-time rewards engine, secure payments and an admin console — shipped to both stores from a single team.',
    stack: ['Flutter', 'Laravel', 'MySQL', 'AWS'],
    metrics: [
      { n: '2', suffix: 'apps', label: 'iOS + Android, one codebase' },
      { n: '40', suffix: '%', label: 'Lower build & upkeep cost' },
      { n: '4.6', suffix: '★', label: 'Avg. app store rating' },
    ],
    quote: 'They shipped a polished cross-platform app faster than vendors quoting twice the budget — and owned the outcome end to end.',
    quoteBy: 'Product Lead, PaceX',
  },
  {
    client: 'Seem',
    tag: 'Wellness · Mobile app',
    title: 'A consumer wellness app shipped from a single Flutter codebase.',
    poster: `${U}/2023/05/seem-jpg.webp`,
    challenge: 'Seem wanted a polished wellness app on both platforms without doubling the budget, and needed it in users’ hands quickly to validate the product.',
    solution: 'A single Flutter build with a clean design system, smooth onboarding and store-ready release pipelines — one team covering design through deployment.',
    stack: ['Flutter', 'Firebase', 'REST API'],
    metrics: [
      { n: '1', suffix: 'team', label: 'Design to store, end to end' },
      { n: '2', suffix: 'stores', label: 'iOS + Android at launch' },
      { n: '50', suffix: '%', label: 'Faster than native parallel' },
    ],
    quote: 'One team took us from concept to both app stores without the usual hand-offs and delays.',
    quoteBy: 'Founder, Seem',
  },
  {
    client: 'Shhh',
    tag: 'Ecommerce · Shopify',
    title: 'A conversion-focused Shopify storefront with a bespoke front end.',
    poster: `${U}/2022/09/shhhshop-jpg-webp.webp`,
    challenge: 'Shhh needed a storefront that felt custom and converted well, without losing the reliability and ease of Shopify’s commerce backend.',
    solution: 'A bespoke HTML5 front end on Shopify with headless content, tuned product pages and a fast, mobile-first checkout flow built for conversion.',
    stack: ['Shopify', 'HTML5', 'Liquid', 'JavaScript'],
    metrics: [
      { n: '100', suffix: '%', label: 'Custom front-end build' },
      { n: '↑', suffix: '', label: 'Higher conversion focus' },
      { n: 'A+', suffix: '', label: 'Mobile-first performance' },
    ],
    quote: 'It looks nothing like a template, but runs on Shopify’s rails — exactly the balance we wanted.',
    quoteBy: 'Owner, Shhh',
  },
]
---
<section id="case-study" class="surface-dark py-[var(--section-y)]">
  <div class="wrap">
    <div class="flex flex-wrap items-end justify-between gap-6 mb-[clamp(32px,4vw,48px)]">
      <div class="max-w-[640px]">
        <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] eyebrow">
          <i class="fi fi-rr-document"></i> Featured case study
        </span>
        <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(26px,3.4vw,44px)] font-black tracking-[-0.04em] leading-[1.05] text-white">
          Deep dives into <span class="accent">shipped work.</span>
        </h2>
      </div>
      <!-- controls -->
      <div data-reveal style="--d:.12s" class="flex items-center gap-3">
        <span class="cs-counter text-[13px] font-bold text-white/55 tabular-nums"><b class="text-white" data-cs-current>1</b> / {CASES.length}</span>
        <button class="cs-arrow" data-cs-prev aria-label="Previous case study"><i class="fi fi-rr-arrow-left"></i></button>
        <button class="cs-arrow" data-cs-next aria-label="Next case study"><i class="fi fi-rr-arrow-right"></i></button>
      </div>
    </div>

    <!-- slides -->
    <div class="cs-track">
      {CASES.map((c, idx) => (
        <article class={`cs-slide ${idx === 0 ? 'is-active' : ''}`} data-cs-slide={idx}>
          <!-- left: visual + metrics -->
          <div class="flex flex-col gap-[16px]">
            <div class="cs-visual relative overflow-hidden rounded-3xl aspect-[16/11]">
              <img src={c.poster} alt={`${c.client} case study`} loading="lazy" class="absolute inset-0 w-full h-full object-cover" />
              <span class="cs-visual-shade absolute inset-0"></span>
              <span class="relative z-[1] flex h-full flex-col justify-between p-7">
                <span class="self-start text-[11px] font-extrabold uppercase tracking-[0.08em] text-white px-3 py-1.5 rounded-full bg-white/10 border border-white/20 backdrop-blur-sm">{c.tag}</span>
                <span class="text-[28px] font-black tracking-[-0.03em] text-white">{c.client}</span>
              </span>
            </div>
            <div class="grid grid-cols-3 gap-[12px] max-[520px]:grid-cols-1">
              {c.metrics.map((m) => (
                <div class="cs-metric rounded-2xl p-5">
                  <div class="text-[clamp(24px,3vw,32px)] font-black tracking-[-0.03em] cs-num leading-none">{m.n}<span class="text-[15px] align-top ml-0.5">{m.suffix}</span></div>
                  <p class="mt-2 text-[12px] leading-[1.4] text-white/60">{m.label}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- right: narrative -->
          <div class="cs-body flex flex-col rounded-3xl p-8 max-[980px]:p-7">
            <h3 class="text-[clamp(19px,1.8vw,23px)] font-extrabold tracking-[-0.02em] text-white leading-[1.2]">{c.title}</h3>
            <div class="mt-6">
              <span class="cs-step inline-flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-[0.1em] text-teal-300"><i class="fi fi-rr-bullseye-arrow"></i> The challenge</span>
              <p class="mt-2 text-[14px] leading-[1.55] text-white/85">{c.challenge}</p>
            </div>
            <div class="mt-5">
              <span class="cs-step inline-flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-[0.1em] text-teal-300"><i class="fi fi-rr-bulb"></i> What we built</span>
              <p class="mt-2 text-[14px] leading-[1.55] text-white/85">{c.solution}</p>
            </div>
            <div class="mt-5 flex flex-wrap gap-2">
              {c.stack.map((t) => (
                <span class="text-[12px] font-semibold text-white/80 px-3 py-1.5 rounded-lg bg-white/[0.06] border border-white/10">{t}</span>
              ))}
            </div>
            <div class="cs-quote mt-6 p-5 rounded-2xl">
              <i class="fi fi-rr-quote-right cs-quote-mark"></i>
              <p class="text-[14.5px] leading-[1.5] text-white font-medium">"{c.quote}"</p>
              <cite class="block mt-2.5 text-[12.5px] font-semibold text-white/55 not-italic">— {c.quoteBy}</cite>
            </div>
            <a href="#cta" class="cs-cta mt-6 inline-flex items-center gap-2 text-[14px] font-bold text-white group self-start">
              Start a project like this <i class="fi fi-rr-arrow-right transition-transform duration-300 group-hover:translate-x-1"></i>
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- dots -->
    <div class="mt-8 flex items-center justify-center gap-2">
      {CASES.map((_, idx) => (
        <button class={`cs-dot ${idx === 0 ? 'is-active' : ''}`} data-cs-dot={idx} aria-label={`Go to case study ${idx + 1}`}></button>
      ))}
    </div>
  </div>
</section>

<style>
  .eyebrow { color: #7dd3fc; }
  .eyebrow i { color: #38bdf8; }
  .accent { background: linear-gradient(100deg, #38bdf8, #818cf8); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .text-teal-300 { color: #7dd3fc; }

  /* only the active slide is shown; others collapse so there's no empty box.
     Grid layout lives here (not as Tailwind utilities) so display:none isn't overridden. */
  .cs-slide { display: none; }
  .cs-slide.is-active {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(20px, 2.6vw, 40px);
    align-items: start;
    animation: csFade .45s cubic-bezier(.16,1,.3,1);
  }
  @media (max-width: 980px) { .cs-slide.is-active { grid-template-columns: 1fr; } }
  @keyframes csFade { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }

  .cs-visual-shade { background: linear-gradient(160deg, rgba(11,18,32,.2) 0%, rgba(11,18,32,.35) 55%, rgba(11,18,32,.82) 100%); }
  .cs-metric { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1); }
  .cs-num { background: linear-gradient(160deg, #fff, #7dd3fc); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .cs-body { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.1); }
  .cs-quote { position: relative; background: rgba(56,189,248,.08); border: 1px solid rgba(56,189,248,.18); border-left: 3px solid #38bdf8; }
  .cs-quote-mark { position: absolute; top: 14px; right: 16px; color: rgba(56,189,248,.35); font-size: 22px; line-height: 0; }
  .cs-step i, .cs-cta i { line-height: 0; }
  .cs-cta:hover { color: #7dd3fc; }

  .cs-arrow {
    display: grid; place-items: center; width: 44px; height: 44px; border-radius: 999px;
    background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.18); color: #fff;
    cursor: pointer; transition: background .25s, border-color .25s, transform .25s;
  }
  .cs-arrow i { line-height: 0; font-size: 15px; }
  .cs-arrow:hover { background: var(--teal); border-color: transparent; transform: translateY(-2px); }

  .cs-dot { width: 8px; height: 8px; border-radius: 999px; border: 0; cursor: pointer;
    background: rgba(255,255,255,.22); transition: width .3s, background .3s; }
  .cs-dot.is-active { width: 26px; background: #38bdf8; }

  @media (prefers-reduced-motion: reduce) { .cs-slide.is-active { animation: none; } }
</style>

<script>
  const sec = document.querySelector('#case-study')
  if (sec) {
    const slides = Array.from(sec.querySelectorAll('.cs-slide'))
    const dots = Array.from(sec.querySelectorAll('.cs-dot'))
    const cur = sec.querySelector('[data-cs-current]')
    const N = slides.length
    let i = 0
    const go = (n) => {
      i = (n + N) % N
      slides.forEach((s, k) => s.classList.toggle('is-active', k === i))
      dots.forEach((d, k) => d.classList.toggle('is-active', k === i))
      if (cur) cur.textContent = String(i + 1)
    }
    sec.querySelector('[data-cs-next]')?.addEventListener('click', () => go(i + 1))
    sec.querySelector('[data-cs-prev]')?.addEventListener('click', () => go(i - 1))
    dots.forEach((d, k) => d.addEventListener('click', () => go(k)))
  }
</script>
