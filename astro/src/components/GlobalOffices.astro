---
<section id="offices" aria-label="Global offices" class="surface-tint">
  <div class="wrap go-inner">
    <div class="go-grid">
      <!-- left: contact + socials -->
      <div class="go-intro">
        <span class="go-eyebrow"><i class="fi fi-rr-globe"></i> Global Presence</span>
        <h3 class="go-title">Four offices.<br/>One team across time zones.</h3>

        <span class="go-label">Mail Us On</span>
        <div class="go-mails">
          <a href="mailto:sales@biztechcs.com" class="go-mail">
            <i class="fi fi-rr-envelope"></i><span>sales@biztechcs.com</span>
          </a>
          <a href="mailto:career@biztechcs.com" class="go-mail">
            <i class="fi fi-rr-briefcase"></i><span>career@biztechcs.com</span>
          </a>
        </div>

        <span class="go-label go-connect">Connect With Us</span>
        <div class="go-socials">
          {SOCIALS.map((s) => (
            <a href={s.href} target="_blank" rel="noopener" aria-label={s.label}>
              <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d={s.path} /></svg>
            </a>
          ))}
        </div>
      </div>

      <!-- country cards -->
      <div class="go-cards">
        {OFFICES.map((o, i) => (
          <article class="go-office" style={`--accent:${o.accent};--tint:${o.tint};--d:${i * 70}ms`}>
            <span class="go-bar" aria-hidden="true"></span>
            <i class={`fi ${o.landmark} go-watermark`} aria-hidden="true"></i>
            <div class="go-head">
              <span class="go-code">{o.code}</span>
              <b>{o.country}</b>
            </div>
            <address class="go-addr">
              {o.lines.map((l) => <span>{l}</span>)}
            </address>
            <span class="go-pin" aria-hidden="true"><i class="fi fi-rr-marker"></i></span>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  #offices { position: relative; z-index: 1; padding: clamp(48px, 6vw, 84px) 0; }
  .go-inner { position: relative; }
  .go-grid { display: grid; grid-template-columns: 1.05fr 2.2fr; gap: clamp(28px, 3.4vw, 56px); align-items: start; }
  @media (max-width: 960px) { .go-grid { grid-template-columns: 1fr; } }

  /* ---------- left intro ---------- */
  .go-intro { display: flex; flex-direction: column; }
  .go-eyebrow {
    display: inline-flex; align-items: center; gap: 8px; align-self: flex-start;
    font-family: var(--font-mono); font-size: 11px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase;
    padding: 7px 14px; border-radius: 999px; background: rgba(14,165,233,.08); border: 1px solid rgba(14,165,233,.22); color: var(--teal-dk);
  }
  .go-eyebrow i { line-height: 0; font-size: 13px; }
  .go-title { margin: 18px 0 30px; font-size: clamp(24px, 2.4vw, 34px); font-weight: 800; line-height: 1.18; letter-spacing: -.02em; color: var(--ink); }

  .go-label { font-size: 12px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); }
  .go-connect { margin-top: 26px; }

  .go-mails { margin-top: 14px; display: flex; flex-direction: column; gap: 10px; }
  .go-mail {
    display: inline-flex; align-items: center; gap: 12px; align-self: flex-start;
    font-size: clamp(15px, 1.3vw, 18px); font-weight: 700; color: var(--ink);
    transition: color .25s, transform .25s;
  }
  .go-mail i {
    display: grid; place-items: center; width: 38px; height: 38px; border-radius: 11px; flex: none;
    background: rgba(14,165,233,.1); color: var(--teal-dk); font-size: 15px; line-height: 0;
    transition: background .25s, color .25s, transform .35s cubic-bezier(.16,1,.3,1);
  }
  .go-mail:hover { color: var(--teal-dk); transform: translateX(4px); }
  .go-mail:hover i { background: var(--teal); color: #fff; transform: rotate(-8deg) scale(1.05); }

  .go-socials { margin-top: 14px; display: flex; gap: 10px; }
  .go-socials a {
    position: relative; display: grid; place-items: center; width: 40px; height: 40px; border-radius: 12px;
    background: var(--ink); color: #fff; font-size: 16px; overflow: hidden;
    transition: transform .3s cubic-bezier(.16,1,.3,1), box-shadow .3s;
  }
  .go-socials a::before {
    content: ""; position: absolute; inset: 0; background: linear-gradient(135deg, var(--teal), var(--teal-dk));
    opacity: 0; transition: opacity .3s;
  }
  .go-socials a > * { position: relative; z-index: 1; line-height: 0; }
  .go-socials a:hover { transform: translateY(-4px); box-shadow: 0 12px 22px -10px rgba(14,165,233,.6); }
  .go-socials a:hover::before { opacity: 1; }
  .go-socials svg { display: block; transition: transform .3s cubic-bezier(.16,1,.3,1); }
  .go-socials a:hover svg { transform: scale(1.1); }

  /* ---------- country cards ---------- */
  .go-cards { display: grid; grid-template-columns: repeat(2, 1fr); gap: clamp(14px, 1.5vw, 20px); }
  @media (max-width: 560px) { .go-cards { grid-template-columns: 1fr; } }

  .go-office {
    position: relative; overflow: hidden; isolation: isolate;
    padding: clamp(24px, 2.4vw, 32px); border-radius: 18px;
    background: #fff; border: 1px solid var(--line);
    transition: transform .4s cubic-bezier(.16,1,.3,1), box-shadow .4s, border-color .4s;
  }
  /* tint wash that fades in on hover */
  .go-office::before {
    content: ""; position: absolute; inset: 0; background: var(--tint); opacity: 0;
    transition: opacity .4s; z-index: -1;
  }
  .go-office:hover { transform: translateY(-6px); border-color: color-mix(in srgb, var(--accent) 35%, var(--line)); box-shadow: 0 24px 50px -28px color-mix(in srgb, var(--accent) 55%, rgba(15,23,42,.4)); }
  .go-office:hover::before { opacity: 1; }

  /* left accent bar grows on hover */
  .go-bar { position: absolute; left: 0; top: 18px; bottom: 18px; width: 4px; border-radius: 0 4px 4px 0; background: var(--accent); transform: scaleY(.32); transform-origin: center; transition: transform .4s cubic-bezier(.16,1,.3,1); }
  .go-office:hover .go-bar { transform: scaleY(1); }

  .go-watermark { position: absolute; right: -16px; bottom: -22px; font-size: 132px; line-height: 0; color: var(--ink); opacity: .04; pointer-events: none; transition: transform .5s cubic-bezier(.16,1,.3,1), opacity .4s, color .4s; }
  .go-office:hover .go-watermark { transform: translate(-6px, -6px) rotate(-6deg) scale(1.06); opacity: .1; color: var(--accent); }

  .go-head { position: relative; display: flex; align-items: center; gap: 12px; }
  .go-code {
    display: grid; place-items: center; min-width: 34px; height: 26px; padding: 0 8px; border-radius: 7px;
    font-family: var(--font-mono); font-size: 12px; font-weight: 700; letter-spacing: .04em;
    background: color-mix(in srgb, var(--accent) 12%, #fff); color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 28%, transparent);
    transition: background .3s, color .3s;
  }
  .go-office:hover .go-code { background: var(--accent); color: #fff; }
  .go-head b { font-size: clamp(17px, 1.5vw, 21px); font-weight: 800; letter-spacing: .01em; color: var(--ink); }

  .go-addr { position: relative; margin-top: 16px; font-style: normal; display: flex; flex-direction: column; gap: 6px; }
  .go-addr span { font-size: 14px; line-height: 1.45; color: var(--muted); }

  .go-pin {
    position: absolute; right: clamp(20px, 2.2vw, 28px); top: clamp(22px, 2.2vw, 30px);
    display: grid; place-items: center; width: 30px; height: 30px; border-radius: 50%;
    background: color-mix(in srgb, var(--accent) 12%, #fff); color: var(--accent); font-size: 13px; line-height: 0;
    opacity: 0; transform: translateY(-6px); transition: opacity .35s, transform .35s cubic-bezier(.16,1,.3,1);
  }
  .go-office:hover .go-pin { opacity: 1; transform: translateY(0); }

  /* entrance: cards rise in on scroll */
  @media (prefers-reduced-motion: no-preference) {
    .go-office { opacity: 0; transform: translateY(18px); }
    #offices.in .go-office { opacity: 1; transform: translateY(0); transition: opacity .6s ease var(--d), transform .6s cubic-bezier(.16,1,.3,1) var(--d), box-shadow .4s, border-color .4s; }
    #offices.in .go-office:hover { transform: translateY(-6px); }
  }
</style>

<script>
  // reveal cards when the section scrolls into view
  const sec = document.getElementById('offices')
  if (sec) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { sec.classList.add('in'); io.disconnect() } })
    }, { threshold: 0.2 })
    io.observe(sec)
  }
</script>
