---
const REASONS = [
  { ic: 'fi-rr-chart-line-up', title: 'Growth-centered teams', desc: 'We are driven by results and growth. Our decisions are goal-centric — engagement and retention prioritized alongside user experience.' },
  { ic: 'fi-rr-document-signed', title: 'Security & IP protection', desc: 'With ISO 27001 & 9001 intact, your data is handled with the utmost security and shared only with your team, under standard dev, test and deploy protocols.' },
  { ic: 'fi-rr-chart-pie', title: 'No cost overruns', desc: 'Agile methodology and weekly standups keep us on the same page as your core team to avoid rework — quality, transparency and no cost overruns.' },
  { ic: 'fi-rr-lock', title: 'Application security', desc: 'Flawless security matters as much as bug-free code. We run static, dynamic, interactive and mobile testing, finding and fixing issues for hardened apps.' },
  { ic: 'fi-rr-heart', title: 'CX-driven development', desc: 'Experience is the highest-selling commodity today. Our CX-driven approach to building products gives you a real competitive advantage.' },
  { ic: 'fi-rr-settings', title: 'DevOps approach', desc: 'From assessment to implementation — open communication, collaboration and automation, with continuous evolution baked into how we ship.' },
]
const STATS = [
  { n: '98%', label: 'Client retention' },
  { n: '200+', label: 'Senior engineers' },
  { n: 'ISO', label: '27001 & 9001 certified' },
]
---
<section id="why" class="why-labs py-[var(--section-y)]">
  <div class="wrap relative">
    <!-- big centered headline -->
    <div class="text-center max-w-[920px] mx-auto">
      <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk">
        <i class="fi fi-rr-badge-check text-teal"></i> Why BiztechCS
      </span>
      <h2 data-reveal style="--d:.06s" class="why-h2 mt-5 font-black tracking-[-0.045em] leading-[0.98]">
        Over <span class="grad">1,200+ projects</span> delivered.
      </h2>
      <p data-reveal style="--d:.12s" class="mt-6 text-muted text-[clamp(16px,1.4vw,20px)] leading-[1.55] max-w-[640px] mx-auto">
        We deliver development solutions and services — but the way we deliver is what differentiates us.
      </p>

      <!-- inline stats -->
      <div data-reveal style="--d:.18s" class="mt-9 flex flex-wrap items-center justify-center gap-x-10 gap-y-4">
        {STATS.map((s, i) => (
          <div class="flex items-center gap-10 max-[560px]:gap-4">
            <div class="text-center">
              <div class="grad text-[clamp(30px,3.4vw,42px)] font-black tracking-[-0.04em] leading-none">{s.n}</div>
              <div class="mt-1.5 text-[12.5px] font-semibold text-muted">{s.label}</div>
            </div>
            {i < STATS.length - 1 && <span class="w-px h-9 bg-line max-[560px]:hidden"></span>}
          </div>
        ))}
      </div>
    </div>

    <!-- tilted floating-card carousel (labs.google style) -->
    <div data-reveal class="rcarousel mt-[clamp(44px,5vw,68px)]">
      <div class="rtrack" data-rtrack>
        {REASONS.map((r, i) => (
          <article class="rcard group" style={`--tilt:${(i % 2 === 0 ? -1 : 1) * (1.5 + (i % 3))}deg`}>
            <span class="ricon grid place-items-center text-[22px]">
              <i class={`fi ${r.ic}`}></i>
            </span>
            <h3 class="mt-6 text-[19px] font-extrabold tracking-[-0.02em] text-ink">{r.title}</h3>
            <p class="mt-2.5 text-[14px] leading-[1.55] text-muted flex-1">{r.desc}</p>
          </article>
        ))}
      </div>
    </div>

    <!-- carousel controls -->
    <div class="mt-9 flex items-center justify-center gap-3">
      <button class="rnav" data-rprev aria-label="Previous"><i class="fi fi-rr-angle-left"></i></button>
      <button class="rnav" data-rnext aria-label="Next"><i class="fi fi-rr-angle-right"></i></button>
    </div>
  </div>
</section>

<style>
  .why-labs { position: relative; overflow: hidden; background: #f7f5ef; }
  .why-h2 { font-size: clamp(40px, 6.5vw, 88px); }
  .grad { background: linear-gradient(92deg, #0ea5e9 0%, #6366f1 45%, #ec4899 100%); -webkit-background-clip: text; background-clip: text; color: transparent; }
</style>
