---
// FEATURED VIDEO — drop the real YouTube/Vimeo embed URL into `embed` to enable playback.
// Poster + person are real biztechcs video-testimonial assets.
const FEATURED = {
  name: 'Adam Harvey',
  role: 'Co-founder & CEO, Proofed Inc',
  quote: 'Biztech has been a genuine technology partner — they understand the product, not just the tickets.',
  poster: 'https://www.biztechcs.com/wp-content/uploads/2020/02/PME--jpg-webp.webp',
  embed: '', // e.g. 'https://www.youtube.com/embed/XXXXXXXX?autoplay=1' — leave '' to link out instead
  fallback: 'https://www.biztechcs.com/clients/video-testimonials/',
}
const QUOTES = [
  { q: 'They felt like an extension of our own team. The time-zone overlap meant we never lost a day — and the code quality was excellent.', name: 'James Miller', role: 'CTO, US SaaS Startup', src: 'Clutch' },
  { q: 'Biztech delivered our Odoo ERP on time and under budget. Their senior engineers understood our manufacturing workflows without hand-holding.', name: 'Sarah Chen', role: 'VP of Operations, SteelWorks Inc', src: 'Google' },
  { q: "We've worked with three offshore vendors before. Biztech is the only one that actually owns the outcome — not just the ticket.", name: 'Marc Dupont', role: 'Director of IT, EU Retail Group', src: 'Clutch' },
]
---
<section id="testimonials" class="surface-dark py-[var(--section-y)]">
  <div class="wrap">
    <div class="max-w-[720px] mb-[clamp(40px,5vw,56px)]">
      <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] eyebrow">
        <i class="fi fi-rr-comment-quote"></i> Testimonials
      </span>
      <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(30px,4vw,52px)] font-black tracking-[-0.04em] leading-[1.04] text-white">
        Words that <span class="accent">make an impact.</span>
      </h2>
    </div>

    <div class="grid grid-cols-[1.05fr_0.95fr] gap-[18px] items-stretch max-[980px]:grid-cols-1">
      <!-- featured video -->
      <button
        data-reveal
        class="vtest group relative overflow-hidden rounded-3xl text-left min-h-[420px] max-[980px]:min-h-[300px]"
        data-embed={FEATURED.embed}
        data-fallback={FEATURED.fallback}
        aria-label={`Play video testimonial — ${FEATURED.name}`}
      >
        <img src={FEATURED.poster} alt={`${FEATURED.name} — ${FEATURED.role}`} loading="lazy" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
        <span class="vtest-shade absolute inset-0"></span>
        <span class="vtest-play absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 grid place-items-center w-[72px] h-[72px] rounded-full">
          <i class="fi fi-sr-play text-white text-[22px]"></i>
        </span>
        <span class="relative z-[1] flex h-full flex-col justify-end p-8">
          <span class="inline-flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-[0.1em] text-white/80 mb-3"><i class="fi fi-rr-video-camera text-teal"></i> Video story</span>
          <p class="text-[clamp(16px,1.4vw,19px)] font-bold leading-[1.4] text-white max-w-[440px]">"{FEATURED.quote}"</p>
          <div class="mt-4">
            <b class="block text-[15px] font-extrabold text-white leading-tight">{FEATURED.name}</b>
            <span class="block text-[12.5px] text-white/65">{FEATURED.role}</span>
          </div>
        </span>
      </button>

      <!-- text quotes -->
      <div class="flex flex-col gap-[14px]">
        {QUOTES.map((t, i) => (
          <div data-reveal style={`--d:${(0.08 + i * 0.06).toFixed(2)}s`} class="tq-card flex flex-col rounded-3xl p-6 flex-1">
            <div class="flex gap-1 text-teal text-[13px] mb-3">
              <i class="fi fi-sr-star"></i><i class="fi fi-sr-star"></i><i class="fi fi-sr-star"></i><i class="fi fi-sr-star"></i><i class="fi fi-sr-star"></i>
            </div>
            <p class="text-[14px] leading-[1.55] text-white/90 flex-1">"{t.q}"</p>
            <div class="mt-5 flex items-center justify-between gap-3">
              <div class="flex items-center gap-3 min-w-0">
                <span class="shrink-0 grid place-items-center w-10 h-10 rounded-full bg-teal text-white text-[12px] font-extrabold">{t.name.split(' ').map(w=>w[0]).join('')}</span>
                <div class="min-w-0">
                  <b class="block text-[13.5px] font-extrabold text-white leading-tight truncate">{t.name}</b>
                  <span class="block text-[12px] text-white/55 truncate">{t.role}</span>
                </div>
              </div>
              <span class="shrink-0 text-[10.5px] font-extrabold uppercase tracking-[0.08em] text-white/45">{t.src}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div data-reveal style="--d:.1s" class="mt-12 flex flex-wrap items-center justify-center gap-x-7 gap-y-3 text-[14px] font-bold text-white">
      <span class="inline-flex items-center gap-2"><i class="fi fi-sr-star text-teal"></i> 4.9/5 <span class="text-white/55 font-semibold">on Clutch</span></span>
      <span class="w-px h-5 bg-white/15"></span>
      <span class="inline-flex items-center gap-2"><i class="fi fi-sr-star text-teal"></i> 4.8/5 <span class="text-white/55 font-semibold">on Google</span></span>
      <span class="w-px h-5 bg-white/15"></span>
      <span class="text-white/55 font-semibold">Based on 80+ verified reviews</span>
    </div>
  </div>

  <!-- video lightbox -->
  <dialog class="vtest-modal" aria-label="Video testimonial">
    <button class="vtest-close" aria-label="Close video">&times;</button>
    <div class="vtest-frame"></div>
  </dialog>
</section>

<style>
  .eyebrow { color: #7dd3fc; }
  .eyebrow i { color: #38bdf8; }
  .accent { background: linear-gradient(100deg, #38bdf8, #818cf8); -webkit-background-clip: text; background-clip: text; color: transparent; }

  .tq-card { background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.1); backdrop-filter: blur(8px); transition: background .3s, border-color .3s, transform .3s; }
  .tq-card:hover { transform: translateY(-3px); background: rgba(255, 255, 255, 0.07); border-color: rgba(125, 211, 252, 0.35) !important; }

  .vtest { border: 1px solid rgba(255, 255, 255, 0.12); cursor: pointer; }
  .vtest-shade { background: linear-gradient(180deg, rgba(11, 18, 32, 0.1) 0%, rgba(11, 18, 32, 0.35) 42%, rgba(11, 18, 32, 0.82) 76%, rgba(11, 18, 32, 0.97) 100%); }
  .vtest-play { background: rgba(14, 165, 233, 0.92); box-shadow: 0 12px 40px -10px rgba(14, 165, 233, 0.7); transition: transform .35s cubic-bezier(.16,1,.3,1), background .3s; }
  .vtest-play i { line-height: 0; margin-left: 3px; }
  .vtest:hover .vtest-play { transform: translate(-50%, -50%) scale(1.08); background: #0ea5e9; }
  .vtest-play::before { content: ""; position: absolute; inset: -10px; border-radius: 999px; border: 1px solid rgba(125, 211, 252, 0.4); animation: vpulse 2.4s ease-out infinite; }
  @keyframes vpulse { 0% { transform: scale(1); opacity: .7 } 100% { transform: scale(1.5); opacity: 0 } }

  .vtest-modal { width: min(900px, 92vw); border: 0; background: transparent; padding: 0; color: #fff; }
  .vtest-modal::backdrop { background: rgba(7, 11, 20, 0.86); backdrop-filter: blur(4px); }
  .vtest-frame { position: relative; width: 100%; aspect-ratio: 16/9; border-radius: 18px; overflow: hidden; background: #000; }
  .vtest-frame iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
  .vtest-close { position: absolute; top: -44px; right: 0; background: transparent; border: 0; color: #fff; font-size: 32px; line-height: 1; cursor: pointer; opacity: .8; }
  .vtest-close:hover { opacity: 1; }

  @media (prefers-reduced-motion: reduce) { .vtest-play::before { animation: none; } .vtest img { transition: none; } }
</style>

<script>
  const sec = document.querySelector('#testimonials')
  if (sec) {
    const trigger = sec.querySelector('.vtest')
    const modal = sec.querySelector('.vtest-modal')
    const frame = sec.querySelector('.vtest-frame')
    const closeBtn = sec.querySelector('.vtest-close')
    const open = () => {
      const embed = trigger.dataset.embed
      if (!embed) { window.open(trigger.dataset.fallback, '_blank', 'noopener'); return }
      frame.innerHTML = `<iframe src="${embed}" allow="autoplay; encrypted-media; picture-in-picture" allowfullscreen></iframe>`
      modal.showModal()
    }
    const close = () => { modal.close(); frame.innerHTML = '' }
    trigger.addEventListener('click', open)
    closeBtn.addEventListener('click', close)
    modal.addEventListener('click', (e) => { if (e.target === modal) close() })
    modal.addEventListener('close', () => { frame.innerHTML = '' })
  }
</script>
