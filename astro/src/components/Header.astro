  </div>

  <!-- Mobile sheet -->
  <div class="mobile-nav" id="mobileNav">
    <nav class="m-acc">
      {MENU.map((m, i) => (
        <a class="m-top" href={m.href} data-mclose style={`--i:${i}`}>{m.label}</a>
      ))}
    </nav>
    <a class="btn-labs m-cta" href={`${BASE}/contact`} data-mclose>
      <span class="lbl"><span class="roll">
        <span class="top">{[...'Get Started'].map((c, i) => <span style={`--i:${i}`}>{c}</span>)}</span>
        <span class="bot">{[...'Get Started'].map((c, i) => <span style={`--i:${i}`}>{c}</span>)}</span>
      </span></span>
    </a>
  </div>
</header>

<style>
  /* mega panels hidden by default; .show reveals (replaces framer-motion) */
  .mega { opacity: 0; visibility: hidden; transform: translate(-50%, 16px); transition: opacity 0.28s cubic-bezier(0.16,1,0.3,1), transform 0.28s cubic-bezier(0.16,1,0.3,1), visibility 0.28s; }
  .mega.show { opacity: 1; visibility: visible; transform: translate(-50%, 8px); }
</style>

<script>
  const EASE = 'cubic-bezier(0.16,1,0.3,1)'
  const hdr = document.getElementById('hdr')
  const menu = document.getElementById('menu')
  const pill = menu && menu.querySelector('.pill')
  const items = menu ? Array.from(menu.querySelectorAll('li')) : []
  const megaWrap = document.getElementById('megaWrap')
  const megas = megaWrap ? Array.from(megaWrap.querySelectorAll('.mega')) : []
  let hideTimer = null

  /* ---- mega menu + sliding pill ---- */
  const showMega = (key) => {
    megas.forEach((m) => m.classList.toggle('show', m.dataset.mega === key))
  }
  const movePill = (li) => {
    if (!pill) return
    pill.style.width = li.offsetWidth + 'px'
    pill.style.transform = `translateX(${li.offsetLeft}px) scale(1)`
    pill.style.opacity = '1'
  }
  const resetMenu = () => {
    if (pill) { pill.style.opacity = '0'; pill.style.transform = 'translateX(' + (pill.style.transform.match(/translateX\(([^)]+)\)/)?.[1] || '0px') + ') scale(0.9)' }
    items.forEach((li) => { li.classList.remove('open'); const a = li.querySelector('a'); if (a) a.style.color = '' })
    megas.forEach((m) => m.classList.remove('show'))
  }
  items.forEach((li) => {
    li.addEventListener('mouseenter', () => {
      clearTimeout(hideTimer)
      movePill(li)
      items.forEach((x) => {
        const isOpen = x === li && !!li.dataset.mega
        x.classList.toggle('open', isOpen)
        const a = x.querySelector('a')
        if (a) a.style.color = (x === li) ? '#fff' : ''   // keep hovered/open item readable over the dark pill
      })
      if (li.dataset.mega) showMega(li.dataset.mega); else megas.forEach((m) => m.classList.remove('show'))
    })
  })
  if (hdr) {
    hdr.addEventListener('mouseenter', () => clearTimeout(hideTimer))
    hdr.addEventListener('mouseleave', () => { hideTimer = setTimeout(resetMenu, 120) })
  }

  /* ---- scroll: scrolled state only (header stays pinned, no auto-hide) ---- */
  // header wrap: width finishes shrinking exactly as the pill background finishes appearing.
  // Pill background is driven by .scrolled (toggles at TRIGGER) with a .4s transition.
  // We map width over the SAME window: starts at TRIGGER, completes by TRIGGER+RANGE,
  // where RANGE is tuned so the width settles together with the .4s background fade.
  const hwrap = hdr && hdr.querySelector('.wrap')
  const W_MAX = 1920, W_MIN = 1440, TRIGGER = 30, RANGE = 130
  const onScroll = () => {
    const y = window.scrollY
    if (hdr) hdr.classList.toggle('scrolled', y > TRIGGER)
    if (hwrap) {
      const p = Math.min(1, Math.max(0, (y - TRIGGER) / RANGE)) // 0 at trigger -> 1 when pill is fully formed
      hwrap.style.maxWidth = (W_MAX - (W_MAX - W_MIN) * p) + 'px'
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true })
  onScroll()

  /* ---- mobile sheet ---- */
  const burger = document.getElementById('burger')
  const toggleMobile = (open) => {
    document.body.classList.toggle('nav-open', open)
    document.body.style.overflow = open ? 'hidden' : ''
    if (burger) burger.setAttribute('aria-expanded', String(open))
  }
  if (burger) burger.addEventListener('click', () => toggleMobile(!document.body.classList.contains('nav-open')))
  document.querySelectorAll('[data-mclose]').forEach((a) => a.addEventListener('click', () => toggleMobile(false)))
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { resetMenu(); toggleMobile(false) } })
</script>
