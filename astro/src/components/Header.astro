    <div class="mega" data-mega="company">
      <div class="wrap mega-grid four">
        <div class="mega-col"><h4>About</h4><ul>
          <li><a href={`${BASE}/company`}><i class="fi fi-rr-building mi"></i>Company Overview</a></li>
          <li><a href={`${BASE}/leadership`}><i class="fi fi-rr-user-crown mi"></i>Leadership Team</a></li>
          <li><a href="#about"><i class="fi fi-rr-rocket-lunch mi"></i>Our Ventures</a></li>
          <li><a href={`${BASE}/careers`}><i class="fi fi-rr-briefcase mi"></i>Careers</a></li>
        </ul></div>
        <div class="mega-col"><h4>Connect</h4><ul>
          <li><a href={`${BASE}/contact`}><i class="fi fi-rr-phone-call mi"></i>Contact Us</a></li>
          <li><a href="#about"><i class="fi fi-rr-marker mi"></i>Office Locations</a></li>
          <li><a href="#about"><i class="fi fi-rr-handshake mi"></i>Partner Program</a></li>
          <li><a href="#about"><i class="fi fi-rr-megaphone mi"></i>Media &amp; Press</a></li>
        </ul></div>
        <div class="mega-col promo span2">
          <span class="label"><span class="idx"><i class="fi fi-rr-heart"></i></span> Life @ Biztech</span>
          <h3>Meet the team behind 1,200+ successful projects.</h3>
          <p class="mega-p">200+ engineers across USA, Europe &amp; India — building enterprise software with craft and accountability.</p>
          <a href={`${BASE}/careers`} class="link-arrow">Join our team <i class="fi fi-rr-arrow-right"></i></a>
