        <div class="mega-col"><h4>Learn</h4><ul>
          <li><a href={`${BASE}/resources`}><i class="fi fi-rr-pen-nib mi"></i>Blog</a></li>
          <li><a href={`${BASE}/resources`}><i class="fi fi-rr-book-alt mi"></i>Whitepapers &amp; Guides</a></li>
