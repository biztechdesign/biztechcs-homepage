---
const BASE = import.meta.env.BASE_URL
const MENU = [
  { label: 'AI Engineering', href: '#ai-native', mega: null },
  { label: 'Services', href: '#services', mega: 'services' },
  { label: 'Industries', href: '#industries', mega: 'industries' },
  { label: 'Case Studies', href: `${BASE}/case-studies`, mega: 'work' },
  { label: 'Why BiztechCS', href: `${BASE}/why-biztechcs`, mega: 'why' },
  { label: 'Resources', href: `${BASE}/resources`, mega: 'resources' },
  { label: 'Company', href: '#about', mega: 'company' },
]
---
<header id="hdr">
  <div class="wrap"><div class="nav">
    <a href="#hero-sec" class="logo" aria-label="Biztech — back to top">
      <img class="lg-dark" src={`${import.meta.env.BASE_URL}/assets/biztech-logo.svg`} alt="Biztech" />
      <img class="lg-light" src={`${import.meta.env.BASE_URL}/assets/biztech-logo.svg`} alt="Biztech" />
    </a>

    <nav class="primary">
      <ul class="menu" id="menu">
        <span class="pill"></span>
        {MENU.map((m, i) => (
          <li class={m.mega ? 'has-mega' : ''} data-mega={m.mega} data-i={i}>
            <a href={m.href}>{m.label}{m.mega && <i class="fi fi-rr-angle-small-down caret"></i>}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="nav-cta">
      <a class="btn-labs" href={`${BASE}/contact`}>
        <span class="lbl"><span class="roll">
          <span class="top">{[...'Get Started'].map((c, i) => <span style={`--i:${i}`}>{c}</span>)}</span>
          <span class="bot">{[...'Get Started'].map((c, i) => <span style={`--i:${i}`}>{c}</span>)}</span>
        </span></span>
      </a>
      <button class="burger" id="burger" aria-label="Menu" aria-expanded="false"><span></span><span></span><span></span></button>
    </div>
  </div></div>

  <!-- Mega panels (all rendered; toggled by JS) -->
  <div class="mega-wrap" id="megaWrap">
    <div class="mega" data-mega="services">
      <div class="wrap mega-grid">
        <div class="mega-col"><h4>Software Product Engineering</h4><ul>
          <li><a href="#services"><i class="fi fi-rr-compass-alt mi"></i>Product Strategy &amp; Roadmapping</a></li>
          <li><a href="#services"><i class="fi fi-rr-code-simple mi"></i>Custom Software Development</a></li>
          <li><a href="#services"><i class="fi fi-rr-rocket-lunch mi"></i>MVP &amp; Prototype Development</a></li>
          <li><a href="#services"><i class="fi fi-rr-mobile-notch mi"></i>Mobile App Development</a></li>
          <li><a href="#services"><i class="fi fi-rr-refresh mi"></i>Legacy Modernization</a></li>
          <li><a href="#services"><i class="fi fi-rr-shield-check mi"></i>QA &amp; Testing</a></li>
        </ul></div>
        <div class="mega-col"><h4>AI &amp; Data</h4><ul>
          <li><a href={`${BASE}/services/ai-ml-development`}><i class="fi fi-rr-brain mi"></i>AI / ML Development</a></li>
          <li><a href="#services"><i class="fi fi-rr-sparkles mi"></i>Generative AI Solutions</a></li>
          <li><a href="#services"><i class="fi fi-rr-robot mi"></i>AI Agent Development</a></li>
