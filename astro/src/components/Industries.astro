---
const INDUSTRIES = [
  { ic: 'fi-rr-stethoscope', name: 'Healthcare & Life Sciences', desc: 'HIPAA-aligned platforms, patient portals and telehealth.' },
  { ic: 'fi-rr-shopping-bag', name: 'Retail & Ecommerce', desc: 'Headless storefronts, marketplaces and POS integrations.' },
  { ic: 'fi-rr-industry-alt', name: 'Manufacturing & Logistics', desc: 'ERP, supply-chain visibility and warehouse automation.' },
  { ic: 'fi-rr-bank', name: 'FinTech & Banking', desc: 'Secure payments, lending platforms and compliance workflows.' },
  { ic: 'fi-rr-graduation-cap', name: 'Education & eLearning', desc: 'LMS platforms, assessment engines and student portals.' },
  { ic: 'fi-rr-network', name: 'SaaS & Startups', desc: 'MVPs to scale-ready products with senior engineering teams.' },
]
---
<section id="industries" class="surface-tint py-[var(--section-y)]">
  <div class="wrap">
    <div class="grid grid-cols-[0.9fr_1.1fr] gap-[clamp(40px,6vw,90px)] items-start max-[900px]:grid-cols-1 max-[900px]:gap-10">

      <!-- left: framing -->
      <div class="max-[900px]:max-w-[640px] min-[900px]:sticky min-[900px]:top-28">
        <span data-reveal class="inline-flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.14em] text-teal-dk">
          <i class="fi fi-rr-globe text-teal"></i> Industries we serve
        </span>
        <h2 data-reveal style="--d:.06s" class="mt-4 text-[clamp(30px,4vw,52px)] font-black tracking-[-0.04em] leading-[1.04]">
          Domain depth, not just <span class="accent">developers for hire.</span>
        </h2>
        <p data-reveal style="--d:.12s" class="mt-5 text-muted text-[clamp(15px,1.2vw,17px)] leading-[1.6] max-w-[420px]">
          Since 2006 we've shipped software across regulated and high-scale industries — so your team starts with engineers who already understand the rules of your world.
        </p>
        <a data-reveal style="--d:.18s" href="#cta" class="seeall mt-7 inline-flex items-center gap-2 text-[14.5px] font-bold text-ink">
          Discuss your industry <i class="fi fi-rr-arrow-right"></i>
        </a>
      </div>

      <!-- right: industry list -->
      <div class="grid grid-cols-2 gap-[14px] max-[560px]:grid-cols-1">
        {INDUSTRIES.map((it, i) => (
          <div data-reveal style={`--d:${(0.1 + i * 0.05).toFixed(2)}s`} class="ind group flex flex-col rounded-2xl bg-white border border-line p-6 transition duration-300 hover:-translate-y-1">
            <span class="grid place-items-center w-12 h-12 rounded-xl bg-teal/10 border border-teal/20 text-teal text-[20px] transition duration-300 group-hover:bg-teal group-hover:text-white group-hover:border-transparent">
              <i class={`fi ${it.ic}`}></i>
            </span>
            <h3 class="mt-5 text-[16.5px] font-extrabold tracking-[-0.02em] text-ink leading-tight">{it.name}</h3>
            <p class="mt-2 text-[13.5px] leading-[1.5] text-muted">{it.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .accent { background: linear-gradient(100deg, #0ea5e9, #0369a1); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .seeall i { transition: transform 0.3s; line-height: 0; }
  .seeall:hover i { transform: translateX(4px); }
  .seeall:hover { color: #0369a1; }
  .ind:hover { border-color: rgba(14, 165, 233, 0.4); box-shadow: 0 18px 44px -26px rgba(14, 165, 233, 0.3); }
</style>
